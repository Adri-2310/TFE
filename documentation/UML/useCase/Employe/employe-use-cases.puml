@startuml Employe-WorkZen
title Diagramme de Cas d'Utilisation - Employé\nWorkZen Secrétariat Social

left to right direction

skinparam backgroundColor #FFFFFF
skinparam actorBackgroundColor #D5E8D4
skinparam actorBorderColor #82B366

actor Employé

rectangle "WorkZen - Système" {

    rectangle "1. AUTHENTIFICATION" #E1D5E7 {
        usecase UC0 as "Se connecter"
    }

    rectangle "2. CONSULTATION FICHE DE PAIE" #DAE8FC {
        usecase UC10 as "Consulter fiche\nde paie"
    }

    rectangle "3. TÉLÉCHARGEMENT DOCUMENTS" #D5E8D4 {
        usecase UC20 as "Télécharger documents"
    }

    rectangle "4. INFORMATIONS PERSONNELLES" #FFE6CC {
        usecase UC30 as "Consulter\ninformations personnelles"
    }

    rectangle "5. SUPPORT" #CCFFCC {
        usecase UC40 as "Accéder support"
    }
}

Employé --> UC0
Employé --> UC10
Employé --> UC20
Employé --> UC30
Employé --> UC40

note right of UC0
  Authentification sécurisée
  de l'employé
end note

note right of UC10
  Consultation de sa fiche
  de paie mensuelle
end note

note right of UC20
  Téléchargement des documents
  (fiche de paie, certificats)
end note

note right of UC30
  Consultation de ses
  données personnelles et contrat
end note

note right of UC40
  Accès au support
  et messagerie
end note

@enduml
