@startuml SuperAdmin_UC01-00_Connexion_Detaille
title UC-01-00: Se Connecter - SuperAdmin (Tous Scenarios)

actor SuperAdmin as SA
participant Dashboard
participant Systeme
participant DB
participant Logs

SA -> Dashboard: 1. Accede page connexion
activate Dashboard

Dashboard --> SA: 2. Affiche formulaire (email + mot de passe)
deactivate Dashboard

SA -> Dashboard: 3. Saisit identifiants et clique Connexion
activate Dashboard

Dashboard -> Dashboard: 4. Valide format email et champs non vides

alt Email invalide ou champs vides
  Dashboard --> SA: ERREUR: Format invalide
  deactivate Dashboard
else Donnees valides
  Dashboard -> Systeme: 5. Envoie email + mot de passe
  activate Systeme

  alt Systeme indisponible (API DOWN)
    Systeme --> Dashboard: ERREUR 503: Service indisponible
    deactivate Systeme
    Dashboard -> Logs: Log tentative connexion: API DOWN
    activate Logs
    Logs --> Dashboard: Event loggue
    deactivate Logs
    Dashboard --> SA: ERREUR: Service d'authentification DOWN
    deactivate Dashboard
  else Systeme repond OK
    Systeme -> DB: 6. Recupere compte par email
    activate DB

    alt Compte non trouve
      DB --> Systeme: Erreur: Email inexistant
      Systeme --> Dashboard: ERREUR 401: Compte inexistant
      deactivate Systeme
      Dashboard -> Logs: Log tentative connexion: Email invalide
      activate Logs
      Logs --> Dashboard: Event loggue
      deactivate Logs
      Dashboard --> SA: ERREUR: Email ou mot de passe incorrect
      deactivate DB
      deactivate Dashboard
    else Compte existe
      DB --> Systeme: Retourne compte avec hash mot de passe
      deactivate DB

      Systeme -> Systeme: 7. Hash mot de passe saisi et compare

      alt Mot de passe incorrect
        Systeme --> Dashboard: ERREUR 401: Mot de passe incorrect
        deactivate Systeme
        Dashboard -> Logs: Log tentative connexion: MDP incorrect
        activate Logs
        Logs --> Dashboard: Event loggue
        deactivate Logs
        Dashboard --> SA: ERREUR: Email ou mot de passe incorrect
        deactivate Dashboard
      else Mot de passe correct
        Systeme -> DB: 8. Verifie statut compte
        activate DB

        alt Compte bloque ou desactive
          DB --> Systeme: Statut = BLOQUE/INACTIF
          Systeme --> Dashboard: ERREUR 403: Compte desactive
          deactivate Systeme
          Dashboard -> Logs: Log tentative connexion: Compte desactive
          activate Logs
          Logs --> Dashboard: Event loggue
          deactivate Logs
          Dashboard --> SA: ERREUR: Compte desactive par admin
          deactivate DB
          deactivate Dashboard
        else Compte actif avec role SuperAdmin
          DB --> Systeme: Statut = ACTIF, Role = SuperAdmin
          deactivate DB

          Systeme -> Systeme: 9. Genere JWT token (secret, role, expiration 8h)

          Systeme -> DB: 10. Enregistre log audit: Connexion reussie (timestamp, IP, user-agent)
          activate DB
          DB --> Systeme: Audit log enregistre en BD
          deactivate DB

          Systeme -> Logs: 11. Log event: SuperAdmin connexion reussie
          activate Logs
          Logs --> Systeme: Event loggue pour monitoring
          deactivate Logs

          Systeme --> Dashboard: 12. Authentification REUSSIE + Token JWT
          deactivate Systeme

          Dashboard -> Systeme: 13. Charge dashboard (secretariats, stats, users, analytics)
          activate Systeme

          alt Erreur chargement donnees
            Systeme --> Dashboard: ERREUR 500: Donnees indisponibles
            deactivate Systeme
            Dashboard -> Logs: Log event: Erreur chargement dashboard
            activate Logs
            Logs --> Dashboard: Event loggue
            deactivate Logs
            Dashboard --> SA: ERREUR: Impossible charger dashboard
            deactivate Dashboard
          else Donnees chargees OK
            Systeme --> Dashboard: Dashboard complet avec toutes donnees
            deactivate Systeme

            Dashboard -> DB: 14. Enregistre log audit: Dashboard load OK (timestamp)
            activate DB
            DB --> Dashboard: Audit log enregistre en BD
            deactivate DB

            Dashboard -> Logs: 15. Log event: Dashboard charge avec succes
            activate Logs
            Logs --> Dashboard: Event loggue pour monitoring
            deactivate Logs

            Dashboard --> SA: 16. SUCCES! Dashboard complet affiche\nAcces: Secretariats, Users, Analytics, Config
            deactivate Dashboard

            note over SA, Logs
              **CONNEXION REUSSIE:**
              - SuperAdmin authentifie OK
              - Token JWT genere (8h)
              - Dashboard charge OK
              - DB: Audit logs persistes (long terme)
              - Logs: Events loggues (monitoring temps reel)
              - Toutes permissions OK
            end note
          end
        end
      end
    end
  end
end

@enduml
