@startuml SC-27-Gerer-Employes
!theme plain
title Diagramme de Collaboration - Gerer Employes Clients (Consultant)

object Consultant
object "Interface Employes" as InterfaceEmployes
object "Service Employes" as ServiceEmployes
object "Base Données" as BaseDonnees
object "Service Audit" as ServiceAudit

Consultant --> InterfaceEmployes : 1: selectionner(client)
InterfaceEmployes --> ServiceEmployes : 2: obtenirEmployesClient(clientId)
ServiceEmployes --> BaseDonnees : 3: executerRequete(employes)
BaseDonnees --> ServiceEmployes : 3.1: listeEmployes[]
ServiceEmployes --> InterfaceEmployes : 4: afficher(liste)
InterfaceEmployes --> Consultant : 4.1: montrer(employes)

Consultant --> InterfaceEmployes : 5: consulter(details_employe)
InterfaceEmployes --> ServiceEmployes : 6: obtenirDetailsEmploye(employeId)
ServiceEmployes --> BaseDonnees : 7: executerRequete(details)
BaseDonnees --> ServiceEmployes : 7.1: donneeEmploye
ServiceEmployes --> InterfaceEmployes : 8: afficher(profil)
InterfaceEmployes --> Consultant : 9: montrer(informations)

Consultant --> InterfaceEmployes : 10: modifier(donnees)
InterfaceEmployes --> ServiceEmployes : 11: mettreAJourEmploye(employeId, donnees)
ServiceEmployes --> BaseDonnees : 12: mettreAJourEnregistrement(donnees)
BaseDonnees --> ServiceEmployes : 12.1: ok

ServiceEmployes --> ServiceAudit : 12.2: enregistrerAction("EMPLOYE_MODIFIE")
ServiceAudit --> BaseDonnees : 12.3: sauvegarderLog()

ServiceEmployes --> InterfaceEmployes : 13: succes()
InterfaceEmployes --> Consultant : 14: afficher("Employe modifie")

@enduml
