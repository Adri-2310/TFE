@startuml SC-25-Connexion-Consultant
!theme plain
title Diagramme de Collaboration - Se Connecter (Consultant)

object Consultant
object "Page Connexion" as PageConnexion
object "Service Auth" as ServiceAuth
object "Base Données" as BaseDonnees
object "Service Session" as ServiceSession
object "Service Audit" as ServiceAudit
object "Dashboard Consultant" as Dashboard

Consultant --> PageConnexion : 1: saisir(email, motDePasse)
PageConnexion --> ServiceAuth : 2: authentifier(email, motDePasse)
ServiceAuth --> BaseDonnees : 3: trouverUtilisateur(email)
BaseDonnees --> ServiceAuth : 3.1: donneeUtilisateur
ServiceAuth --> ServiceAuth : 4: verifierMotDePasse()
ServiceAuth --> PageConnexion : 5: connexionReussie()
PageConnexion --> ServiceSession : 6: creerSession(idUtilisateur)
ServiceSession --> BaseDonnees : 7: sauvegarderSession(jwt)
BaseDonnees --> ServiceSession : 7.1: ok

ServiceSession --> ServiceAudit : 7.2: enregistrerAction("CONNEXION_CONSULTANT")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceSession --> PageConnexion : 8: jeton
PageConnexion --> Dashboard : 9: rediriger()
Dashboard --> Consultant : 10: afficher(portail_consultant)

@enduml
