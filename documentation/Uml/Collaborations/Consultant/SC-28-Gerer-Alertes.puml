@startuml SC-28-Gerer-Alertes
!theme plain
title Diagramme de Collaboration - Gerer Calendrier d'Alertes (Consultant)

object Consultant
object "Interface Alertes" as InterfaceAlertes
object "Service Alertes" as ServiceAlertes
object "Base Données" as BaseDonnees
object "Service Scheduleur" as ServiceScheduleur
object "Service Audit" as ServiceAudit

Consultant --> InterfaceAlertes : 1: acceder("Alertes")
InterfaceAlertes --> ServiceAlertes : 2: obtenirAlertes(consultantId)
ServiceAlertes --> BaseDonnees : 3: executerRequete(alertes)
BaseDonnees --> ServiceAlertes : 3.1: listeAlertes[]
ServiceAlertes --> InterfaceAlertes : 4: afficher(calendrier)
InterfaceAlertes --> Consultant : 4.1: montrer(alertes)

Consultant --> InterfaceAlertes : 5: creer(alerte)
InterfaceAlertes --> ServiceAlertes : 6: creerAlerte({titre, date, type, clients})
ServiceAlertes --> BaseDonnees : 7: sauvegarderAlerte(alerte)
BaseDonnees --> ServiceAlertes : 7.1: alerteId

ServiceAlertes --> ServiceAudit : 7.2: enregistrerAction("ALERTE_CREEE")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceAlertes --> ServiceScheduleur : 8: planifierAlerte(alerteId, date)
ServiceScheduleur --> ServiceAlertes : 9: planifiee
ServiceAlertes --> InterfaceAlertes : 10: succes()
InterfaceAlertes --> Consultant : 11: afficher("Alerte programmee")

Consultant --> InterfaceAlertes : 12: modifier(alerte)
InterfaceAlertes --> ServiceAlertes : 13: mettreAJourAlerte(alerteId, donnees)
ServiceAlertes --> BaseDonnees : 14: mettreAJourEnregistrement(donnees)
BaseDonnees --> ServiceAlertes : 14.1: ok

ServiceAlertes --> ServiceAudit : 14.2: enregistrerAction("ALERTE_MODIFIEE")
ServiceAudit --> BaseDonnees : 14.3: sauvegarderLog()

ServiceAlertes --> InterfaceAlertes : 15: succes()
InterfaceAlertes --> Consultant : 16: afficher("Alerte modifiee")

@enduml
