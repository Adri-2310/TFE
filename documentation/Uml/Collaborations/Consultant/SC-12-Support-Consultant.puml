@startuml SC-12-Support-Consultant
!theme plain
title Diagramme de Collaboration - Support aux Clients (Consultant)

object Consultant
object "Interface Support" as InterfaceSupport
object "Service Tickets" as ServiceTickets
object "Service Notifications" as ServiceNotifications
object "Base Données" as BaseDonnees
object "Service FAQ" as ServiceFAQ
object "Service Audit" as ServiceAudit
object Client

Consultant --> InterfaceSupport : 1: acceder("Support Clients")
InterfaceSupport --> ServiceTickets : 2: obtenirTickets(consultantId)
ServiceTickets --> BaseDonnees : 3: executerRequete(tickets_ouverts)
BaseDonnees --> ServiceTickets : 3.1: listeTickets[]
ServiceTickets --> InterfaceSupport : 4: afficher(tickets)
InterfaceSupport --> Consultant : 4.1: montrer(file_attente)

Client --> InterfaceSupport : 5: soumettre(ticket_support)
InterfaceSupport --> ServiceTickets : 6: creerTicket({titre, description, priorite})
ServiceTickets --> BaseDonnees : 7: sauvegarderTicket(statut: OUVERT)
BaseDonnees --> ServiceTickets : 7.1: ticketId

ServiceTickets --> ServiceAudit : 7.2: enregistrerAction("TICKET_CREE")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceTickets --> ServiceNotifications : 8: notifierConsultant(ticketId)
ServiceNotifications --> ServiceNotifications : 9: envoyerEmail(consultant)
ServiceTickets --> InterfaceSupport : 10: succes()
InterfaceSupport --> Client : 11: afficher("Ticket cree #123")

Consultant --> InterfaceSupport : 12: selectionner(ticket)
InterfaceSupport --> ServiceTickets : 13: obtenirTicket(ticketId)
ServiceTickets --> BaseDonnees : 14: executerRequete(details_ticket)
BaseDonnees --> ServiceTickets : 14.1: donneeTicket
ServiceTickets --> InterfaceSupport : 15: afficher(details)
InterfaceSupport --> Consultant : 16: montrer(demande_client)

Consultant --> InterfaceSupport : 17: consulter("FAQ")
InterfaceSupport --> ServiceFAQ : 18: rechercherFAQ(mots_cles)
ServiceFAQ --> BaseDonnees : 19: executerRequete(articles_faq)
BaseDonnees --> ServiceFAQ : 19.1: listeArticles[]
ServiceFAQ --> InterfaceSupport : 20: afficher(articles)
InterfaceSupport --> Consultant : 21: montrer(solutions)

Consultant --> InterfaceSupport : 22: repondre(ticket, solution)
InterfaceSupport --> ServiceTickets : 23: ajouterReponse({ticketId, message, solution})
ServiceTickets --> BaseDonnees : 24: sauvegarderReponse(reponse)
BaseDonnees --> ServiceTickets : 24.1: reponseId

ServiceTickets --> ServiceAudit : 24.2: enregistrerAction("REPONSE_TICKET")
ServiceAudit --> BaseDonnees : 24.3: sauvegarderLog()

ServiceTickets --> ServiceNotifications : 25: notifierClient(reponseId)
ServiceNotifications --> ServiceNotifications : 26: envoyerEmail(client)
ServiceTickets --> InterfaceSupport : 27: succes()
InterfaceSupport --> Consultant : 28: afficher("Reponse envoyee")

Client --> InterfaceSupport : 29: consulter(reponse)
InterfaceSupport --> ServiceTickets : 30: obtenirReponse(reponseId)
ServiceTickets --> BaseDonnees : 31: executerRequete(details)
BaseDonnees --> ServiceTickets : 31.1: donneeReponse
ServiceTickets --> InterfaceSupport : 32: afficher(reponse)
InterfaceSupport --> Client : 33: montrer(solution)

Client --> InterfaceSupport : 34: cloturer(ticket)
InterfaceSupport --> ServiceTickets : 35: cloturerTicket(ticketId)
ServiceTickets --> BaseDonnees : 36: mettreAJourStatut(FERME)
BaseDonnees --> ServiceTickets : 36.1: ok

ServiceTickets --> ServiceAudit : 36.2: enregistrerAction("TICKET_FERME")
ServiceAudit --> BaseDonnees : 36.3: sauvegarderLog()

ServiceTickets --> ServiceNotifications : 37: notifierConsultant(ferme)
ServiceNotifications --> ServiceNotifications : 38: envoyerEmail(consultant)
ServiceTickets --> InterfaceSupport : 39: succes()
InterfaceSupport --> Client : 40: afficher("Ticket ferme")

note right of Client
Flux principal - Probleme resolu:
- Fermeture du ticket
- Notification au consultant
- Statut FERME

Alternative (cas non resolu):
- Client pose nouvelle question
- Reponse ajoutee au suivi
- Notification consultant
- Relance de la discussion
end note

Consultant --> InterfaceSupport : 48: evaluer(satisfaction)
InterfaceSupport --> ServiceTickets : 49: sauvegarderRetroaction(note)
ServiceTickets --> BaseDonnees : 50: mettreAJourRetroaction(note)
BaseDonnees --> ServiceTickets : 50.1: ok

ServiceTickets --> ServiceAudit : 50.2: enregistrerAction("RETROACTION_TICKET")
ServiceAudit --> BaseDonnees : 50.3: sauvegarderLog()

ServiceTickets --> InterfaceSupport : 51: succes()
InterfaceSupport --> Consultant : 52: afficher("Evaluation sauvegardee")

note right of ServiceTickets
Support Tickets (SC-12):
- Systeme formel de support
- Numerotation et suivi
- FAQ integree
- Evaluation satisfaction
- Voir SC-31 pour messagerie directe
end note

@enduml
