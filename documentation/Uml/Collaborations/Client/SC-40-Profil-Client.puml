@startuml SC-40-Profil-Client
!theme plain
title Diagramme de Collaboration - Gerer Profil Personnel (Client)

object Client
object "Interface Profil" as InterfaceProfil
object "Service Profil" as ServiceProfil
object "Base Données" as BaseDonnees
object "Service Audit" as ServiceAudit

Client --> InterfaceProfil : 1: acceder("Mon Profil")
InterfaceProfil --> ServiceProfil : 2: obtenirProfil(clientId)
ServiceProfil --> BaseDonnees : 3: executerRequete(profil)
BaseDonnees --> ServiceProfil : 3.1: donneeProfil
ServiceProfil --> InterfaceProfil : 4: afficher(profil)
InterfaceProfil --> Client : 4.1: montrer(informations)

Client --> InterfaceProfil : 5: modifier(donnees)
InterfaceProfil --> ServiceProfil : 6: mettreAJourProfil(clientId, donnees)
ServiceProfil --> BaseDonnees : 7: mettreAJourEnregistrement(donnees)
BaseDonnees --> ServiceProfil : 7.1: ok

ServiceProfil --> ServiceAudit : 7.2: enregistrerAction("PROFIL_MODIFIE")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceProfil --> InterfaceProfil : 8: succes()
InterfaceProfil --> Client : 9: afficher("Profil mis a jour")

Client --> InterfaceProfil : 10: configurer(notifications)
InterfaceProfil --> ServiceProfil : 11: mettreAJourPreferences({emailAlertes, smsAlertes})
ServiceProfil --> BaseDonnees : 12: sauvegarderPreferences(prefs)
BaseDonnees --> ServiceProfil : 12.1: ok

ServiceProfil --> ServiceAudit : 12.2: enregistrerAction("PREFERENCES_MISES_A_JOUR")
ServiceAudit --> BaseDonnees : 12.3: sauvegarderLog()

ServiceProfil --> InterfaceProfil : 13: succes()
InterfaceProfil --> Client : 14: afficher("Preferences mises a jour")

@enduml
