@startuml SC-38-Support-Client
!theme plain
title Diagramme de Collaboration - Support Messagerie (Client)

object Client
object "Portail Support" as Portail
object "Service Tickets" as ServiceTickets
object "Base Données" as BaseDonnees
object "Service Audit" as ServiceAudit

Client --> Portail : 1: cliquer("Support")
Portail --> ServiceTickets : 2: obtenirMesTickets(clientId)
ServiceTickets --> BaseDonnees : 3: executerRequete(tickets)
BaseDonnees --> ServiceTickets : 3.1: listeTickets[]
ServiceTickets --> Portail : 4: afficher(liste)
Portail --> Client : 4.1: montrer(tickets)

Client --> Portail : 5: creer(ticket)
Portail --> ServiceTickets : 6: creerTicket({titre, description})
ServiceTickets --> BaseDonnees : 7: sauvegarderTicket(ticket)
BaseDonnees --> ServiceTickets : 7.1: ticketId

ServiceTickets --> ServiceAudit : 7.2: enregistrerAction("TICKET_CLIENT_CREE")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceTickets --> Portail : 8: succes()
Portail --> Client : 9: afficher("Ticket cree")

Client --> Portail : 10: consulter(reponse)
Portail --> ServiceTickets : 11: obtenirMessagesTicket(ticketId)
ServiceTickets --> BaseDonnees : 12: executerRequete(messages)
BaseDonnees --> ServiceTickets : 12.1: listeMessages[]
ServiceTickets --> Portail : 13: afficher(conversation)
Portail --> Client : 14: montrer(messages)

@enduml
