@startuml SC-03-Gestion-Utilisateurs
!theme plain
title Diagramme de Collaboration - Gestion des Utilisateurs (SuperAdmin)

object SuperAdmin
object "Interface Admin" as InterfaceAdmin
object "Service Utilisateurs" as ServiceUtilisateurs
object "Service RBAC" as ServiceRBAC
object "Base Données" as BaseDonnees
object "Service Notification" as ServiceNotification
object "Service Audit" as ServiceAudit

SuperAdmin --> InterfaceAdmin : 1: cliquer("Gestion Utilisateurs")
InterfaceAdmin --> ServiceUtilisateurs : 2: obtenirUtilisateurs()
ServiceUtilisateurs --> BaseDonnees : 3: executerRequete(tous_utilisateurs)
BaseDonnees --> ServiceUtilisateurs : 3.1: listeUtilisateurs[]
ServiceUtilisateurs --> InterfaceAdmin : 4: afficher(liste)
InterfaceAdmin --> SuperAdmin : 4.1: montrer(tableau)

SuperAdmin --> InterfaceAdmin : 5: creer(nouvel_utilisateur)
InterfaceAdmin --> ServiceUtilisateurs : 6: creerUtilisateur({email, nom, role})
ServiceUtilisateurs --> ServiceRBAC : 7: assignerRole(idUtilisateur, role)
ServiceRBAC --> BaseDonnees : 8: sauvegarderRole(mapping)
BaseDonnees --> ServiceRBAC : 8.1: ok
ServiceRBAC --> ServiceUtilisateurs : 8.2: roleAssigne
ServiceUtilisateurs --> BaseDonnees : 9: sauvegarderUtilisateur(donnees)
BaseDonnees --> ServiceUtilisateurs : 9.1: idUtilisateur

ServiceUtilisateurs --> ServiceAudit : 9.2: enregistrerAction("CREATION_UTILISATEUR")
ServiceAudit --> BaseDonnees : 9.3: sauvegarderLog()

ServiceUtilisateurs --> ServiceNotification : 10: notifier(utilisateur)
ServiceNotification --> ServiceNotification : 11: envoyerEmail(email)
ServiceUtilisateurs --> InterfaceAdmin : 12: succes(idUtilisateur)
InterfaceAdmin --> SuperAdmin : 13: afficher("Utilisateur cree")

SuperAdmin --> InterfaceAdmin : 14: modifier(utilisateur)
InterfaceAdmin --> ServiceUtilisateurs : 15: mettreAJourUtilisateur(idUtilisateur, donnees)
ServiceUtilisateurs --> BaseDonnees : 16: mettreAJourEnregistrement(idUtilisateur)
BaseDonnees --> ServiceUtilisateurs : 16.1: mis_a_jour

ServiceUtilisateurs --> ServiceAudit : 16.2: enregistrerAction("MODIFICATION_UTILISATEUR")
ServiceAudit --> BaseDonnees : 16.3: sauvegarderLog()

ServiceUtilisateurs --> InterfaceAdmin : 17: succes()
InterfaceAdmin --> SuperAdmin : 18: afficher("Modifie")

SuperAdmin --> InterfaceAdmin : 19: desactiver(utilisateur)
InterfaceAdmin --> ServiceUtilisateurs : 20: desactiverUtilisateur(idUtilisateur)
ServiceUtilisateurs --> BaseDonnees : 21: definirStatut(INACTIF)
BaseDonnees --> ServiceUtilisateurs : 21.1: ok

ServiceUtilisateurs --> ServiceAudit : 21.2: enregistrerAction("DESACTIVATION_UTILISATEUR")
ServiceAudit --> BaseDonnees : 21.3: sauvegarderLog()

ServiceUtilisateurs --> InterfaceAdmin : 22: succes()
InterfaceAdmin --> SuperAdmin : 23: afficher("Utilisateur desactive")

note left of ServiceRBAC
Assignation des roles:
- SuperAdmin
- AdminSecretariat
- Consultant
- Client
- Employe
end note

@enduml
