@startuml SC-21-White-Label
!theme plain
title Diagramme de Collaboration - Configurer Marque Blanche (SuperAdmin)

object SuperAdmin
object "Interface Marque Blanche" as InterfaceWL
object "Service Marque Blanche" as ServiceWL
object "Service Identite Visuelle" as ServiceBranding
object "Base Données" as BaseDonnees
object "Service Cache" as ServiceCache
object "Service Audit" as ServiceAudit

SuperAdmin --> InterfaceWL : 1: acceder("Configuration Marque Blanche")
InterfaceWL --> ServiceWL : 2: obtenirConfigMarqueBlanche()
ServiceWL --> BaseDonnees : 3: executerRequete(config_mb)
BaseDonnees --> ServiceWL : 3.1: donneesConfig
ServiceWL --> InterfaceWL : 4: afficher(configuration)
InterfaceWL --> SuperAdmin : 4.1: montrer(parametres)

SuperAdmin --> InterfaceWL : 5: configurer("Couleurs")
InterfaceWL --> ServiceBranding : 6: modifierCouleurs({primaire, secondaire, accent})
ServiceBranding --> BaseDonnees : 7: sauvegarderCouleursMarque(couleurs)
BaseDonnees --> ServiceBranding : 7.1: ok

ServiceBranding --> ServiceAudit : 7.2: enregistrerAction("MODIFICATION_COULEURS_MARQUE")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceBranding --> ServiceCache : 8: invaliderCacheMarque()
ServiceBranding --> InterfaceWL : 9: succes()
InterfaceWL --> SuperAdmin : 10: afficher("Couleurs mises a jour")

SuperAdmin --> InterfaceWL : 11: televerser(logo)
InterfaceWL --> ServiceBranding : 12: televerserLogo(fichier)
ServiceBranding --> ServiceBranding : 13: validerImage()
ServiceBranding --> ServiceBranding : 14: optimiserImage()
ServiceBranding --> BaseDonnees : 15: sauvegarderLogo(idFichier)
BaseDonnees --> ServiceBranding : 15.1: ok

ServiceBranding --> ServiceAudit : 15.2: enregistrerAction("MODIFICATION_LOGO")
ServiceAudit --> BaseDonnees : 15.3: sauvegarderLog()

ServiceBranding --> ServiceCache : 16: invaliderCacheMarque()
ServiceBranding --> InterfaceWL : 17: succes()
InterfaceWL --> SuperAdmin : 18: afficher("Logo mis a jour")

SuperAdmin --> InterfaceWL : 19: configurer("Domaines Personnalises")
InterfaceWL --> ServiceWL : 20: obtenirDomainesPersonnalises()
ServiceWL --> BaseDonnees : 21: executerRequete(domaines)
BaseDonnees --> ServiceWL : 21.1: listeDomaines[]
ServiceWL --> InterfaceWL : 22: afficher(domaines)
InterfaceWL --> SuperAdmin : 23: montrer(liste)

SuperAdmin --> InterfaceWL : 24: ajouter(domaine)
InterfaceWL --> ServiceWL : 25: ajouterDomainePersonnalise({domaine, secretariat})
ServiceWL --> ServiceWL : 26: validerDomaine()
ServiceWL --> ServiceWL : 27: genererDNS()
ServiceWL --> BaseDonnees : 28: sauvegarderDomaine(domaine)
BaseDonnees --> ServiceWL : 28.1: idDomaine

ServiceWL --> ServiceAudit : 28.2: enregistrerAction("AJOUT_DOMAINE_PERSONNALISE")
ServiceAudit --> BaseDonnees : 28.3: sauvegarderLog()

ServiceWL --> InterfaceWL : 29: afficher(instructions_dns)
InterfaceWL --> SuperAdmin : 30: montrer(enregistrements_dns)

SuperAdmin --> InterfaceWL : 31: configurer(emails)
InterfaceWL --> ServiceBranding : 32: modifierModelesEmail({signature, banniere})
ServiceBranding --> BaseDonnees : 33: sauvegarderConfigEmail(config)
BaseDonnees --> ServiceBranding : 33.1: ok

ServiceBranding --> ServiceAudit : 33.2: enregistrerAction("MODIFICATION_MODELES_EMAIL")
ServiceAudit --> BaseDonnees : 33.3: sauvegarderLog()

ServiceBranding --> InterfaceWL : 34: succes()
InterfaceWL --> SuperAdmin : 35: afficher("Modeles emails mis a jour")

@enduml
