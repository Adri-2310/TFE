@startuml Client-Package-Diagram
!theme plain
title Diagramme de Package - Client (WorkZen)

package "🔐 Authentification" as P_Auth {
  package "Module Authentification" {
    [Gestion Connexion]
    [Gestion Sessions]
    [Réinitialisation Mot de Passe]
  }
}

package "📋 Consultation Paie" as P_Paie {
  package "Fiche Paie" {
    [Visualiseur Fiche Paie]
    [Télécharger Fiche]
    [Accès Archives]
  }
  package "Historique Paie" {
    [Archives Historiques]
    [Détails Salaire]
    [Détail Déductions]
  }
}

package "📄 Gestion Documents" as P_Documents {
  package "Documents Employés" {
    [Visualiseur Documents]
    [Télécharger Documents]
    [Recherche Documents]
  }
  package "Types Documents" {
    [Contrats]
    [Certificats (C4)]
    [Autres Documents]
  }
}

package "📊 Dashboard & Analytics" as P_Dashboard {
  package "Dashboard Employé" {
    [Vue d'ensemble Dashboard]
    [Accès Rapide]
    [Notifications]
  }
  package "Analytics Paie & RH" {
    [Analytics Paie]
    [Statistiques Documents]
    [Tendances Historiques]
    [Insights RH]
  }
}

package "👤 Gestion Profil" as P_Profil {
  package "Profil Personnel" {
    [Afficher Infos Personnelles]
    [Mettre à Jour Profil]
    [Infos Contact]
  }
  package "Préférences" {
    [Paramètres Notifications]
    [Préférences Affichage]
    [Paramètres Langue]
  }
}

package "🔗 Services Additionnels" as P_Services {
  package "Certification & C4" {
    [Télécharger Certificat C4]
    [Vérifier Certificat]
    [Historique Certificats]
  }
  package "Analytics RH" {
    [Insights Carrière]
    [Données Performance]
    [Statistiques Paie Personnelle]
  }
}

package "💬 Support & Communication" as P_Support {
  package "Messagerie" {
    [Boîte Messages]
    [Envoyer Messages]
    [Tickets Support]
  }
  package "FAQ & Centre d'Aide" {
    [Accès FAQ]
    [Centre d'Aide]
    [Guides & Tutoriels]
  }
}

package "📜 Audit & Sécurité" as P_Audit {
  package "Sécurité Données" {
    [Masquage NISS]
    [Données Personnelles Masquées]
  }
  package "Traçabilité" {
    [Journaux Accès]
    [Historique Consultations]
  }
}

[Gestion Connexion] ..> [Gestion Sessions] : <<use>>
[Visualiseur Fiche Paie] ..> [Télécharger Fiche] : <<use>>
[Télécharger Fiche] ..> [Accès Archives] : <<use>>
[Visualiseur Documents] ..> [Recherche Documents] : <<use>>
[Télécharger Documents] ..> [Types Documents] : <<use>>
[Vue d'ensemble Dashboard] ..> [Accès Rapide] : <<use>>
[Afficher Infos Personnelles] ..> [Mettre à Jour Profil] : <<use>>
[Paramètres Notifications] ..> [Préférences Affichage] : <<use>>
[Télécharger Certificat C4] ..> [Vérifier Certificat] : <<use>>
[Télécharger Certificat C4] ..> [Télécharger Documents] : <<use>>
[Boîte Messages] ..> [Envoyer Messages] : <<use>>
[Accès FAQ] ..> [Guides & Tutoriels] : <<use>>

' === DÉPENDANCES ARCHITECTURALES (ENTRE PACKAGES) ===

P_Auth ..> P_Audit : <<import>>

P_Paie ..> P_Auth : <<import>>
P_Paie ..> P_Audit : <<import>>

P_Documents ..> P_Auth : <<import>>
P_Documents ..> P_Audit : <<import>>

P_Dashboard ..> P_Paie : <<import>>
P_Dashboard ..> P_Documents : <<import>>
P_Dashboard ..> P_Audit : <<import>>

P_Profil ..> P_Auth : <<import>>
P_Profil ..> P_Audit : <<import>>

P_Services ..> P_Paie : <<import>>
P_Services ..> P_Documents : <<import>>
P_Services ..> P_Audit : <<import>>

P_Support ..> P_Auth : <<import>>
P_Support ..> P_Audit : <<import>>

@enduml
