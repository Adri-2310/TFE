P_Auth ..> P_Audit : <<import>>

P_Clients ..> P_Auth : <<import>>
P_Clients ..> P_Audit : <<import>>

P_Employes ..> P_Clients : <<import>>
P_Employes ..> P_Audit : <<import>>

P_Paie ..> P_Employes : <<import>>
P_Paie ..> P_Audit : <<import>>

P_Alertes ..> P_Paie : <<import>>
P_Alertes ..> P_Employes : <<import>>
P_Alertes ..> P_Audit : <<import>>

P_Dashboard ..> P_Clients : <<import>>
P_Dashboard ..> P_Paie : <<import>>
P_Dashboard ..> P_Audit : <<import>>

P_Documents ..> P_Clients : <<import>>
P_Documents ..> P_Audit : <<import>>

P_Integrations ..> P_Paie : <<import>>
P_Integrations ..> P_Audit : <<import>>

P_Support ..> P_Clients : <<import>>
P_Support ..> P_Audit : <<import>>

@enduml
