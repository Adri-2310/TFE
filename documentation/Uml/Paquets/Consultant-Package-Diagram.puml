@startuml Consultant-Package-Diagram
!theme plain
title Diagramme de Package - Consultant (WorkZen)

package "🔐 Authentification" as P_Auth {
  package "Module Authentification" {
    [Gestion Connexion]
    [Gestion Sessions]
  }
}

package "🏢 Gestion Clients" as P_Clients {
  package "Répertoire Clients" {
    [CRUD Clients]
    [Recherche Clients]
    [Infos Clients]
  }
  package "Communication Clients" {
    [Système Messagerie]
    [Intégration Email]
    [Partage Documents]
  }
}

package "👥 Gestion Employés" as P_Employes {
  package "Employés Clients" {
    [Répertoire Employés]
    [CRUD Employés]
    [Contrats Emploi]
  }
  package "Données Employés" {
    [Infos Personnelles]
    [Postes de Travail]
    [Attribution Départements]
  }
}

package "📋 Paie & Conformité Belge" as P_Paie {
  package "Traitement Paie" {
    [Génération Fiche Paie]
    [Calcul Salaire]
    [Règles Déductions]
    [Moteur Validation]
  }
  package "Conformité ONSS & Belgique" {
    [Vérification DIMONA]
    [Validation Données NISS]
    [Somme de Contrôle ONSS]
    [Export ONSS]
    [Sync Exact Online]
  }
}

package "📅 Calendrier & Alertes" as P_Alertes {
  package "Gestion Calendrier" {
    [Calendrier Événements]
    [Gestion Jours Fériés]
    [Suivi Échéances]
  }
  package "Système Alertes" {
    [Alertes Échéances]
    [Alertes Conformité ONSS]
    [Rappels Tâches]
  }
}

package "📊 Dashboard & Analytics" as P_Dashboard {
  package "Dashboard Consultant" {
    [Vue d'ensemble Clients]
    [Résumé Paie]
    [Statut Conformité ONSS]
  }
  package "Analytics" {
    [Métriques Performance]
    [Statistiques Clients]
    [Analytics Paie]
  }
}

package "📄 Gestion Documents" as P_Documents {
  package "Templates Documents" {
    [Bibliothèque Templates]
    [Templates Personnalisés]
    [Versioning Templates]
  }
  package "Opérations Documents" {
    [Générer Documents]
    [Éditer Documents]
    [Archiver Documents]
  }
}

package "⚙️ Intégrations & Synchronisation" as P_Integrations {
  package "Exact Online" {
    [Sync Comptes]
    [Sync Transactions]
    [Mappage Données]
  }
  package "Gestion Données" {
    [Import Données]
    [Export Données]
    [Opérations Groupées]
  }
}

package "💬 Support & Communication Clients" as P_Support {
  package "Messagerie Client" {
    [Boîte Messages]
    [Envoyer Messages]
    [Gestion Fils]
  }
  package "Support Professionnel" {
    [Tickets Support]
    [Accès FAQ]
    [Escalade Issues]
  }
}

package "📜 Audit & Conformité" as P_Audit {
  package "Journaux Audit" {
    [Suivi Actions]
    [Activités Utilisateurs]
    [Historique Modifications]
  }
  package "Conformité" {
    [Traçabilité Données]
    [Rapports Conformité]
  }
}

[Gestion Connexion] ..> [Gestion Sessions] : <<use>>
[CRUD Clients] ..> [Infos Clients] : <<use>>
[Système Messagerie] ..> [Intégration Email] : <<use>>
[Répertoire Employés] ..> [Contrats Emploi] : <<use>>
[Génération Fiche Paie] ..> [Calcul Salaire] : <<use>>
[Vérification DIMONA] ..> [Validation Données NISS] : <<use>>
[Validation Données NISS] ..> [Somme de Contrôle ONSS] : <<use>>
[Somme de Contrôle ONSS] ..> [Export ONSS] : <<use>>
[Export ONSS] ..> [Sync Exact Online] : <<use>>
[Alertes Conformité ONSS] ..> [Export ONSS] : <<use>>
[Alertes Conformité ONSS] ..> [Sync Exact Online] : <<use>>
[Vue d'ensemble Clients] ..> [Statut Conformité ONSS] : <<use>>
[Bibliothèque Templates] ..> [Générer Documents] : <<use>>
[Sync Comptes] ..> [Mappage Données] : <<use>>
[Import Données] ..> [Opérations Groupées] : <<use>>
[Boîte Messages] ..> [Envoyer Messages] : <<use>>
[Suivi Actions] ..> [Historique Modifications] : <<use>>

