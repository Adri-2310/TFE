P_Conges ..> P_Audit : <<import>>

P_Dashboard ..> P_Paie : <<import>>
P_Dashboard ..> P_Documents : <<import>>
P_Dashboard ..> P_Conges : <<import>>
P_Dashboard ..> P_Audit : <<import>>

P_Parametres ..> P_Auth : <<import>>
P_Parametres ..> P_Audit : <<import>>

