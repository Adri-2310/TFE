@startuml Employe-Package-Diagram
!theme plain
title Diagramme de Package - Employé (WorkZen)

package "🔐 Authentification" as P_Auth {
  package "Module Authentification" {
    [Gestion Connexion]
    [Gestion Sessions]
    [Réinitialisation Mot de Passe]
  }
}

package "📋 Consultation Paie" as P_Paie {
  package "Fiche Paie" {
    [Visualiseur Fiche Paie]
    [Télécharger Fiche]
    [Détails Fiche Paie]
  }
  package "Historique Paie" {
    [Archives Historiques]
    [Vue Mensuelle]
    [Résumé Année]
  }
}

package "📄 Gestion Documents" as P_Documents {
  package "Documents Personnels" {
    [Visualiseur Documents]
    [Télécharger Documents]
    [Recherche & Filtrage]
  }
  package "Types Documents" {
    [Contrats Emploi]
    [Certificats]
    [Documents Professionnels]
  }
}

package "👤 Informations Personnelles" as P_Profil {
  package "Gestion Profil" {
    [Afficher Infos Personnelles]
    [Mettre à Jour Contact]
    [Gérer Préférences]
  }
  package "Données Personnelles (Masquées)" {
    [Infos Adresse (Masquée)]
    [Détails Contact (Masqués)]
    [Contact Urgence]
  }
}

package "🏖️ Gestion Congés & Absences" as P_Conges {
  package "Demandes Congés" {
    [Demander Congés]
    [Voir Statut Demande]
    [Annuler Demande]
  }
  package "Suivi Congés" {
    [Solde Congés]
    [Historique Congés]
    [Attendre Approbation Consultant]
  }
}

package "📊 Dashboard & Notifications" as P_Dashboard {
  package "Dashboard Personnel" {
    [Vue d'ensemble Dashboard]
    [Informations Importantes]
    [Actions Rapides]
  }
  package "Notifications" {
    [Alertes Nouveaux Documents]
    [Notifications Paie]
    [Mises à Jour Congés]
  }
}

package "⚙️ Paramètres Notifications & Confidentialité" as P_Parametres {
  package "Préférences" {
    [Préférences Email]
    [Types Notifications]
    [Paramètres Fréquence]
  }
  package "Confidentialité & RGPD" {
    [Paramètres Confidentialité]
    [Préférences Communication]
    [Droits RGPD]
  }
}

package "❓ Support & FAQ" as P_Support {
  package "Centre d'Aide" {
    [Accès FAQ]
    [Guides & Tutoriels]
    [Articles Comment Faire]
  }
  package "Support" {
    [Système Messagerie]
    [Tickets Support]
    [Contacter Support]
  }
}

package "📜 Audit & Sécurité Données" as P_Audit {
  package "Protection Données" {
    [Masquage NISS]
    [Masquage Données Sensibles]
  }
  package "Traçabilité" {
    [Journaux Accès]
    [Historique Consultations]
  }
}

[Gestion Connexion] ..> [Gestion Sessions] : <<use>>
[Visualiseur Fiche Paie] ..> [Télécharger Fiche] : <<use>>
[Télécharger Fiche] ..> [Détails Fiche Paie] : <<use>>
[Visualiseur Documents] ..> [Recherche & Filtrage] : <<use>>
[Télécharger Documents] ..> [Types Documents] : <<use>>
[Afficher Infos Personnelles] ..> [Mettre à Jour Contact] : <<use>>
[Demander Congés] ..> [Voir Statut Demande] : <<use>>
[Solde Congés] ..> [Historique Congés] : <<use>>
[Voir Statut Demande] ..> [Attendre Approbation Consultant] : <<use>>
[Vue d'ensemble Dashboard] ..> [Informations Importantes] : <<use>>
[Préférences Email] ..> [Types Notifications] : <<use>>
[Accès FAQ] ..> [Articles Comment Faire] : <<use>>
[Système Messagerie] ..> [Tickets Support] : <<use>>
[Télécharger Fiche] ..> [Vue Mensuelle] : <<use>>
[Vue Mensuelle] ..> [Résumé Année] : <<use>>
[Télécharger Documents] ..> [Recherche & Filtrage] : <<use>>
[Mettre à Jour Contact] ..> [Gérer Préférences] : <<use>>
[Demander Congés] ..> [Solde Congés] : <<use>>
[Préférences Email] ..> [Paramètres Fréquence] : <<use>>
[Alertes Nouveaux Documents] ..> [Accès FAQ] : <<use>>

