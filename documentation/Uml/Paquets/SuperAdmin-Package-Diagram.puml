P_Auth ..> P_Audit : <<import>>

P_Users ..> P_Auth : <<import>>
P_Users ..> P_Audit : <<import>>

P_Secretariats ..> P_Users : <<import>>
P_Secretariats ..> P_Pricing : <<import>>
P_Secretariats ..> P_Audit : <<import>>

P_Pricing ..> P_Audit : <<import>>

P_Dashboard ..> P_Secretariats : <<import>>
P_Dashboard ..> P_Audit : <<import>>

P_Config ..> P_Auth : <<import>>
P_Config ..> P_Audit : <<import>>

P_Branding ..> P_Secretariats : <<import>>
P_Branding ..> P_Audit : <<import>>

P_Veille ..> P_Secretariats : <<access>>
P_Veille ..> P_Audit : <<import>>

P_Monitoring ..> P_Audit : <<import>>

@enduml
