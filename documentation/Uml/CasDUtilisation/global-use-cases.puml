@startuml Global-SocialFlow-UseCases
title Diagramme de Cas d'Utilisation Global\nSocialFlow Secrétariat Social

left to right direction

skinparam backgroundColor #FFFFFF

' ============================================
' ACTEURS - UTILISATEURS
' ============================================
actor SuperAdmin
actor AdminSecretariat
actor Consultant
actor Client
actor Employé

' ============================================
' ACTEURS - SYSTEMES EXTERNES
' ============================================
actor "<<Système>>\nStripe" as Stripe
actor "<<Système>>\nExact Online" as ExactOnline

rectangle "SocialFlow - Système" {

' ============================================
' AUTHENTIFICATION
' ============================================
usecase "Se connecter" as UC_Auth

' ============================================
' GESTION PROFIL
' ============================================
usecase "Gérer profil personnel" as UC_Profile

' ============================================
' CAS SUPERADMIN
' ============================================
usecase "Gérer secrétariats" as UC0110
usecase "Gérer utilisateurs" as UC0120
usecase "Analytics & monitoring" as UC0130
usecase "Configurer système" as UC0140
usecase "Audit logs" as UC0150
usecase "Veille législative" as UC0160
usecase "Gérer API publique" as UC0170
usecase "White-label" as UC0180

' ============================================
' CAS ADMIN SECRETARIAT
' ============================================
usecase "Gérer personnel" as UC0210
usecase "Gérer abonnement" as UC0220
usecase "Gérer templates documents" as UC0230
usecase "Consulter rapports" as UC0240
usecase "Audit logs secrétariat" as UC0250
usecase "Exporter données (RGPD)" as UC0260
usecase "Importer données" as UC0270

' ============================================
' CAS CONSULTANT
' ============================================
usecase "Gérer clients" as UC0310
usecase "Gérer employés clients" as UC0320
usecase "Gérer fiches de paie" as UC0330
usecase "Conformité ONSS/DIMONA" as UC0340
usecase "Calendrier & alertes" as UC0350
usecase "Consulter dashboard\n(Consultant)" as UC0360
usecase "Synchroniser Exact Online" as UC0370
usecase "Messagerie client" as UC0375
usecase "Export/Import données" as UC0385

' ============================================
' CAS CLIENT
' ============================================
usecase "Consulter fiches de paie" as UC0420
usecase "Consulter employés" as UC0430
usecase "Gérer documents" as UC0440
usecase "Analytics RH" as UC0470
usecase "Télécharger certificats C4" as UC0480

' ============================================
' CAS EMPLOYE
' ============================================
usecase "Consulter fiche de paie\n(Employé)" as UC0510
usecase "Télécharger documents\n(Employé)" as UC0520
usecase "Consulter infos\npersonnelles" as UC0530
usecase "Accéder support" as UC0540
usecase "Demander congés/absences" as UC0560
usecase "Configurer notifications" as UC0570

}

' ============================================
' CONNECTIONS - AUTHENTIFICATION
' ============================================
SuperAdmin -- UC_Auth
AdminSecretariat -- UC_Auth
Consultant -- UC_Auth
Client -- UC_Auth
Employé -- UC_Auth

' ============================================
' CONNECTIONS - GESTION PROFIL
' ============================================
Client -- UC_Profile
Employé -- UC_Profile

' ============================================
' CONNECTIONS - SUPERADMIN
' ============================================
SuperAdmin -- UC0110
SuperAdmin -- UC0120
SuperAdmin -- UC0130
SuperAdmin -- UC0140
SuperAdmin -- UC0150
SuperAdmin -- UC0160
SuperAdmin -- UC0170
SuperAdmin -- UC0180

' ============================================
' CONNECTIONS - ADMIN SECRETARIAT
' ============================================
AdminSecretariat -- UC0210
AdminSecretariat -- UC0220
AdminSecretariat -- UC0230
AdminSecretariat -- UC0240
AdminSecretariat -- UC0250
AdminSecretariat -- UC0260
AdminSecretariat -- UC0270

' ============================================
' CONNECTIONS - CONSULTANT
' ============================================
Consultant -- UC0310
Consultant -- UC0320
Consultant -- UC0330
Consultant -- UC0340
Consultant -- UC0350
Consultant -- UC0360
Consultant -- UC0370
Consultant -- UC0375
Consultant -- UC0385

' ============================================
' CONNECTIONS - CLIENT
' ============================================
Client -- UC0420
Client -- UC0430
Client -- UC0440
Client -- UC0470
Client -- UC0480

' ============================================
' CONNECTIONS - EMPLOYE
' ============================================
Employé -- UC0510
Employé -- UC0520
Employé -- UC0530
Employé -- UC0540
Employé -- UC0560
Employé -- UC0570

' ============================================
' CONNECTIONS - SYSTEMES EXTERNES
' ============================================
Stripe -- UC0140
Stripe -- UC0220
ExactOnline -- UC0370

@enduml

