@startuml Comp-01-Architecture-Components
!theme plain
title Diagramme de Composants - Architecture Technique WorkZen (UML 2.x)

package "🎨 Frontend (Next.js 15)" {
  component ["Application Web"] as WebApp
  component ["Bibliothèque ShadcnUI"] as ShadcnUI
  component ["React Query"] as ReactQuery
}

package "⚙️ Backend (Node.js)" {
  component ["Routes API"] as APIRoutes
  component ["Service Authentification"] as AuthService
  component ["Logique Métier"] as BusinessLogic
  component ["Moteur de Calcul"] as CalcEngine
}

package "🗄️ Couche de Données" {
  component ["Prisma ORM"] as PrismaORM
  component ["PostgreSQL"] as PostgreSQL
  component ["Cache Redis"] as RedisCache
}

package "📦 Traitement Jobs" {
  component ["File BullMQ"] as BullMQ
  component ["Worker Email"] as EmailWorker
  component ["Worker PDF"] as PDFWorker
}

package "☁️ Services Externes" {
  component ["Stripe"] as Stripe
  component ["Exact Online"] as ExactOnline
  component ["API ONSS"] as ONSSAPI
  component ["Email Resend"] as ResendEmail
}

package "📁 Stockage" {
  component ["MinIO (S3)"] as MinIO
  component ["Téléchargements Fichiers"] as FileUpload
}

package "🔒 Sécurité & Monitoring" {
  component ["Better Auth"] as BetterAuth
  component ["Sentry"] as Sentry
  component ["Logger"] as Logger
}

' ═════════════════════════════════════════════════════════════════
' INTERFACES MAJEURES (UML 2.x)
' ═════════════════════════════════════════════════════════════════

interface "API REST (JSON)" as I_API
interface "Data Access (Prisma/SQL)" as I_Data
interface "Job Queue (Redis)" as I_Queue

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES (Frontend)
' ═════════════════════════════════════════════════════════════════

WebApp --> ShadcnUI : utilise composants
WebApp --> ReactQuery : gestion état

' ═════════════════════════════════════════════════════════════════
' RELATIONS FOURNISSEUR D'INTERFACES
' ═════════════════════════════════════════════════════════════════

' I_API est fournie par Routes API
APIRoutes --o I_API : fournit

' I_Data est fournie par Prisma ORM
PrismaORM --o I_Data : fournit

' I_Queue est fournie par BullMQ
BullMQ --o I_Queue : fournit

' ═════════════════════════════════════════════════════════════════
' RELATIONS CONSOMMATEURS D'INTERFACES (<<use>>)
' ═════════════════════════════════════════════════════════════════

' Frontend consomme I_API
ReactQuery ..> I_API : <<use>>\nrequêtes HTTP

' Backend API consomme I_Data
APIRoutes ..> I_Data : <<use>>\nrequêtes données

' Backend Business Logic consomme I_Data
BusinessLogic ..> I_Data : <<use>>\nrequêtes données

' Moteur Calcul consomme I_Data
CalcEngine ..> I_Data : <<use>>\nrécupère données

' Backend API consomme I_Queue
APIRoutes ..> I_Queue : <<use>>\nmettre en queue

' Workers consomment I_Queue
EmailWorker ..> I_Queue : <<use>>\ntraiter jobs

PDFWorker ..> I_Queue : <<use>>\ntraiter jobs

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES BACKEND
' ═════════════════════════════════════════════════════════════════

APIRoutes --> AuthService : authentifier utilisateur
APIRoutes --> BusinessLogic : exécuter métier
APIRoutes --> CalcEngine : calculer paie

BusinessLogic --> PostgreSQL : données brutes
BusinessLogic --> Stripe : paiement

CalcEngine --> PostgreSQL : données brutes

' ═════════════════════════════════════════════════════════════════
' RELATIONS SERVICES EXTERNES
' ═════════════════════════════════════════════════════════════════

BusinessLogic --> ExactOnline : synchroniser comptabilité
BusinessLogic --> ONSSAPI : soumettre déclarations

EmailWorker --> ResendEmail : envoyer emails

PDFWorker --> MinIO : stocker fichiers PDF
FileUpload --> MinIO : télécharger fichiers

' ═════════════════════════════════════════════════════════════════
' RELATIONS SÉCURITÉ & MONITORING
' ═════════════════════════════════════════════════════════════════

APIRoutes --> BetterAuth : gestion sessions
APIRoutes --> Sentry : suivi erreurs
APIRoutes --> Logger : audit logs

BusinessLogic --> Sentry : suivi erreurs
BusinessLogic --> Logger : audit logs

' ═════════════════════════════════════════════════════════════════
' RELATIONS CACHE REDIS
' ═════════════════════════════════════════════════════════════════

PrismaORM --> RedisCache : cache résultats
ReactQuery --> RedisCache : synchroniser cache client

' ═════════════════════════════════════════════════════════════════
' ANNOTATIONS TECHNIQUES
' ═════════════════════════════════════════════════════════════════

note right of WebApp
  Routeur Application Next.js 15
  Composants Serveur React
  Design Responsif ShadcnUI
  Validations client
end note

note right of APIRoutes
  Express.js ou Hono
  Passerelle API REST
  Authentification
  Validation requêtes
  Gestion Erreurs
  CORS & Sécurité
end note

note right of CalcEngine
  Calculs complexes
  Règles ONSS belges
  Calculs fiscaux
  Prorations salaires
  Déductions sociales
end note

note right of BullMQ
  File d'attente Redis
  Traitement asynchrone
  Envoi emails en batch
  Génération PDF
  Exports données
  Réconciliations
end note

note right of I_API
  Endpoints REST
  Authentification Bearer JWT
  Rate Limiting
  Compression gzip
end note

note right of I_Data
  Requêtes Prisma
  Transactions SQL
  Connexion pool PostgreSQL
  Migrations versionnées
end note

note right of I_Queue
  Redis FIFO (First In First Out)
  Logique de retry
  File de lettres mortes
  Surveillance des tâches
end note

@enduml
