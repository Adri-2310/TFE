@startuml SuperAdmin_Classes
!theme plain
title Classes SuperAdmin - WorkZen v1.0

' ==================== USER & SECURITY ====================

class Utilisateur {
  - id: UUID
  - email: String
  - password_hash: String
  - first_name: String
  - last_name: String
  - phone: String
  - avatar_url: String
  - role: RoleUtilisateur = SUPER_ADMIN
  - is_active: Boolean
  - last_login: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + changePassword()
  + enable2FA()
  + updateProfile()
}

class Session {
  - id: UUID
  - user_id: UUID (FK)
  - token: String
  - ip_address: String
  - user_agent: String
  - created_at: DateTime
  - expires_at: DateTime
  --
  + isValid(): Boolean
  + revoke()
}

class AuthDoubleFacteur {
  - id: UUID
  - user_id: UUID (FK)
  - totp_secret: String (encrypted)
  - is_enabled: Boolean
  - backup_codes: String (encrypted array)
  --
  + generateSecret()
  + validateCode()
  + generateBackupCodes()
}

' ==================== SECRETARIAT MANAGEMENT ====================

class Secrétariat {
  - id: UUID
  - name: String
  - vat_number: String
  - email: String
  - phone: String
  - address: String
  - country: String
  - logo_url: String
  - subscription_plan: PlanAbonnement
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + createSecretariat()
  + updateProfile()
  + suspendAccount()
  + deleteAccount()
}

enum PlanAbonnement {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

class Facturation {
  - id: UUID
  - secretariat_id: UUID (FK)
  - stripe_customer_id: String
  - plan: PlanAbonnement
  - monthly_fee: Decimal
  - payment_method: String
  - invoice_count: Integer
  - next_renewal_date: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  --
  + upgradePlan()
  + generateInvoice()
  + processRefund()
}

' ==================== LEGISLATIVE MONITORING ====================

class AlerteLégislative {
  - id: UUID
  - title: String
  - content: String
  - source: String (whitelist)
  - alert_type: TypeAlerte
  - severity: NiveauSévérité
  - created_at: DateTime
  - updated_at: DateTime
  - expires_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + createAlert()
  + notifyAll()
}

enum TypeAlerte {
  ONSS_UPDATE
  DIMONA_CHANGE
  TAX_RATE_UPDATE
  COMPLIANCE_REQUIREMENT
}

enum NiveauSévérité {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

class SourceLégislative {
  - id: UUID
  - name: String
  - url: String
  - is_whitelisted: Boolean
  - last_scraped_at: DateTime
  - scrape_frequency: String (cron)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + addSource()
  + whitelist()
  + scrapeLatest()
}

' ==================== API MANAGEMENT ====================

class CléAPI {
  - id: UUID
  - name: String
  - key: String (masked)
  - secret: String (encrypted)
  - scopes: String (array) (JSON)
  - rate_limit: Integer
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  --
  + generateKey()
  + rotate()
  + deactivate()
  + trackUsage()
}

class StatistiquesUtilisationAPI {
  - id: UUID
  - api_key_id: UUID (FK)
  - calls_today: Integer
  - calls_total: Integer
  - errors_count: Integer
  - created_at: DateTime
  - last_called_at: DateTime
  --
  + trackCall()
  + calculateUsage()
}

' ==================== WHITE-LABEL CONFIG ====================

class ConfigWhiteLabel {
  - id: UUID
  - secretariat_id: UUID (FK)
  - custom_domain: String (optional)
  - custom_logo_url: String
  - primary_color: String
  - secondary_color: String
  - brand_name: String
  - is_active: Boolean
  - ssl_certificate: String (optional)
  - ssl_expires_at: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  --
  + validateDomain()
  + generateSSL()
  + applyBranding()
  + rollback()
}

class ValidateurDomaine {
  - id: UUID
  - config_id: UUID (FK)
  - domain: String
  - dns_records: String (array) (JSON)
  - is_verified: Boolean
  - verification_code: String
  - verified_at: DateTime
  --
  + validateDNS()
  + requestSSL()
}

' ==================== WEBHOOK MANAGEMENT ====================

class Webhook {
  - id: UUID
  - secretariat_id: UUID (FK)
  - event_type: TypeEvenementWebhook
  - url: String
  - secret: String (HMAC)
  - is_active: Boolean
  - retry_count: Integer
  - created_at: DateTime
  - updated_at: DateTime
  - last_triggered_at: DateTime
  --
  + trigger()
  + signPayload()
  + retry()
}

enum TypeEvenementWebhook {
  PAYSLIP_GENERATED
  EMPLOYEE_CREATED
  DECLARATION_SUBMITTED
  PAYMENT_PROCESSED
}

enum PaySlipStatus {
  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

enum DIMONAStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  CANCELLED
}

' ==================== AUDIT ====================

class JournalAudit {
  - id: UUID
  - admin_id: UUID (FK, SuperAdmin)
  - action: String
  - entity_type: String
  - entity_id: UUID
  - secretariat_id: UUID (optional)
  - changes: JSON
  - ip_address: String
  - reason: String (optionnel)
  - requires_approval: Boolean
  - approved_by: UUID (FK) -> Utilisateur
  - approved_at: DateTime
  - created_at: DateTime
  - deleted_at: DateTime (soft-delete)
  - anonymized_at: DateTime
  - anonymized_by: UUID
  --
  + logAction()
  + queryHistory()
  + anonymize()
}

' ==================== MONITORING & ALERTS ====================

class MoniteurSystème {
  - id: UUID
  - metric_name: String
  - value: Float
  - threshold: Float
  - status: StatutMoniteur
  - last_checked_at: DateTime
  --
  + checkHealth()
  + alertIfThresholdExceeded()
}

enum StatutMoniteur {
  OK
  WARNING
  CRITICAL
}

class AlerteSystème {
  - id: UUID
  - monitor_id: UUID (FK)
  - message: String
  - severity: NiveauSévérité
  - is_resolved: Boolean
  - created_at: DateTime
  --
  + createAlert()
  + resolve()
}

' ==================== GDPR COMPLIANCE ====================

class ConsentementGDPR {
  - id: UUID
  - user_id: UUID (FK)
  - consent_type: TypeConsent
  - data_category: String
  - consent_given: Boolean
  - consent_date: DateTime
  - consent_method: MethodConsent
  - consent_version: String
  - ip_address: String
  - user_agent: String
  - expiry_date: DateTime (optionnel)
  - revoked_at: DateTime (optionnel)
  - revoked_reason: String (optionnel)
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + giveConsent(): void
  + revokeConsent(reason: String): void
  + isActiveNow(): Boolean
  + getAuditTrail(): List
}

enum TypeConsent {
  PAIE_DATA
  MEDICAL_DATA
  PHOTO
  EMAIL_MARKETING
  COOKIES
  OTHER
}

enum MethodConsent {
  FORM_SIGNATURE
  EMAIL_CONFIRMATION
  VERBAL_WITH_WITNESS
  IMPLICIT
}

class ExportDonnées {
  - id: UUID
  - user_id: UUID (FK)
  - scope: PortéeExport
  - format: FormatExport
  - status: StatutExport
  - file_url: String
  - encryption_key: String (OBLIGATOIRE)
  - encryption_algorithm: String (ex: AES256-GCM)
  - exported_to_email: String (destinataire validé)
  - export_purpose: PurposeExport
  - authorized_by: UUID (FK) -> Utilisateur
  - authorization_date: DateTime
  - expires_at: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  --
  + generateExport()
  + generateDownloadToken()
  + deleteExpiredFile()
  + revokeAccess()
}

enum PurposeExport {
  DATA_PORTABILITY
  VERIFICATION
  BACKUP
  LEGAL_REQUEST
  OTHER
}

enum PortéeExport {
  PERSONAL_DATA
  EMPLOYMENT_DATA
  PAYROLL_DATA
  FULL_DATA
}

enum FormatExport {
  JSON
  CSV
  XML
  PDF
}

enum StatutExport {
  REQUESTED
  GENERATING
  READY
  DOWNLOADED
  EXPIRED
  REVOKED
}

' ==================== RELATIONS ====================

Utilisateur "1" *-- "*" ConsentementGDPR : donne
Utilisateur "1" --> "*" ExportDonnées : demande
Utilisateur "1" --> "*" JournalAudit : approuve
Utilisateur "1" *-- "*" Session : a
Utilisateur "1" *-- "1" AuthDoubleFacteur : configure
Secrétariat "1" *-- "1" Facturation : possède
Secrétariat "1" *-- "*" CléAPI : émet
Secrétariat "1" *-- "*" Webhook : configure
Secrétariat "1" *-- "1" ConfigWhiteLabel : configure
ConfigWhiteLabel "1" --> "*" ValidateurDomaine : utilise
CléAPI "1" --> "1" StatistiquesUtilisationAPI : suit
Utilisateur "1" *-- "*" JournalAudit : génère
MoniteurSystème "1" *-- "*" AlerteSystème : triggers
SourceLégislative "1" *-- "*" AlerteLégislative : produit

@enduml
