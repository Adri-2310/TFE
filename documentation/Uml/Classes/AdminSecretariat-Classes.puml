  VERBAL_AVEC_TEMOIN
  IMPLICITE
}

' ==================== RELATIONS ====================

Utilisateur "1" *-- "*" ConsentementRGPD : donne
Utilisateur "1" --> "*" ExportDonnees : demande
Utilisateur "1" --> "*" JournalAudit : approuve
Utilisateur "1" *-- "*" Session : a
Utilisateur "1" *-- "1" AuthDoubleFacteur : configure
Utilisateur "1" *-- "1" ParamNotifications : definit
Utilisateur "1" *-- "*" ModeleDoc : cree
Utilisateur "1" --> "*" IndexationSalaire : approuve
Utilisateur "1" --> "*" HeuresSupplémentaires : approuve
Utilisateur "1" --> "*" PrimeEtMajoration : approuve
TempRegistration "1" *-- "0..1" Secrétariat : cree
Secrétariat "1" *-- "*" Client : gere
Secrétariat "1" *-- "*" Consultant : emploie
Secrétariat "1" *-- "*" ModeleDoc : possede
Secrétariat "1" *-- "*" AnalytiquesSecretariat : suit
Client "*" --> "1" Consultant : assigne_a
Client "1" *-- "*" Employe : a
Client "1" *-- "1" AffiliationSecuriteSociale : possede
Employe "1" *-- "1" AllocationFamiliale : reçoit
Employe "1" *-- "*" HeuresSupplémentaires : effectue
Employe "1" *-- "*" PrimeEtMajoration : reçoit
Client "1" *-- "*" FichePaie : genere
Client "1" *-- "*" Declaration : soumet
Employe "1" *-- "*" Contrat : a
Employe "1" *-- "*" IndexationSalaire : subit
Employe "1" *-- "*" FichePaie : reçoit
Contrat "1" *-- "*" IndexationSalaire : reference
Contrat "1" *-- "*" PrimeEtMajoration : determine
FichePaie "1" *-- "*" HeuresSupplémentaires : contient
FichePaie "*" --> "*" PrimeEtMajoration : inclut
FichePaie "*" --> "1" Declaration : reference
Declaration "*" --> "1" AffiliationSecuriteSociale : utilise
Consultant "1" *-- "1" Utilisateur : a
ModeleDoc "1" *-- "*" DocGeneree : genere
Utilisateur "1" *-- "*" JournalAudit : genere
Utilisateur "1" *-- "*" JournalNotifications : reçoit
Utilisateur "1" *-- "0..1" DemandeSuppressionData : demande

@enduml


