@startuml AdminSecretariat_Classes
!theme plain
title Classes AdminSecretariat - WorkZen v1.0

' ==================== UTILISATEUR & SÉCURITÉ ====================

class Utilisateur {
  - id: UUID
  - email: Email
  - hachage_mot_de_passe: Texte
  - prenom: Texte
  - nom: Texte
  - telephone: Texte
  - url_avatar: Texte
  - role: RoleUtilisateur = ADMIN_SECRETARIAT
  - est_actif: Booléen
  - derniere_connexion: DateTime
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + changerMotDePasse()
  + activer2FA()
  + mettreAJourProfil()
}

class Session {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - jeton: Texte
  - adresse_ip: Texte
  - agent_utilisateur: Texte
  - cree_a: DateTime
  - expire_a: DateTime
  --
  + estValide(): Booléen
  + revoquer()
}

class AuthDoubleFacteur {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - secret_totp: Texte (chiffré)
  - est_actif: Booléen
  - codes_secours: Texte (tableau chiffré)
  --
  + genererSecret()
  + validerCode()
  + genererCodesSecours()
  + estValide(): Booléen
}

class ParamNotifications {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - email_actif: Booléen
  - sms_actif: Booléen
  - notification_app_active: Booléen
  - frequence: FrequenceNotification
  - types: Texte (tableau) (JSON)
  - mis_a_jour_a: DateTime
  --
  + mettreAJourPreferences()
  + testerNotification()
}

enum FrequenceNotification {
  IMMEDIAT
  QUOTIDIEN
  HEBDOMADAIRE
}

' ==================== SECRÉTARIAT ====================

class Secrétariat {
  - id: UUID
  - nom: Texte
  - numero_tva: Texte
  - email: Email
  - telephone: Texte
  - adresse: Texte
  - pays: Texte
  - url_logo: Texte
  - plan_abonnement: PlanAbonnement
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + mettreAJourProfil()
  + gererFacturation()
  + afficherAnalytiques()
}

enum PlanAbonnement {
  STARTER
  PROFESSIONNEL
  ENTREPRISE
}

' ==================== GESTION CLIENT ====================

class Client {
  - id: UUID
  - id_secretariat: UUID (FK)
  - numero_tva: Texte
  - nom_entreprise: Texte
  - email_contact: Texte
  - telephone_contact: Texte
  - adresse: Texte
  - nombre_employes: Entier
  - id_consultant: UUID (FK)
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + creerClient()
  + mettreAJourInfo()
  + assignerConsultant()
  + suspendreCompte()
}

class Consultant {
  - id: UUID
  - id_secretariat: UUID (FK)
  - id_utilisateur: UUID (FK)
  - prenom: Texte
  - nom: Texte
  - email: Email
  - telephone: Texte
  - nombre_clients: Entier
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + afficherCasesLoad()
  + afficherDetailsClient()
  + assignerClient()
  + retirerClient()
}

' ==================== EMPLOYÉ & CONTRAT ====================

class Employe {
  - id: UUID
  - id_client: UUID (FK)
  - id_utilisateur: UUID (FK, optionnel) → Utilisateur
  - prenom: Texte
  - nom: Texte
  - niss: Texte (masqué) [CHIFFRE_AES256]
  - email: Email
  - telephone: Texte
  - date_naissance: Date [CHIFFRE_AES256]
  - email: Email
  - telephone: Texte
  - date_embauche: Date
  - titre_poste: Texte
  - departement: Texte
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + creerEmploye()
  + mettreAJourInfo()
  + desactiver()
}

' === DONNÉES SENSIBLES (RGPD Article 9) ===
' Chiffrement AES256 obligatoire sur:
' - Identité (NISS, date_naissance)

class Contrat {
  - id: UUID
  - id_employe: UUID (FK)
  - type_contrat: TypeContrat
  - date_debut: Date
  - date_fin: Date (optionnel si CDI)
  - salaire_brut: Décimal
  - url_fichier_contrat: Texte (optionnel)
  - statut: StatutContrat
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + creerContrat()
  + resilierContrat()
  + estActif(): Booléen
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  INTERIM
}

enum StatutContrat {
  ACTIF
  TERMINE
  SUSPENDU
  RESILIE
}

enum StatutDIMONA {
  EN_ATTENTE
  SOUMISE
  ACCEPTEE
  REJETEE
  ANNULEE
}

enum StatutFichePaie {
  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

' ==================== INDEXATION SALARIALE ====================

class IndexationSalaire {
  - id: UUID
  - id_employe: UUID (FK)
  - id_contrat: UUID (FK)
  - date_effet: Date
  - salaire_base: Décimal
  - pourcentage_indexation: Décimal
  - montant_indexation: Décimal
  - nouveau_salaire: Décimal
  - raison_indexation: enum (INDEX_ANNUEL, PROMOTION, AJUSTEMENT, TARIF_MARCHE)
  - approuve_par: UUID (FK) -> Utilisateur
  - date_approbation: DateTime
  - statut: enum (EN_ATTENTE, APPROUVE, REJETE, APPLIQUE)
  - notes: Texte (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + calculerNouveauSalaire(): Décimal
  + appliquer(): vide
  + rejeter(raison: Texte): vide
  + obtenirHistoriqueIndexation(): Liste
}

' ==================== ALLOCATIONS FAMILIALES ====================

class AllocationFamiliale {
  - id: UUID
  - id_employe: UUID (FK)
  - nombre_enfants: Entier
  - montant_premier_enfant: Décimal
  - montant_deuxieme_enfant: Décimal
  - montant_troisieme_plus: Décimal
  - total_mensuel: Décimal (calculé)
  - effectif_a_partir_de: Date
  - effectif_jusqu_a: Date (optionnel)
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + calculerAllocationMensuelle(): Décimal
  + mettreAJourNombreEnfants()
  + obtenirMontantParEnfant(): Décimal
}

' ==================== AFFILIATION SÉCURITÉ SOCIALE ====================

class AffiliationSecuriteSociale {
  - id: UUID
  - id_client: UUID (FK)
  - numero_onss: Texte (unique par secrétariat, format: XX.XXX.XXX.XXX)
  - type_affiliation: TypeAffiliation
  - date_affiliation: Date
  - nom_juridique_entreprise: Texte
  - code_nace_entreprise: Texte
  - telephone_contact_onss: Texte
  - email_contact_onss: Email
  - iban_compte_bancaire: Texte (chiffré)
  - bic_compte_bancaire: Texte
  - est_actif: Booléen
  - derniere_validation_a: DateTime
  - statut_validation: StatutValidationAffiliation
  - erreur_validation: Texte (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + validerNumeroONSS(): Booléen
  + verifierAvecONSS(): Booléen
  + obtenirHistoriqueAffiliation(): Liste
  + mettreAJourComptesBancaires(iban, bic): vide
}

enum TypeAffiliation {
  INDEPENDANT
  SALARIE
  MIXTE
  AUTRE
}

enum StatutValidationAffiliation {
  NON_VERIFIE
  VERIFIE
  REJETE
}

' ==================== HEURES SUPPLÉMENTAIRES ====================

class HeuresSupplémentaires {
  - id: UUID
  - id_employe: UUID (FK)
  - id_fiche_paie: UUID (FK)
  - date_debut_periode: Date
  - date_fin_periode: Date
  - heures_50_pourcent: Décimal
  - heures_100_pourcent: Décimal
  - montant_50_pourcent: Décimal (calculé)
  - montant_100_pourcent: Décimal (calculé)
  - montant_total: Décimal (calculé)
  - tarif_horaire_base: Décimal
  - type_heures_supplémentaires: TypeHeuresSupplémentaires
  - approuve_par: UUID (FK) -> Utilisateur
  - date_approbation: DateTime
  - est_approuve: Booléen
  - notes: Texte (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + calculerMontant(): Décimal
  + approuver(): vide
  + rejeter(raison: Texte): vide
  + obtenirTotalMensuel(): Décimal
}

enum TypeHeuresSupplémentaires {
  REGULIER
  TRAVAIL_NUIT
  FIN_SEMAINE
  JOUR_FERIE
}

' ==================== PRIMES & MAJORATIONS ====================

class PrimeEtMajoration {
  - id: UUID
  - id_employe: UUID (FK)
  - id_contrat: UUID (FK)
  - periode_mois: Texte (YYYY-MM)
  - type_prime: TypePrime
  - montant: Décimal
  - pourcentage: Décimal (optionnel)
  - montant_base: Décimal
  - est_imposable: Booléen
  - effectif_a_partir_de: Date
  - effectif_jusqu_a: Date (optionnel)
  - approuve_par: UUID (FK) -> Utilisateur
  - notes: Texte (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + calculerMontant(): Décimal
  + estActifPourMois(mois: Texte): Booléen
}

enum TypePrime {
  BONUS_NUIT
  BONUS_VACANCES
  BONUS_ANCIENNETE
  CHEQUES_REPAS
  ALLOCATION_TRANSPORT
  PERSONNALISE
}

' ==================== PAIE & DÉCLARATIONS ====================

class FichePaie {
  - id: UUID
  - id_employe: UUID (FK)
  - id_client: UUID (FK)
  - date_debut_periode: Date
  - date_fin_periode: Date
  ' === REVENUS ===
  - salaire_brut: Décimal
  - allocations_familiales: Décimal
  - heures_supplementaires_total: Décimal
  - primes_et_majorations_total: Décimal
  ' === COTISATIONS ===
  - onss_employe: Décimal
  - taux_onss: Décimal (calculé)
  - onss_employeur: Décimal
  - montant_precompte: Décimal
  - taux_precompte: Décimal (calculé)
  ' === IMPÔT ===
  - taux_impot: Décimal
  ' === EMPLOYEUR ===
  - charges_employeur: Décimal
  ' === RÉSULTAT ===
  - salaire_net: Décimal
  ' === DIMONA ===
  - dimona_envoye_a: DateTime (optionnel)
  - statut_dimona: StatutDIMONA
  ' === STATUT ===
  - statut_fiche_paie: StatutFichePaie
  - chemin_pdf: Texte (optionnel)
  - date_envoi: DateTime (optionnel)
  - generee_a: DateTime
  - mis_a_jour_a: DateTime
  --
  + creerFichePaie()
  + calculerNet()
  + genererPDF()
  + envoyerAEmploye()
  + envoyerADIMONA()
}

class Declaration {
  - id: UUID
  - id_client: UUID (FK)
  - type_declaration: TypeDeclaration
  - periode: Texte (YYYY-MM)
  - nombre_employes: Entier
  - statut: StatutDeclaration
  - url_fichier: Texte (optionnel)
  - raison_rejet: Texte (optionnel)
  - soumise_a: DateTime (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
