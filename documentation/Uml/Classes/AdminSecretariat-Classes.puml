@startuml AdminSecretariat_Classes
!theme plain
title Classes AdminSecretariat - SocialFlow v1.0

' ==================== USER & SECURITY ====================

class Utilisateur {
  - id: UUID
  - email: String
  - password_hash: String
  - first_name: String
  - last_name: String
  - phone: String
  - avatar_url: String
  - role: RoleUtilisateur = ADMIN_SECRETARIAT
  - is_active: Boolean
  - last_login: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + changePassword()
  + enable2FA()
  + updateProfile()
}

class Session {
  - id: UUID
  - user_id: UUID (FK)
  - token: String
  - ip_address: String
  - user_agent: String
  - created_at: DateTime
  - expires_at: DateTime
  --
  + isValid(): Boolean
  + revoke()
}

class AuthDoubleFacteur {
  - id: UUID
  - user_id: UUID (FK)
  - totp_secret: String (encrypted)
  - is_enabled: Boolean
  - backup_codes: String (encrypted array)
  --
  + generateSecret()
  + validateCode()
  + generateBackupCodes()
  + isValid(): Boolean
}

class ParamNotifications {
  - id: UUID
  - user_id: UUID (FK)
  - email_enabled: Boolean
  - sms_enabled: Boolean
  - in_app_enabled: Boolean
  - frequency: FréquenceNotification
  - types: String (array) (JSON)
  - updated_at: DateTime
  --
  + updatePreferences()
  + testNotification()
}

enum FréquenceNotification {
  IMMEDIATE
  DAILY
  WEEKLY
}

' ==================== SECRETARIAT ====================

class Secrétariat {
  - id: UUID
  - name: String
  - vat_number: String
  - email: String
  - phone: String
  - address: String
  - country: String
  - logo_url: String
  - subscription_plan: PlanAbonnement
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + updateProfile()
  + manageTarification()
  + viewAnalytics()
}

enum PlanAbonnement {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

' ==================== CLIENT MANAGEMENT ====================

class Client {
  - id: UUID
  - secretariat_id: UUID (FK)
  - vat_number: String
  - company_name: String
  - contact_email: String
  - contact_phone: String
  - address: String
  - employees_count: Integer
  - consultant_id: UUID (FK)
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + createClient()
  + updateInfo()
  + assignConsultant()
  + suspendAccount()
}

class Consultant {
  - id: UUID
  - secretariat_id: UUID (FK)
  - user_id: UUID (FK)
  - first_name: String
  - last_name: String
  - email: String
  - phone: String
  - clients_count: Integer
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + viewCaseload()
  + viewClientDetails()
  + assignClient()
  + removeClient()
}

' ==================== EMPLOYEE & CONTRACT ====================

class Employé {
  - id: UUID
  - client_id: UUID (FK)
  - user_id: UUID (FK, optionnel) → Utilisateur
  - first_name: String
  - last_name: String
  - niss: String (masked) [ENCRYPTED_AES256]
  - email: String
  - phone: String
  - birth_date: Date [ENCRYPTED_AES256]
  - hire_date: Date
  - job_title: String
  - department: String
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + createEmployee()
  + updateInfo()
  + deactivate()
}

' === DONNÉES SENSIBLES (RGPD Article 9) ===
' Chiffrement AES256 obligatoire sur:
' - Identité (NISS, birth_date)

class Contrat {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_type: TypeContrat
  - start_date: Date
  - end_date: Date (optionnel si CDI)
  - salary_gross: Decimal
  - contract_file_url: String (optionnel)
  - status: StatutContrat
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + createContract()
  + terminateContract()
  + isActive(): Boolean
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  INTERIM
}

enum StatutContrat {
  ACTIVE
  COMPLETED
  SUSPENDED
  TERMINATED
}

enum DIMONAStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum PaySlipStatus {
  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

' ==================== INDEXATION SALARIALE ====================

class IndexationSalaire {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_id: UUID (FK)
  - effective_date: Date
  - base_salary: Decimal
  - indexation_percentage: Decimal
  - indexation_amount: Decimal
  - new_salary: Decimal
  - indexation_reason: enum (ANNUAL_INDEX, PROMOTION, ADJUSTMENT, MARKET_RATE)
  - approved_by: UUID (FK) -> Utilisateur
  - approval_date: DateTime
  - status: enum (PENDING, APPROVED, REJECTED, APPLIED)
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateNewSalary(): Decimal
  + apply(): void
  + reject(reason: String): void
  + getIndexationHistory(): List
}

' ==================== ALLOCATIONS FAMILIALES ====================

class AllocationFamiliale {
  - id: UUID
  - employee_id: UUID (FK)
  - number_of_children: Integer
  - first_child_amount: Decimal
  - second_child_amount: Decimal
  - third_plus_amount: Decimal
  - monthly_total: Decimal (calculé)
  - effective_from: Date
  - effective_to: Date (optionnel)
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateMonthlyAllowance(): Decimal
  + updateChildCount()
  + getAmountForChild(): Decimal
}

' ==================== AFFILIATION SÉCURITÉ SOCIALE ====================

class AffiliationSecuriteSociale {
  - id: UUID
  - client_id: UUID (FK)
  - onss_number: String (unique par secrétariat, format: XX.XXX.XXX.XXX)
  - affiliation_type: TypeAffiliation
  - affiliation_date: Date
  - company_legal_name: String
  - company_nace_code: String
  - contact_onss_phone: String
  - contact_onss_email: String
  - bank_account_iban: String (encrypted)
  - bank_account_bic: String
  - is_active: Boolean
  - last_validated_at: DateTime
  - validation_status: StatutValidationAffiliation
  - validation_error: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + validateONSSNumber(): Boolean
  + verifyWithONSS(): Boolean
  + getAffiliationHistory(): List
  + updateBankAccount(iban, bic): void
}

enum TypeAffiliation {
  INDÉPENDANT
  SALARIÉ
  MIXTE
  AUTRE
}

enum StatutValidationAffiliation {
  UNVERIFIED
  VERIFIED
  REJECTED
}

' ==================== HEURES SUPPLÉMENTAIRES ====================

class HeuresSupplémentaires {
  - id: UUID
  - employee_id: UUID (FK)
  - fiche_paye_id: UUID (FK)
  - period_start: Date
  - period_end: Date
  - hours_50_percent: Decimal
  - hours_100_percent: Decimal
  - amount_50_percent: Decimal (calculé)
  - amount_100_percent: Decimal (calculé)
  - total_amount: Decimal (calculé)
  - hourly_rate_base: Decimal
  - overtime_type: TypeHeuresSupplémentaires
  - approved_by: UUID (FK) -> Utilisateur
  - approval_date: DateTime
  - is_approved: Boolean
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateAmount(): Decimal
  + approve(): void
  + reject(reason: String): void
  + getMonthlyTotal(): Decimal
}

enum TypeHeuresSupplémentaires {
  REGULAR
  NIGHT_SHIFT
  WEEKEND
  HOLIDAY
}

' ==================== PRIMES & MAJORATIONS ====================

class PrimeEtMajoration {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_id: UUID (FK)
  - period_month: String (YYYY-MM)
  - prime_type: TypePrime
  - amount: Decimal
  - percentage: Decimal (optionnel)
  - base_amount: Decimal
  - is_taxable: Boolean
  - effective_from: Date
  - effective_to: Date (optionnel)
  - approved_by: UUID (FK) -> Utilisateur
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateAmount(): Decimal
  + isActiveForMonth(month: String): Boolean
}

enum TypePrime {
  NIGHT_BONUS
  HOLIDAY_BONUS
  SENIORITY_BONUS
  MEAL_VOUCHERS
  TRANSPORT_ALLOWANCE
  CUSTOM
}

' ==================== PAYROLL & DECLARATIONS ====================

class FichePaye {
  - id: UUID
  - employee_id: UUID (FK)
  - client_id: UUID (FK)
  - period_start: Date
  - period_end: Date
  ' === REVENUS ===
  - salary_gross: Decimal
  - allocations_familiales: Decimal
  - heures_supplementaires_total: Decimal
  - primes_et_majorations_total: Decimal
  ' === COTISATIONS ===
  - onss_employee: Decimal
  - onss_rate: Decimal (calculé)
  - onss_employer: Decimal
  - precompte_amount: Decimal
  - precompte_rate: Decimal (calculé)
  ' === IMPÔT ===
  - taux_impot: Decimal
  ' === EMPLOYEUR ===
  - employer_charges: Decimal
  ' === RÉSULTAT ===
  - salary_net: Decimal
  ' === DIMONA ===
  - dimona_sent_at: DateTime (optionnel)
  - dimona_status: DIMONAStatus
  ' === STATUT ===
  - payslip_status: PaySlipStatus
  - chemin_pdf: String (optionnel)
  - date_envoi: DateTime (optionnel)
  - generated_at: DateTime
  - updated_at: DateTime
  --
  + createPayslip()
  + calculateNet()
  + generatePDF()
  + sendToEmployee()
  + sendToDIMONA()
}

class Déclaration {
  - id: UUID
  - client_id: UUID (FK)
  - declaration_type: TypeDéclaration
  - period: String (YYYY-MM)
  - employee_count: Integer
  - status: StatutDéclaration
  - file_url: String (optionnel)
  - rejection_reason: String (optionnel)
  - submitted_at: DateTime (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + generateFile()
  + submit()
  + validate()
}

enum TypeDéclaration {
  ONSS_CONTRIBUTION
  PRECOMPTE
  DIMONA
}

enum StatutDéclaration {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  PROCESSED
}

' ==================== DOCUMENTS ====================

class ModèleDoc {
  - id: UUID
  - secretariat_id: UUID (FK)
  - name: String
  - category: String
  - content: String (rich text)
  - variables: String (array) (JSON)
  - created_by: UUID (FK) -> Utilisateur
  ' Validation: Utilisateur.role IN [CONSULTANT, ADMIN_SECRETARIAT, SUPER_ADMIN]
  - is_global: Boolean
  - usage_count: Integer
  - created_at: DateTime
  - updated_at: DateTime
  --
  + createTemplate()
  + updateTemplate()
  + deleteTemplate()
}

class DocGénéré {
  - id: UUID
  - template_id: UUID (FK)
  - client_id: UUID (FK)
  - employee_id: UUID (FK, optionnel)
  - content: String (merged)
  - file_url: String
  - file_format: FormatFichier
  - access_token: String
  - access_token_expires_at: DateTime
  - download_count: Integer
  - created_at: DateTime
  --
  + generatePDF()
  + generateAccessToken()
}

enum FormatFichier {
  PDF
  DOCX
  EXCEL
}

' ==================== EXPORT & DATA ====================

class ExportDonnées {
  - id: UUID
  - user_id: UUID (FK)
  - scope: PortéeExport
  - format: FormatExport
  - status: StatutExport
  - file_url: String
  - encryption_key: String (OBLIGATOIRE)
  - encryption_algorithm: String (ex: AES256-GCM)
  - exported_to_email: String (destinataire validé)
  - export_purpose: PurposeExport
  - authorized_by: UUID (FK) -> Utilisateur
  - authorization_date: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  - expires_at: DateTime
  --
  + generateExport()
  + generateDownloadToken()
  + deleteExpiredFile()
  + revokeAccess()
}

enum PurposeExport {
  DATA_PORTABILITY
  VERIFICATION
  BACKUP
  LEGAL_REQUEST
  OTHER
}

enum PortéeExport {
  ALL
  CLIENTS
  EMPLOYEES
  PAYSLIPS
  DECLARATIONS
}

enum FormatExport {
  CSV
  EXCEL
  JSON
  XML
}

enum StatutExport {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

class DemandeSupPression {
  - id: UUID
  - user_id: UUID (FK)
  - requested_at: DateTime
  - scheduled_delete_at: DateTime
  - status: StatutSupPression
  --
  + requestDeletion()
  + cancelDeletion()
  + executeDeletion()
}

enum StatutSupPression {
  PENDING
  CONFIRMED
  EXECUTED
  CANCELLED
}

' ==================== TEMPORARY DATA (REGISTRATION) ====================

class TempRegistration {
  - id: UUID
  - email: String
  - first_name: String
  - last_name: String
  - company_name: String
  - vat_number: String
  - plan: PlanAbonnement
  - stripe_session_id: String
  - status: StatutTempRegistration
  - expires_at: DateTime
  - created_at: DateTime
  --
  + createTempRecord()
  + updateFromStripeCallback()
  + findByStripeSessionId()
  + expireAfter24h()
}

enum StatutTempRegistration {
  PENDING
  PAYMENT_PROCESSING
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  EXPIRED
}

' ==================== ANALYTICS ====================

class AnalytiquesSecrétariat {
  - id: UUID
  - secretariat_id: UUID (FK)
  - period: String (YYYY-MM)
  - clients_count: Integer
  - employees_total: Integer
  - total_payroll: Decimal
  - cached_at: DateTime
  --
  + calculateMetrics()
  + generateReport()
}

' ==================== AUDIT & LOGS ====================

class JournalAudit {
  - id: UUID
  - user_id: UUID (FK)
  - action: String
  - entity_type: String
  - entity_id: UUID
  - changes: JSON
  - ip_address: String
  - user_agent: String
  - reason: String (optionnel)
  - requires_approval: Boolean
  - approved_by: UUID (FK) -> Utilisateur
  - approved_at: DateTime
  - created_at: DateTime
  - deleted_at: DateTime (soft-delete)
  - anonymized_at: DateTime
  - anonymized_by: UUID
  --
  + logAction()
  + queryHistory()
  + anonymize()
}

class JournalNotifications {
  - id: UUID
  - user_id: UUID (FK)
  - notification_type: String
  - subject: String
  - body: String
  - channels: String (array) [EMAIL, SMS, IN_APP]
  - status: StatutJournal
  - sent_at: DateTime
  - deleted_at: DateTime (soft-delete)
  - delivery_log: String (array) (JSON)
  --
  + logSend()
  + trackDelivery()
}

enum StatutJournal {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

' ==================== GDPR COMPLIANCE ====================

class ConsentementGDPR {
  - id: UUID
  - user_id: UUID (FK)
  - consent_type: TypeConsent
  - data_category: String
  - consent_given: Boolean
  - consent_date: DateTime
  - consent_method: MethodConsent
  - consent_version: String
  - ip_address: String
  - user_agent: String
  - expiry_date: DateTime (optionnel)
  - revoked_at: DateTime (optionnel)
  - revoked_reason: String (optionnel)
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + giveConsent(): void
  + revokeConsent(reason: String): void
  + isActiveNow(): Boolean
  + getAuditTrail(): List
}

enum TypeConsent {
  PAIE_DATA
  MEDICAL_DATA
  PHOTO
  EMAIL_MARKETING
  COOKIES
  OTHER
}

enum MethodConsent {
  FORM_SIGNATURE
  EMAIL_CONFIRMATION
  VERBAL_WITH_WITNESS
  IMPLICIT
}

' ==================== RELATIONS ====================

Utilisateur "1" *-- "*" ConsentementGDPR : donne
Utilisateur "1" --> "*" ExportDonnées : demande
Utilisateur "1" --> "*" JournalAudit : approuve
Utilisateur "1" *-- "*" Session : a
Utilisateur "1" *-- "1" AuthDoubleFacteur : configure
Utilisateur "1" *-- "1" ParamNotifications : définit
Utilisateur "1" *-- "*" ModèleDoc : crée
Utilisateur "1" --> "*" IndexationSalaire : approuve
Utilisateur "1" --> "*" HeuresSupplémentaires : approuve
Utilisateur "1" --> "*" PrimeEtMajoration : approuve
TempRegistration "1" *-- "0..1" Secrétariat : crée
Secrétariat "1" *-- "*" Client : gère
Secrétariat "1" *-- "*" Consultant : emploie
Secrétariat "1" *-- "*" ModèleDoc : possède
Secrétariat "1" *-- "*" AnalytiquesSecrétariat : suit
Client "*" --> "1" Consultant : assigné_à
Client "1" *-- "*" Employé : a
Client "1" *-- "1" AffiliationSecuriteSociale : possède
Employé "1" *-- "1" AllocationFamiliale : reçoit
Employé "1" *-- "*" HeuresSupplémentaires : effectue
Employé "1" *-- "*" PrimeEtMajoration : reçoit
Client "1" *-- "*" FichePaye : génère
Client "1" *-- "*" Déclaration : soumet
Employé "1" *-- "*" Contrat : a
Employé "1" *-- "*" IndexationSalaire : subit
Employé "1" *-- "*" FichePaye : reçoit
Employé "1" *-- "*" DemandeConge : crée
Employé "1" *-- "*" SoldeConge : suit (leave_type, year)
Contrat "1" *-- "*" IndexationSalaire : référence
Contrat "1" *-- "*" PrimeEtMajoration : détermine
FichePaye "1" *-- "*" HeuresSupplémentaires : contient
FichePaye "*" --> "*" PrimeEtMajoration : inclut
FichePaye "*" --> "1" Déclaration : référence
Déclaration "*" --> "1" AffiliationSecuriteSociale : utilise
DemandeConge "1" *-- "1" Consultant : approuvé par
Consultant "1" *-- "1" Utilisateur : a
ModèleDoc "1" *-- "*" DocGénéré : génère
Utilisateur "1" *-- "*" JournalAudit : génère
Utilisateur "1" *-- "*" JournalNotifications : reçoit
Utilisateur "1" *-- "0..1" DemandeSupPression : demande

@enduml

