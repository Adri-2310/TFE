  + genererFichier()
  + soumettre()
  + valider()
}

enum TypeDeclaration {
  COTISATION_ONSS
  PRECOMPTE
  DIMONA
}

enum StatutDeclaration {
  BROUILLON
  SOUMISE
  ACCEPTEE
  REJETEE
  TRAITEE
}

