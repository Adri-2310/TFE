  - methode_consentement: MethodeConsentement
  - version_consentement: Texte
  - adresse_ip: Texte
  - agent_utilisateur: Texte
  - date_expiration: DateTime (optionnel)
  - revoque_a: DateTime (optionnel)
  - raison_revocation: Texte (optionnel)
  - notes: Texte (optionnel)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
