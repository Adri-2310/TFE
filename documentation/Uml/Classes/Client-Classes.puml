@startuml Client_Classes
!theme plain
title Classes Client - SocialFlow v1.0

' ==================== SECRETARIAT ====================

class Secrétariat {
  - id: UUID
  - name: String
  - vat_number: String
  - email: String
  - phone: String
  - address: String
  - country: String
  - logo_url: String
  - subscription_plan: PlanAbonnement
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + updateProfile()
}

enum PlanAbonnement {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

' ==================== USER & SECURITY ====================

class Utilisateur {
  - id: UUID
  - email: String
  - password_hash: String
  - first_name: String
  - last_name: String
  - phone: String
  - avatar_url: String
  - role: RoleUtilisateur = CLIENT
  - is_active: Boolean
  - last_login: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + changePassword()
  + enable2FA()
  + updateProfile()
}

class Session {
  - id: UUID
  - user_id: UUID (FK)
  - token: String
  - ip_address: String
  - user_agent: String
  - created_at: DateTime
  - expires_at: DateTime
  --
  + isValid(): Boolean
  + revoke()
}

class AuthDoubleFacteur {
  - id: UUID
  - user_id: UUID (FK)
  - totp_secret: String (encrypted)
  - is_enabled: Boolean
  - backup_codes: String (encrypted array)
  --
  + generateSecret()
  + validateCode()
  + generateBackupCodes()
  + isValid(): Boolean
}

class ParamNotifications {
  - id: UUID
  - user_id: UUID (FK)
  - email_enabled: Boolean
  - sms_enabled: Boolean
  - in_app_enabled: Boolean
  - frequency: FréquenceNotification
  - types: String (array) (JSON)
  - updated_at: DateTime
  --
  + updatePreferences()
  + testNotification()
}

enum FréquenceNotification {
  IMMEDIATE
  DAILY
  WEEKLY
}

' ==================== CLIENT PROFILE ====================

class Client {
  - id: UUID
  - secretariat_id: UUID (FK)
  - vat_number: String
  - company_name: String
  - contact_email: String
  - contact_phone: String
  - address: String
  - billing_address: String
  - employees_count: Integer
  - consultant_id: UUID (FK)
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + updateProfile()
  + viewConsultant()
  + viewAnalytics()
  + downloadCertificates()
}

class Consultant {
  - id: UUID
  - secretariat_id: UUID (FK)
  - user_id: UUID (FK)
  - first_name: String
  - last_name: String
  - email: String
  - phone: String
  - clients_count: Integer
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + viewCaseload()
  + viewClientDetails()
}

' ==================== EMPLOYEE & PAYROLL ====================

class Employé {
  - id: UUID
  - user_id: UUID (FK)
  - client_id: UUID (FK)
  - first_name: String
  - last_name: String
  - niss: String (masked) [ENCRYPTED_AES256]
  - email: String
  - phone: String
  - birth_date: Date [ENCRYPTED_AES256]
  - hire_date: Date
  - job_title: String
  - department: String
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + viewProfile()
  + getPayslips()
  + downloadCertificates()
}

' === DONNÉES SENSIBLES (RGPD Article 9) ===
' Chiffrement AES256 obligatoire sur:
' - Identité (NISS, birth_date)

class Contrat {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_type: TypeContrat
  - start_date: Date
  - end_date: Date (optionnel si CDI)
  - salary_gross: Decimal
  - contract_file_url: String (optionnel)
  - status: StatutContrat
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + viewContract()
  + isActive(): Boolean
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  INTERIM
}

enum StatutContrat {
  ACTIVE
  COMPLETED
  SUSPENDED
  TERMINATED
}

class FichePaye {
  - id: UUID
  - employee_id: UUID (FK)
  - client_id: UUID (FK)
  - period_start: Date
  - period_end: Date
  ' === REVENUS ===
  - salary_gross: Decimal
  - allocations_familiales: Decimal
  - heures_supplementaires_total: Decimal
  - primes_et_majorations_total: Decimal
  ' === COTISATIONS ===
  - onss_employee: Decimal
  - onss_rate: Decimal (calculé)
  - onss_employer: Decimal
  - precompte_amount: Decimal
  - precompte_rate: Decimal (calculé)
  ' === IMPÔT ===
  - taux_impot: Decimal
  ' === EMPLOYEUR ===
  - employer_charges: Decimal
  ' === RÉSULTAT ===
  - salary_net: Decimal
  ' === DIMONA ===
  - dimona_sent_at: DateTime (optionnel)
  - dimona_status: DIMONAStatus
  ' === STATUT ===
  - payslip_status: PaySlipStatus
  - chemin_pdf: String (optionnel)
  - date_envoi: DateTime (optionnel)
  - generated_at: DateTime
  - updated_at: DateTime
  --
  + viewPayslip()
  + downloadPayslip()
  + viewBreakdown()
}

class CertificatC4 {
  - id: UUID
  - employee_id: UUID (FK)
  - client_id: UUID (FK)
  - period_start: Date
  - period_end: Date
  - days_worked: Integer
  - salary_gross: Decimal
  - file_url: String
  - generated_at: DateTime
  - access_token: String
  - access_token_expires_at: DateTime
  --
  + viewCertificate()
  + downloadCertificate()
  + generateAccessToken()
}

' ==================== INDEXATION SALARIALE ====================

class IndexationSalaire {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_id: UUID (FK)
  - effective_date: Date
  - base_salary: Decimal
  - indexation_percentage: Decimal
  - indexation_amount: Decimal
  - new_salary: Decimal
  - indexation_reason: enum (ANNUAL_INDEX, PROMOTION, ADJUSTMENT, MARKET_RATE)
  - approved_by: UUID (FK) -> Utilisateur
  - approval_date: DateTime
  - status: enum (PENDING, APPROVED, REJECTED, APPLIED)
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateNewSalary(): Decimal
  + apply(): void
  + reject(reason: String): void
  + getIndexationHistory(): List
}

' ==================== ALLOCATIONS FAMILIALES ====================

class AllocationFamiliale {
  - id: UUID
  - employee_id: UUID (FK)
  - number_of_children: Integer
  - first_child_amount: Decimal
  - second_child_amount: Decimal
  - third_plus_amount: Decimal
  - monthly_total: Decimal (calculé)
  - effective_from: Date
  - effective_to: Date (optionnel)
  - is_active: Boolean
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateMonthlyAllowance(): Decimal
  + updateChildCount()
  + getAmountForChild(): Decimal
}

' ==================== AFFILIATION SÉCURITÉ SOCIALE ====================

class AffiliationSecuriteSociale {
  - id: UUID
  - client_id: UUID (FK)
  - onss_number: String (unique par secrétariat, format: XX.XXX.XXX.XXX)
  - affiliation_type: TypeAffiliation
  - affiliation_date: Date
  - company_legal_name: String
  - company_nace_code: String
  - contact_onss_phone: String
  - contact_onss_email: String
  - bank_account_iban: String (encrypted)
  - bank_account_bic: String
  - is_active: Boolean
  - last_validated_at: DateTime
  - validation_status: StatutValidationAffiliation
  - validation_error: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + validateONSSNumber(): Boolean
  + verifyWithONSS(): Boolean
  + getAffiliationHistory(): List
  + updateBankAccount(iban, bic): void
}

enum TypeAffiliation {
  INDÉPENDANT
  SALARIÉ
  MIXTE
  AUTRE
}

enum StatutValidationAffiliation {
  UNVERIFIED
  VERIFIED
  REJECTED
}

' ==================== HEURES SUPPLÉMENTAIRES ====================

class HeuresSupplémentaires {
  - id: UUID
  - employee_id: UUID (FK)
  - fiche_paye_id: UUID (FK)
  - period_start: Date
  - period_end: Date
  - hours_50_percent: Decimal
  - hours_100_percent: Decimal
  - amount_50_percent: Decimal (calculé)
  - amount_100_percent: Decimal (calculé)
  - total_amount: Decimal (calculé)
  - hourly_rate_base: Decimal
  - overtime_type: TypeHeuresSupplémentaires
  - approved_by: UUID (FK) -> Utilisateur
  - approval_date: DateTime
  - is_approved: Boolean
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateAmount(): Decimal
  + approve(): void
  + reject(reason: String): void
  + getMonthlyTotal(): Decimal
}

enum TypeHeuresSupplémentaires {
  REGULAR
  NIGHT_SHIFT
  WEEKEND
  HOLIDAY
}

' ==================== PRIMES & MAJORATIONS ====================

class PrimeEtMajoration {
  - id: UUID
  - employee_id: UUID (FK)
  - contract_id: UUID (FK)
  - period_month: String (YYYY-MM)
  - prime_type: TypePrime
  - amount: Decimal
  - percentage: Decimal (optionnel)
  - base_amount: Decimal
  - is_taxable: Boolean
  - effective_from: Date
  - effective_to: Date (optionnel)
  - approved_by: UUID (FK) -> Utilisateur
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  - deleted_at: DateTime (soft-delete)
  --
  + calculateAmount(): Decimal
  + isActiveForMonth(month: String): Boolean
}

enum TypePrime {
  NIGHT_BONUS
  HOLIDAY_BONUS
  SENIORITY_BONUS
  MEAL_VOUCHERS
  TRANSPORT_ALLOWANCE
  CUSTOM
}

' ==================== ANALYTICS & REPORTS ====================

class AnalytiquesClient {
  - id: UUID
  - client_id: UUID (FK)
  - period: String (YYYY-MM)
  - total_cost: Decimal
  - employee_charges: Decimal
  - employer_charges: Decimal
  - forecast_next_month: Decimal
  - cached_at: DateTime
  - cache_expires_at: DateTime
  --
  + calculateKPIs()
  + generateBreakdown()
  + exportReport()
  + cacheResults()
}

class VentilationAnalytiques {
  - id: UUID
  - analytics_id: UUID (FK)
  - employee_id: UUID (FK)
  - gross_salary: Decimal
  - onss_deduction: Decimal
  - precompte_deduction: Decimal
  - net_salary: Decimal
  --
  + computeBreakdown()
}

class RapportAnalytiques {
  - id: UUID
  - client_id: UUID (FK)
  - format: FormatRapport
  - period: String
  - file_url: String
  - generated_at: DateTime
  - access_token: String
  - access_token_expires_at: DateTime
  --
  + generateReport()
  + downloadReport()
  + exportPDF()
}

enum FormatRapport {
  PDF
  EXCEL
  CSV
}

enum PaySlipStatus {
  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

enum DIMONAStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  CANCELLED
}

' ==================== MESSAGING ====================

class Conversation {
  - id: UUID
  - client_id: UUID (FK)
  - consultant_id: UUID (FK)
  - subject: String
  - is_archived: Boolean
  - deleted_at: DateTime (soft-delete)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + sendMessage()
  + getMessages()
  + archive()
}

class Message {
  - id: UUID
  - conversation_id: UUID (FK)
  - sender_id: UUID (FK)
  - sender_role: RoleUtilisateur
  - content: String
  - attachments: MessageAttachment (array) (JSON)
  - is_read: Boolean
  - deleted_at: DateTime (soft-delete)
  - created_at: DateTime
  --
  + sendMessage()
  + downloadAttachment()
}

class PièceJointe {
  - id: UUID
  - message_id: UUID (FK)
  - file_name: String
  - file_url: String [ENCRYPTED_AES256]
  - file_size: Integer
  - mime_type: String
  - virus_scanned: Boolean
  - access_token: String
  - access_token_expires_at: DateTime
  --
  + downloadFile()
  + scanForVirus()
  + generateDownloadLink()
}

' === DONNÉES SENSIBLES (RGPD Article 9) ===
' Chiffrement AES256 obligatoire sur:
' - Fichiers (urls de documents sensibles)

' ==================== AUDIT & LOGS ====================

class JournalAudit {
  - id: UUID
  - user_id: UUID (FK)
  - action: String
  - entity_type: String
  - entity_id: UUID
  - changes: JSON
  - ip_address: String
  - user_agent: String
  - reason: String (optionnel)
  - requires_approval: Boolean
  - approved_by: UUID (FK) -> Utilisateur
  - approved_at: DateTime
  - created_at: DateTime
  - deleted_at: DateTime (soft-delete)
  - anonymized_at: DateTime
  - anonymized_by: UUID
  --
  + logAction()
  + queryHistory()
  + anonymize()
}

class JournalNotifications {
  - id: UUID
  - user_id: UUID (FK)
  - notification_type: String
  - subject: String
  - body: String
  - channels: String (array) [EMAIL, SMS, IN_APP]
  - status: StatutJournal
  - sent_at: DateTime
  - deleted_at: DateTime (soft-delete)
  - delivery_log: String (array) (JSON)
  --
  + logSend()
  + trackDelivery()
}

enum StatutJournal {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

' ==================== GDPR COMPLIANCE ====================

class ConsentementGDPR {
  - id: UUID
  - user_id: UUID (FK)
  - consent_type: TypeConsent
  - data_category: String
  - consent_given: Boolean
  - consent_date: DateTime
  - consent_method: MethodConsent
  - consent_version: String
  - ip_address: String
  - user_agent: String
  - expiry_date: DateTime (optionnel)
  - revoked_at: DateTime (optionnel)
  - revoked_reason: String (optionnel)
  - notes: String (optionnel)
  - created_at: DateTime
  - updated_at: DateTime
  --
  + giveConsent(): void
  + revokeConsent(reason: String): void
  + isActiveNow(): Boolean
  + getAuditTrail(): List
}

enum TypeConsent {
  PAIE_DATA
  MEDICAL_DATA
  PHOTO
  EMAIL_MARKETING
  COOKIES
  OTHER
}

enum MethodConsent {
  FORM_SIGNATURE
  EMAIL_CONFIRMATION
  VERBAL_WITH_WITNESS
  IMPLICIT
}

class ExportDonnées {
  - id: UUID
  - user_id: UUID (FK)
  - scope: PortéeExport
  - format: FormatExport
  - status: StatutExport
  - file_url: String
  - encryption_key: String (OBLIGATOIRE)
  - encryption_algorithm: String (ex: AES256-GCM)
  - exported_to_email: String (destinataire validé)
  - export_purpose: PurposeExport
  - authorized_by: UUID (FK) -> Utilisateur
  - authorization_date: DateTime
  - expires_at: DateTime
  - created_at: DateTime
  - updated_at: DateTime
  --
  + generateExport()
  + generateDownloadToken()
  + deleteExpiredFile()
  + revokeAccess()
}

enum PurposeExport {
  DATA_PORTABILITY
  VERIFICATION
  BACKUP
  LEGAL_REQUEST
  OTHER
}

enum PortéeExport {
  PERSONAL_DATA
  EMPLOYMENT_DATA
  PAYROLL_DATA
  FULL_DATA
}

enum FormatExport {
  JSON
  CSV
  XML
  PDF
}

enum StatutExport {
  REQUESTED
  GENERATING
  READY
  DOWNLOADED
  EXPIRED
  REVOKED
}

' ==================== RELATIONS ====================

Utilisateur "1" *-- "*" ConsentementGDPR : donne
Utilisateur "1" --> "*" ExportDonnées : demande
Utilisateur "1" --> "*" JournalAudit : approuve
Utilisateur "1" *-- "*" Session : a
Utilisateur "1" *-- "1" AuthDoubleFacteur : configure
Utilisateur "1" *-- "1" ParamNotifications : définit
Utilisateur "1" --> "*" HeuresSupplémentaires : approuve
Utilisateur "1" --> "*" PrimeEtMajoration : approuve
Secrétariat "1" *-- "*" Client : gère
Client "1" *-- "*" Employé : emploie
Client "1" *-- "1" AffiliationSecuriteSociale : possède
Employé "1" *-- "1" AllocationFamiliale : reçoit
Employé "1" *-- "*" HeuresSupplémentaires : effectue
Employé "1" *-- "*" PrimeEtMajoration : reçoit
Client "1" *-- "*" FichePaye : reçoit
Client "1" *-- "*" CertificatC4 : reçoit
Client "*" --> "1" Consultant : assigné_à
Client "1" *-- "*" AnalytiquesClient : suit
Client "1" *-- "*" Conversation : a
Employé "1" *-- "*" Contrat : signe
Employé "1" *-- "*" FichePaye : reçoit
Employé "1" *-- "*" CertificatC4 : génère
Contrat "1" *-- "*" PrimeEtMajoration : détermine
FichePaye "1" *-- "*" HeuresSupplémentaires : contient
FichePaye "*" --> "*" PrimeEtMajoration : inclut
AnalytiquesClient "1" *-- "*" VentilationAnalytiques : contient
Client "1" *-- "*" RapportAnalytiques : génère
Conversation "1" *-- "*" Message : contient
Message "1" *-- "*" PièceJointe : inclut
Message "*" --> "1" Utilisateur : envoyé par
Utilisateur "1" *-- "*" JournalAudit : génère
Utilisateur "1" *-- "*" JournalNotifications : reçoit

@enduml

