}

enum TypeContrat {
  CDI
  CDD
  STAGE
  INTERIM
}

enum StatutContrat {
  ACTIF
  TERMINE
  SUSPENDU
  RESILIE
}

' ==================== INDEXATION SALARIALE ====================

class IndexationSalaire {
  - id: UUID
  - id_employe: UUID (FK)
