' ==================== GESTION CONGÉS ====================

class DemandeConge {
  ' Validation métier:
  ' Seul Consultant assigné au Client (via Client.id_consultant) peut approuver
  - id: UUID
  - id_employe: UUID (FK)
  - type_conge: TypeConge
  - date_debut: Date
  - date_fin: Date
  - nombre_jours: Entier
  - raison: Texte (optional) [CHIFFRE_AES256]
  - url_certificat_medical: Texte [CHIFFRE_AES256]
  - statut: StatutDemande
  - statut_approbation: enum (EN_ATTENTE, APPROUVE, REJETE)
  - raison_rejet: Texte (optional)
  - commentaire_approbation: Texte (optional)
  - date_approbation: DateTime (optional)
  - id_consultant: UUID (FK, approbateur)
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  --
  + creerDemande()
  + afficherDemande()
  + annulerDemande()
  + afficherHistorique()
}

' === DONNÉES SENSIBLES (RGPD Article 9) ===
' Chiffrement AES256 obligatoire sur:
' - Données médicales (congés maladie, maternité, raisons médicales)
' - Fichiers (urls de documents sensibles)

enum TypeConge {
  ANNUEL
  MALADIE
  MATERNITE
  PATERNITE
  SABBATIQUE
}

enum StatutDemande {
  EN_ATTENTE
  ACCEPTE
  REJETE
  ANNULE
}

enum StatutFichePaie {
  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

enum StatutDIMONA {
  EN_ATTENTE
  SOUMISE
  ACCEPTEE
  REJETEE
  ANNULEE
}

class SoldeConge {
  ' COMPOSITE KEY: (id_employe, type_conge, annee)
  ' Exemple: emp-123 + ANNUEL + 2025 = 20 jours disponibles
  - id: UUID
  - id_employe: UUID (FK, PK1)
  - type_conge: TypeConge (PK2)
  - annee: Entier (PK3)
  - jours_disponibles: Entier
  - total_jours: Entier
  - jours_utilises: Entier
  - jours_reporte_annee_precedente: Entier
  - max_jours_reportes: Entier
  - jours_planifies: Entier
  - minimum_legal_pris: Entier
  - mis_a_jour_a: DateTime
  --
  + afficherSolde()
  + calculerRestant()
}

