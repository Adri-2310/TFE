@startuml Employe_Classes
!theme plain
title Classes Employé - WorkZen v1.0

' ==================== SECRÉTARIAT ====================

class Secrétariat {
  - id: UUID
  - nom: Texte
  - numero_tva: Texte
  - email: Email
  - telephone: Texte
  - adresse: Texte
  - pays: Texte
  - url_logo: Texte
  - plan_abonnement: PlanAbonnement
  - est_actif: Booléen
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + mettreAJourProfil()
}

enum PlanAbonnement {
  STARTER
  PROFESSIONNEL
  ENTREPRISE
}

' ==================== UTILISATEUR & SÉCURITÉ ====================

class Utilisateur {
