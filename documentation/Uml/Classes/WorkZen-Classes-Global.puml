skinparam backgroundColor #FEFEFE
skinparam classBorderColor #333
skinparam classBackgroundColor #F4F8FF

' ==================== ENTITÉS CORE ====================

class Utilisateur {
  - id: UUID
  - email: Email
  - hachage_mot_de_passe: Texte
