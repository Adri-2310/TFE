  BROUILLON
  VALIDEE
  ENVOYEE
  ARCHIVEE
}

enum StatutDIMONA {
  EN_ATTENTE
  SOUMISE
  ACCEPTEE
  REJETEE
  ANNULEE
}

enum FormatRapport {
  PDF
  EXCEL
  CSV
}

class SoldeConge {
  ' COMPOSITE KEY: (id_employe, type_conge, annee)
  ' Exemple: emp-123 + ANNUEL + 2025 = 20 jours disponibles
  - id: UUID
  - id_employe: UUID (FK, PK1)
  - type_conge: TypeConge (PK2)
  - annee: Entier (PK3)
  - jours_disponibles: Entier
  - total_jours: Entier
  - jours_utilises: Entier
  - jours_reporte_annee_precedente: Entier
  - max_jours_reportes: Entier
  - jours_planifies: Entier
  - minimum_legal_pris: Entier
  - mis_a_jour_a: DateTime
  --
  + mettreAJourSolde()
  + deduireJours()
  + restituerJours()
}

