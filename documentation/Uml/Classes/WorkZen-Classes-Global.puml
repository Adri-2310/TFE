  - est_actif: Booléen
  - derniere_connexion: DateTime
  - cree_a: DateTime
  - mis_a_jour_a: DateTime
  - supprime_a: DateTime (soft-delete)
  --
  + mettreAJourProfil()
  + changerMotDePasse()
  + activer2FA()
}

enum RoleUtilisateur {
  SUPER_ADMIN
  ADMIN_SECRETARIAT
  CONSULTANT
  CLIENT
  EMPLOYE
}

class Session {
  - id: UUID
  - id_utilisateur: UUID (FK)
