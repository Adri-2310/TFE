  - id_utilisateur: UUID (FK)
  - format: FormatExport
  - url_fichier: Texte
  - statut: StatutImport
  - erreurs: ErreurImport (tableau, JSON)
  - cree_a: DateTime
  - nombre_crees: Entier
  - nombre_mis_a_jour: Entier
  - nombre_erreurs: Entier
  --
  + validerFichier()
  + analyseDonnees()
  + traiterImport()
  + genererRapportErreurs()
}

enum StatutImport {
  VALIDATION
  TRAITEMENT
  COMPLETEE
  PARTIELLEMENT_COMPLETEE
  ECHOUEE
}

class ErreurImport {
  - numero_ligne: Entier
  - colonne: Texte
  - message_erreur: Texte
  - valeur: Texte
}

' ==================== AUDIT & JOURNAUX ====================

class JournalAudit {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - action: Texte
  - type_entite: Texte
  - id_entite: UUID
  - modifications: JSON
  - adresse_ip: Texte
  - agent_utilisateur: Texte
  - raison: Texte (optionnel)
  - necessite_approbation: Booléen
  - approuve_par: UUID (FK) -> Utilisateur
  - approuve_a: DateTime
  - cree_a: DateTime
  - supprime_a: DateTime (soft-delete)
  - anonymise_a: DateTime
  - anonymise_par: UUID
  --
  + enregistrerAction()
  + interrogerHistorique()
  + anonymiser()
}

class JournalNotifications {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - type_notification: Texte
  - sujet: Texte
  - corps: Texte
  - canaux: Texte (tableau) [EMAIL, SMS, APP]
  - statut: StatutJournal
  - envoye_a: DateTime
  - supprime_a: DateTime (soft-delete)
  - journal_livraison: Texte (tableau) (JSON)
  --
  + enregistrerEnvoi()
  + suivreLivraison()
}

enum StatutJournal {
  EN_ATTENTE
  ENVOYE
  LIVREE
  ECHOUEE
  RENVOYEE
}

class DemandeSuppressionData {
  - id: UUID
  - id_utilisateur: UUID (FK)
  - demandee_a: DateTime
  - suppression_programmee_a: DateTime
  - raison: Texte (optional)
  - statut: StatutSuppressionData
  --
  + programmezSuppression()
  + annulerSuppression()
  + executerSuppression()
}

enum StatutSuppressionData {
  EN_ATTENTE
  CONFIRMEE
  EXECUTEE
  ANNULEE
}

