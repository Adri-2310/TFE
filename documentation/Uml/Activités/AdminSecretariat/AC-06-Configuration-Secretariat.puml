@startuml AC-06-Configuration-Secretariat

title AC-06: Configuration Secrétariat (AdminSecretariat)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:AdminSecretariat accède Configuration Secrétariat;

if (AdminSecretariat choisit ?) then (Infos sociales)
  :Afficher nom entreprise (lecture seule);
  :Afficher TVA (lecture seule);
  :Afficher adresse;
  :Afficher téléphone;
  :Afficher email principal;

  if (AdminSecretariat modifie ?) then (oui)
    :Éditer adresse, téléphone, email;
    :Valider format email;
    :Valider format téléphone;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: COMPANY_INFO_UPDATED);
  endif

elseif (Paramètres paie) then
  :Afficher devise (EUR);
  :Afficher année fiscale début;
  :Afficher fréquence paie;

  if (AdminSecretariat modifie ?) then (oui)
    :Modifier fréquence paie;
    :Sélectionner: Mensuelle/Bi-mensuelle;
    :Confirmer changement;
    :Enregistrer l'action (Audit Log: PAYROLL_CONFIG_CHANGED);
  endif

elseif (Paramètres RGPD) then
  :Afficher durée rétention données;
  :Afficher statut chiffrement AES-256;

  if (AdminSecretariat configure ?) then (oui)
    :Définir durée rétention (mois);
    :Activer/désactiver chiffrement;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: RGPD_CONFIG_UPDATED);
  endif

elseif (Gérer utilisateurs) then
  :Afficher liste consultants;
  :Afficher statut, permissions, clients assignés;

  if (AdminSecretariat action ?) then (Ajouter)
    :Saisir email;
    :Saisir nom/prénom;
    :Sélectionner spécialisation;
    :Envoyer invitation;
    :Enregistrer l'action (Audit Log: CONSULTANT_ADDED);

  elseif (Modifier) then
    :Sélectionner consultant;
    :Modifier permissions;
    :Modifier clients assignés;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: CONSULTANT_UPDATED);

  else (Désactiver)
    :Confirmation action;
    :Invalider sessions;
    :Mettre statut inactif;
    :Enregistrer l'action (Audit Log: CONSULTANT_DEACTIVATED);
  endif

else (Configurer intégrations)
  if (Intégration ?) then (Stripe)
    :Afficher statut connexion;
    :Afficher nombre transactions;

    if (Test connexion ?) then (oui)
      :Tester API Stripe;
      :Afficher résultat;
    endif

  elseif (Exact Online) then
    :Afficher statut synchronisation;
    :Afficher dernière sync;

    if (Resynchroniser ?) then (oui)
      :Lancer sync manuelle;
      :Attendre résultat;
      :Enregistrer l'action (Audit Log: EXACT_SYNC_TRIGGERED);
    endif

  else (Email)
    :Afficher serveur SMTP;
    :Afficher email FROM;

    if (Tester ?) then (oui)
      :Envoyer email test;
      :Vérifier réception;
      :Enregistrer l'action (Audit Log: EMAIL_CONFIG_TESTED);
    endif
  endif
endif

:Afficher logs modifications;
:Enregistrer l'action (Audit Log: CONFIG_SECRETARIAT_ACCESSED);
:Afficher confirmation;

stop

@enduml
