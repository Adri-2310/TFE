@startuml AC-20-Gerer-Abonnement

title AC-20: Gérer Abonnement (AdminSecretariat)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:AdminSecretariat accède gestion abonnement;
:Consulter détails abonnement actuel;

:Afficher plan actuel;
:Afficher features incluses;
:Afficher date renouvellement;
:Afficher montant mensuel/annuel;

split
  :Consulter historique factures;
  :Afficher liste factures;
  :Filtrer par période;
  :Consulter détails facture;

  split
    :Télécharger PDF facture;
    :Générer facture PDF;
    :Proposer téléchargement;
  split
    :Partager facture par email;
    :Entrer adresse email;
    :Envoyer PDF email;
    :Confirmer envoi;
  end split

split
  :Changer plan d'abonnement;
  :Consulter plans disponibles;
  :Afficher différences plans;
  :Afficher prix (proratisé);

  if (Plan supérieur ?) then (oui)
    :Calculer crédit actuel;
    :Calculer coût upgrade;
    :Afficher montant différence;
  else (non)
    :Plan inférieur;
    :Afficher message avertissement;
    :Afficher date effet baisse;
  endif

  :Confirmation changement;
  if (Confirme ?) then (non)
    :Annuler changement;
  else (oui)
    :Soumettre changement à Stripe;
    :Attendre confirmation Stripe;

    if (Changement réussi ?) then (oui)
      :Mettre à jour plan local;
      :Enregistrer l'action (Audit Log: SUBSCRIPTION_PLAN_CHANGED);
      :Envoyer email confirmation;
      :Afficher nouveau plan;
    else (non)
      :Afficher erreur;
      :Proposer retry ou contact support;
    endif
  endif

split
  :Accéder Stripe Customer Portal;
  :Générer link session customer portal;
  :Récupérer token authentification;
  :Rediriger vers Stripe portal;

  :Utilisateur dans Stripe portal;
  :Peut gérer méthode paiement;
  :Peut consulter facturation;
  :Peut gérer données factures;

  :Retour application après Stripe;
  :Recharger page abonnement;

split
  :Mettre à jour méthode paiement;
  :Cliquer "Gérer paiement";
  :Rediriger Stripe payment method page;

  :Entrer infos nouvelle carte;
  :Confirmer changement;

  if (Paiement validé ?) then (oui)
    :Carte mise à jour Stripe;
    :Confirmation dans app;
    :Logger changement (audit);
  else (non)
    :Afficher erreur paiement;
    :Proposer retry;
  endif

end split

:Afficher résumé abonnement;
:AdminSecretariat peut continuer ou quitter;

stop

@enduml
