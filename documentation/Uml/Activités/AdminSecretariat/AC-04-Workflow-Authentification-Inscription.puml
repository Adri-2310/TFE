@startuml AC-04-Workflow-Authentification-Inscription
!theme plain
title Diagramme d'Activité - Workflow Authentification & Inscription

start
:Utilisateur accède /auth/register;
:Afficher formulaire inscription;

partition "Sélection Méthode Authentification" {
  if ("Méthode?") then (Email + Password)
    :Saisir: Nom, Email, Password;
    :Valider email format;
    :Valider password strength;
  else (Google OAuth)
    :Rediriger vers Google OAuth;
    :Google affiche consent screen;
    :Utilisateur autorise WorkZen;
    :Google retourne authorization_code;
    :Échanger code contre access_token;
  endif
}

:Continuer vers étape secrétariat;

partition "Infos Secrétariat" {
  :Saisir: Nom, TVA, Adresse;
  :Saisir: Secteur, Téléphone;

  :Vérifier unicité TVA;
  if ("TVA unique?") then (Oui)
    :Continuer;
  else (Non)
    :Afficher erreur: TVA existe;
    :Proposer correction;
    stop
  endif
}

partition "Sélection Plan" {
  :Afficher plans disponibles;
  note right
  Starter: 99€/mois
  Pro: 299€/mois
  Enterprise: Devis
  end note
  :Utilisateur sélectionne plan;
}

:Valider toutes données;

partition "Stripe Paiement" {
  :Créer session Stripe Checkout;
  note right
  Métadonnées: User data,
  Secretariat data, Plan
  end note
  :Stocker TempRegistration (24h TTL);
  :Démarrer job cleanup (BullMQ);
  :Rediriger vers Stripe Checkout URL;
}

:Utilisateur saisit infos carte;
:Stripe traite paiement;

if ("Paiement accepté?") then (Oui - Paiement OK)
  :Stripe crée Customer;
  :Stripe crée Subscription;
else (Non - Carte refusée)
  :Stripe affiche erreur;
  :Utilisateur propose autre carte;
  :Enregistrer l'action (Audit Log: PAYMENT_FAILED);
:Retour paiement Stripe;
endif

:Stripe envoie webhook: checkout.session.completed;

partition "Traitement Webhook (Backend)" {
  :Vérifier signature Stripe;

  :Récupérer TempRegistration;
  if ("TempReg expirée?") then (Non)
    :Continuer;
  else (Oui - >24h)
  :Retourner 400 Bad Request;
    :Enregistrer l'action (Audit Log: REGISTRATION_FAILED_TEMPREG_EXPIRED);
    :Utilisateur redemande inscription;
    stop
  endif

  :Créer transaction ACID;

  :Créer Secrétariat;
  note right
  stripe_customer_id
  stripe_subscription_id
  Plan, Status = ACTIVE
  end note

  :Créer AdminSecretariat User;
  note right
  Rôle: ADMIN_SECRETARIAT
  is_main_admin: true
  Lié au secrétariat
  end note

  if (Méthode = Google) then
    :Créer Account Provider 'google';
    :Stocker: google_id, access_token;
  else (Méthode = Email)
    :Créer Account Provider 'credential';
    :Hash password (bcrypt 12 rounds);
  endif

:Enregistrer l'action (Audit Log: REGISTRATION_SUCCESS);
  :Supprimer TempRegistration;
}

fork
  partition "Email" {
    :Envoyer email bienvenue;
    :Inclure: Lien connexion;
  }
fork again
  partition "Analyse & Suivi" {
    :Enregistrer: Plan choisi;
    :Enregistrer: Secteur;
    :Enregistrer: Timestamp;
  }
end fork

:Stripe redirige vers /auth/success;
:Afficher page confirmation;
:Afficher: "Compte créé avec succès!";

:Utilisateur clique "Se connecter";
:Rediriger vers /auth/login;
stop

@enduml
