@startuml AC-13-Dashboard-Global

title AC-13: Dashboard Global (SuperAdmin)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:SuperAdmin accède dashboard global;

partition "Collecte Données" {
  :Récupérer statistiques système;
  :Compter secrétariats actifs;
  :Compter utilisateurs totaux;
  :Compter clients totaux;
  :Compter employés totaux;
  :Calculer volume stockage;
}

partition "Affichage Widgets" {
  :Afficher widget Vue Générale;
  :Afficher secrétariats actifs;
  :Afficher utilisateurs connectés;
  :Afficher clients actifs;
  :Afficher employés actifs;
  :Afficher stockage utilisé/total;

  :Afficher widget Santé Système;
  :Afficher uptime serveurs;
  :Afficher utilisation CPU/RAM;
  :Afficher latence API;
  :Afficher taux erreurs;
  :Afficher alertes système;

  :Afficher widget Activité;
  :Afficher créations secrétariats (7 derniers jours);
  :Afficher utilisateurs créés;
  :Afficher paies générées;
  :Afficher documents créés;
  :Afficher tendance sur graphique;

  :Afficher widget Conformité;
  :Afficher secrétariats en conformité RGPD;
  :Afficher audits complétés;
  :Afficher alertes légales;
  :Afficher mises à jour en attente;

  :Afficher widget Facturation;
  :Afficher revenu MRR;
  :Afficher secrétariats par plan;
  :Afficher impayés;
  :Afficher churn rate;
}

if (SuperAdmin filtre ?) then (oui)
  :Sélectionner période (7j/30j/90j/1an);
  :Appliquer filtre;
else (non)
  :Afficher défaut 30 jours;
endif

if (SuperAdmin exporte ?) then (oui)
  :Sélectionner format CSV/PDF;
  :Générer rapport;
  :Télécharger;
else (non)
  :Continuer;
endif

:Enregistrer l'action (Audit Log: DASHBOARD_ACCESSED);
:Afficher dashboard complet;

stop

@enduml
