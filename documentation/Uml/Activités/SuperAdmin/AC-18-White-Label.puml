@startuml AC-18-White-Label

title AC-18: Configurer White-Label et Branding (SuperAdmin)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:SuperAdmin accède White-Label;

if (SuperAdmin choisit ?) then (Branding général)
  partition "Configuration Branding" {
    :Uploader logo entreprise;
    :Définir couleur primaire;
    :Définir couleur secondaire;
    :Définir couleur accentuation;
    :Sélectionner font primaire;
    :Sélectionner font secondaire;
    :Définir taille texte par défaut;
    :Configurer email FROM;
    :Configurer signature email;
    :Uploader bannière email;
    :Valider cohérence couleurs;
    :Sauvegarder branding;
    :Enregistrer l'action (Audit Log: BRANDING_GLOBAL_UPDATED);
  }

elseif (Secrétariat personnalisé) then
  :Sélectionner secrétariat;

  partition "Personalisation Secrétariat" {
    :Uploader logo spécifique;
    :Permet override branding général;
    :Définir couleur primaire propre;
    :Définir couleur secondaire propre;
    :Configurer FROM email;
    :Configurer signature;
    :Sauvegarder config secrétariat;
    :Envoyer email confirmation;
    :Enregistrer l'action (Audit Log: BRANDING_SECRETARIAT_UPDATED);
  }

elseif (Domaines personnalisés) then
  :Lister domaines configurés;
  :Afficher domaine, statut DNS, certificat SSL;

  if (SuperAdmin ajoute domaine ?) then (oui)
    :Entrer domaine (ex: secrétariat.company.com);
    :Afficher instructions DNS;
    :Vérifier CNAME/A record;
    :Générer certificat SSL (Let's Encrypt);
    :Ajouter domaine;
    :Enregistrer l'action (Audit Log: DOMAIN_ADDED);
  else (non)
    :Continuer consultation;
  endif

else (Aperçu)
  :Afficher prévisualisation login page;
  :Afficher prévisualisation dashboard;
  :Afficher prévisualisation email;
  :Comparer original vs personnalisé;

  if (SuperAdmin teste ?) then (oui)
    :Envoyer email test;
    :Vérifier rendu email;
    :Enregistrer l'action (Audit Log: WHITE_LABEL_TESTED);
  endif
endif

:Afficher confirmation changements;

stop

@enduml
