@startuml AC-11-Workflow-Gerer-Secretariats

!theme plain
title Diagramme d'Activité - Gérer Secrétariats (SuperAdmin)

start

:SuperAdmin accède Gestion Secrétariats;

partition "Consultation Liste" {
  :Afficher tous les secrétariats;
  :Avec: Nom, TVA, Plan, Status, Clients, Utilisateurs, Stockage;
  :Filtrer/Trier;
  :Chercher par TVA ou nom;
}

:Sélectionner action;

if ("Action?") then (Consulter)
  partition "Consultation Détails Secrétariat" {
    :Afficher: Nom, TVA, Adresse;
    :Afficher: Plan actuel, Date activation;
    :Afficher: Nombre clients, utilisateurs;
    :Afficher: Stockage utilisé;
    :Afficher: Status (ACTIVE/SUSPENDED);

    :Récupérer statistiques;
    :Clients actifs (count);
    :Employés totaux (count);
    :Documents (count);
    :Audit logs (count);
  }

elseif (Modifier) then
  partition "Modification Secrétariat" {
    :SuperAdmin édite: Adresse, Contact;
    :SuperAdmin peut changer: Plan (UI Stripe);

    :Valider données;
    if ("Données valides?") then (Oui)
      :Continuer;
    else (Non)
      :Afficher erreur;
      :Enregistrer l'action (Audit Log: SECRETARIAT_MODIFICATION_FAILED);
      stop
    endif

    fork
      partition "Sauvegarde" {
        :Mettre à jour BD;
      }
    fork again
      partition "Notification" {
        :Envoyer email AdminSecretariat;
        :Informer des changements;
      }
    fork again
      partition "Audit" {
        :Enregistrer l'action (Audit Log: SECRETARIAT_UPDATED);
      }
    end fork
  }

elseif (Suspendre) then
  partition "Suspension Secrétariat" {
    :Afficher confirmation;
    :Modal: "Raison de suspension?";
    :SuperAdmin saisit raison;

    fork
      partition "Suspension" {
        :Status = SUSPENDED;
        :Tous utilisateurs déconnectés;
        :Données conservées;
      }
    fork again
      partition "Notification" {
        :Email AdminSecretariat;
        :Informer suspension;
        :Inclure: Raison, Date;
      }
    fork again
      partition "Facturation" {
        :Arrêter facturation immédiate;
        :Créer prorata credit;
      }
    end fork

    :Enregistrer l'action (Audit Log: SECRETARIAT_SUSPENDED);
  }

else (Supprimer)
  partition "Suppression Secrétariat" {
    :Confirmation suppression;
    :Soft delete (conservation données);
    :Status = DELETED;
    :Tous utilisateurs déconnectés;
    :Envoyer email notification;
    :Enregistrer l'action (Audit Log: SECRETARIAT_DELETED);
  }
endif

:Afficher résultat;

stop

@enduml
