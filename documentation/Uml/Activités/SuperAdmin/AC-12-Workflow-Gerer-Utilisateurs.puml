@startuml AC-12-Gerer-Utilisateurs

title AC-12: Gérer Utilisateurs (SuperAdmin)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:SuperAdmin accède panel de gestion;
:Consulter liste utilisateurs;

if (SuperAdmin choisit ?) then (Créer utilisateur)
  :Entrer email, prénom, nom;
  :Sélectionner rôle (AdminSecretariat, Consultant, Client, Employe);
  :Sélectionner secrétariat(s) d'accès;
  :Définir permissions par UC;

  :Validation email unique;
  if (Email existe ?) then (oui)
    :Afficher erreur;
    :Enregistrer l'action (Audit Log: USER_CREATION_FAILED_DUPLICATE_EMAIL);
    stop
  else (non)
    :Email valide;
  endif

  :Générer token invitation;
  :Envoyer email d'invitation;
  :Attendre confirmation email;

  :Créer compte utilisateur;
  :Initialiser permissions;
  :Sauvegarder base données;
  :Enregistrer l'action (Audit Log: USER_CREATED);
  :Afficher confirmation création;

elseif (Modifier utilisateur) then
  :Consulter détails compte;

  if (Employé modifie ?) then (Infos personnelles)
    :Mettre à jour email;
    :Changer mot de passe;
    :Enregistrer l'action (Audit Log: USER_PERSONAL_INFO_UPDATED);

  elseif (Permissions) then
    :Ajouter/retirer UC autorisées;
    :Modifier rôle;
    :Ajouter/retirer secrétariats;
    :Enregistrer l'action (Audit Log: USER_PERMISSIONS_UPDATED);

  else (Tous)
    :Modifier infos personnelles;
    :Modifier permissions;
  endif

  :Sauvegarder modifications;
  :Afficher confirmation;

elseif (Gérer accès) then
  if (SuperAdmin action ?) then (Désactiver)
    :Confirmation action;
    :Invalider sessions actives;
    :Mettre statut "inactif";
    :Conserver données (RGPD);
    :Enregistrer l'action (Audit Log: USER_DEACTIVATED);

  elseif (Réactiver) then
    :Confirmation action;
    :Mettre statut "actif";
    :Envoyer email réactivation;
    :Enregistrer l'action (Audit Log: USER_REACTIVATED);

  else (Réinitialiser mot de passe)
    :Générer token temporaire;
    :Envoyer email réinitialisation;
    :Attendre confirmation utilisateur;
    :Enregistrer l'action (Audit Log: PASSWORD_RESET_INITIATED);
  endif

  :Sauvegarder base données;
  :Afficher confirmation;

else (Consulter)
  :Afficher détails utilisateur;
  :Afficher permissions;
  :Afficher secrétariats d'accès;
endif

:Afficher liste utilisateurs mise à jour;

stop

@enduml
