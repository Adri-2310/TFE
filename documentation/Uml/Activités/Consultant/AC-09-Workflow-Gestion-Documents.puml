@startuml AC-09-Workflow-Gestion-Documents
!theme plain
title Diagramme d'Activité - Workflow Gestion Documents & Templates

start
:Consultant ou AdminSecretariat accède Templates;

partition "Consultation Bibliothèque" {
  :Afficher liste templates;
  note right
  Catégories: Contrats, Lettres,
  Documents, Déclarations
  end note

  :Filtrer par: Catégorie, Tags;
  :Trier par: Nom, Date création;
}

:Sélectionner action;

if ("Action?") then (Consulter)
  :Cliquer sur template;
elseif (Créer) then
  :Cliquer "Nouveau template";
elseif (Modifier) then
  :Cliquer "Modifier";
elseif (Dupliquer) then
  :Cliquer "Dupliquer";
else (Archiver/Supprimer)
  :Cliquer "Supprimer";
endif

partition "Consultation Template" {
  :Afficher contenu complet;
  :Mettre en évidence: Variables {{...}};
  note right
  Exemple: {{employee_name}},
  {{company_name}}, {{salary}}
  end note

  :Afficher metadata;
  note right
  Catégorie, Tags, Version,
  Date création, Auteur
  end note
}

partition "Création Nouveau Template" {
  :Saisir: Nom, Catégorie;
  :Ouvrir rich text editor;
  :Rédiger contenu template;

  :Ajouter variables;
  note right
  Variables disponibles affichées
  à droite (helper panel)
  end note

  :Prévisualiser avec exemples;
  :Afficher: Comment variables seront remplacées;

  :Ajouter tags;

  :Valider template;
  if ("Contenu valide?") then (Oui)
    :Continuer;
  else (Non - Vide)
    :Afficher erreur;
    stop
  endif

  fork
    partition "Sauvegarde" {
      :Créer document Template;
      :Stocker contenu;
      :Enregistrer metadata;
      :Associer au secrétariat;
    }
  fork again
    partition "Audit" {
      :Log: TEMPLATE_CREATED;
      :Enregistrer: Nom, Auteur;
    }
  end fork
}

partition "Modification Template" {
  :Afficher contenu actuel;

  :Consultant édite contenu;
  :Affiche changements en temps réel;

  :Prévisualiser modifications;

  :Valider;

  fork
    partition "Mise à Jour" {
      :Mettre à jour document;
      :Incrémenter version;
      :Documenter changements;
    }
  fork again
    partition "Notification" {
      :Log: TEMPLATE_UPDATED;
      :Enregistrer diff;
    }
  end fork

  :Tous futurs documents utiliseront nouvelle version;
}

partition "Duplication Template" {
  :Créer copie exact;
  :Ajouter suffix " (copie)";

  :Nouvelle copie modifiable;
  :Indépendante de l'original;

  :Enregistrer comme nouveau template;
}

partition "Suppression Template" {
  if ("Avant supprimer") then (Vérifier utilisation)
    :Rechercher documents utilisant template;
    if ("Docs existent?") then (Oui)
      :Erreur: "Impossible, Docs utilisent ce template";
      :Option: Archiver au lieu supprimer;
      stop
    else (Non)
      :Continuer;
    endif
  endif

  if ("Type suppression?") then (Archiver)
    :Marquer archived = true;
    :Template invisible;
    :Récupérable via filtre;
  else (Supprimer définitif)
    :Hard delete;
    :Perte définitive;
  endif

  :Log audit: TEMPLATE_DELETED;
}

:Afficher résultat;
:Template disponible pour utilisation;

note right
Templates utilisés pour générer
documents automatiquement
avec fusion variables
end note

stop

@enduml
