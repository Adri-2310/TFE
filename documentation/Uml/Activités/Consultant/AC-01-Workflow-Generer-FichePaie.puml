@startuml AC-01-Workflow-Generer-FichePaie
!theme plain
title Diagramme d'Activité - Workflow Génération de Fiche de Paie

start
:Consultant accède Dashboard;
:Sélectionner mois/année;
:Récupérer liste employés;

fork
  :Employé avec données complètes;
fork again
  :Employé avec données manquantes;
  :Afficher avertissement;
end fork

:Afficher aperçu paies;
:Consultant valide;

partition "Moteur Calcul" {
  repeat
    :Sélectionner employé;
    :Récupérer contrat actif;
    :Récupérer salaire brut;
    :Calculer cotisations ONSS;
    :Calculer retenues (mutuelle, assurance);
    :Calculer allocations familiales;
    :Calculer IPP (impôt);
    :Calculer salaire net;
    repeat while (Autres employés?)
}

:Valider montants totaux;

if ("Montants plausibles?") then (Oui)
  :Continuer;
else (Non)
  :Afficher erreurs;
  :Retourner correction;
  :Recalculer;
endif

partition "Persistance Données" {
  :Créer FichePaie record;
  :Sauvegarder en BD;
  :Mettre à jour status = GENEREE;
}

:Générer template PDF;
:Appliquer logo/styles;
:Créer fichier PDF;

fork
  partition "Service Email" {
    repeat
      :Sélectionner employé;
      :Envoyer email avec PDF;
      :Log notification;
      repeat while (Autres employés?)
    }
fork again
  partition "Audit" {
    :Enregistrer l'action (Audit Log: PAYROLL_GENERATED);
    :Enregistrer timestamp;
    :Enregistrer utilisateur;
  }
end fork

:Afficher résultat;
:Fiches de paie disponibles;
stop

note right
  Processus asynchrone
  pour emails via BullMQ
end note

@enduml
