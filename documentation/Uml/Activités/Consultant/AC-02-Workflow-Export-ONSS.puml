@startuml AC-02-Workflow-Export-ONSS
!theme plain
title Diagramme d'Activité - Workflow Export Déclaration ONSS

start
:Consultant accède Conformité ONSS;
:Sélectionner mois à déclarer;

if ("Fiches générées?") then (Oui)
  :Continuer;
else (Non)
  :Afficher message erreur;
  stop
endif

:Afficher résumé paies;
:Afficher montants bruts/nets;

partition "Validation ONSS" {
  repeat
    :Vérifier données complètes;
    :Vérifier formats correctes;
    :Vérifier numéros nationaux;
    :Vérifier contrats actifs;
    repeat while (Tous vérifiés?)
}

if ("Données valides?") then (Oui)
  :Continuer;
else (Non)
  :Afficher liste erreurs;
  :Proposer corrections;
  stop
endif

:Afficher preview fichier ONSS;
:Consultant examine format;

:Cliquer "Générer fichier XML";

partition "XML Generation" {
  :Créer structure XML ONSS;
  :Ajouter header (numéro secrétariat);
  repeat
    :Ajouter employé;
    :Ajouter cotisations;
    :Ajouter identificateurs;
    repeat while (Autres employés?)
  :Ajouter footer (totaux);
  :Générer checksum;
  :Valider schéma XML;
}

if ("XML valide?") then (Oui)
  :Continuer;
else (Non)
  :Afficher erreurs XML;
  stop
endif

:Afficher preview lisible;
:Consultant valide;

fork
  partition "Soumission ONSS" {
    :Créer connexion sécurisée;
    :Envoyer fichier XML;
    :Attendre réponse ONSS;
  }
fork again
  partition "Traçabilité Audit" {
    :Log tentative soumission;
    :Enregistrer IP/utilisateur;
    :Enregistrer timestamp;
  }
end fork

if ("ONSS répond OK?") then (Accepté)
  :Status = SOUMIS;
  :Enregistrer confirmation ONSS;
elseif (Erreur réseau) then
  :Sauvegarder fichier;
  :Proposer soumission manuelle;
  :Status = ERREUR;
else (Rejeté ONSS)
  :Envoyer erreurs au Consultant;
  :Status = ERREUR;
  :Proposer corrections;
endif

:Envoyer email Consultant;
:Afficher résultat;
stop

note right
  Processus sécurisé avec
  logs complets pour audit
  Délai légal: avant le 10
end note

@enduml
