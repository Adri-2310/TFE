@startuml AC-12-Consulter-Documents

title AC-12: Consulter Documents (Client)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:Client accède Documents;
:Afficher documents partagés;
:Grouper par catégorie;

partition "Filtrage et recherche" {
  if (Client filtre ?) then (Par type)
    :Sélectionner type;
    :Contrats, Certificats, Rapports, Attestations;
  elseif (Par période) then
    :Sélectionner période;
    :Appliquer filtre dates;
  else (Recherche)
    :Saisir terme recherche;
    :Chercher titre/description;
  endif

  :Appliquer filtres;
}

if (Client choisit ?) then (Consulter)
  :Cliquer document;
  :Charger prévisualisation;

  :Afficher metadata;
  :Afficher date création;
  :Afficher auteur;
  :Afficher version;
  :Afficher description;

  if (Client voit contenu ?) then (oui)
    :Prévisualiser PDF/document;
  else (non)
    :Demander permission;
  endif

elseif (Télécharger) then
  :Générer document sécurisé;
  :Chiffrer AES-256;
  :Créer lien téléchargement;
  :Lien expire 7 jours;

  :Client télécharge;
  :Enregistrer l'action (Audit Log: DOCUMENT_DOWNLOADED);

elseif (Imprimer) then
  :Ouvrir dialogue impression;
  :Sélectionner imprimante;
  :Envoyer impression;
  :Enregistrer l'action (Audit Log: DOCUMENT_PRINTED);

elseif (Partager) then
  :Saisir email destinataire;
  :Générer lien partage;
  :Accès temporaire;
  :Expiration configurable;
  :Envoyer email partage;
  :Destinataire accède lien;
  :Enregistrer l'action (Audit Log: DOCUMENT_SHARED);

elseif (Ajouter favori) then
  :Cliquer étoile;
  :Marquer comme favori;
  :Enregistrer l'action (Audit Log: DOCUMENT_ADDED_TO_FAVORITES);

else (Ajouter annotation)
  :Cliquer "Ajouter note";
  :Saisir commentaire;
  :Marquer zone PDF;
  :Sauvegarder annotation;
  :Affichage annotation;
  :Enregistrer l'action (Audit Log: ANNOTATION_ADDED);
endif

:Afficher documents complets;

stop

@enduml
