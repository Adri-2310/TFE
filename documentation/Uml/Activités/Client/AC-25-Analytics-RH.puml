@startuml AC-25-Analytics-RH

title AC-25: Analytics RH (Client)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:Client accède Analytics RH;

if (Client consulte ?) then (Masse salariale)
  :Récupérer données 12 mois;
  :Aggréger par mois;
  :Afficher graphique évolution;
  :Tendance mensuelle;
  :Courbe de croissance;

  :Afficher analyse;
  :Masse salariale totale;
  :Évolution mois/mois;
  :Pourcentage augmentation;
  :Détail par département;
  :Répartition salaires;

elseif (Absences) then
  :Calculer taux absentéisme;
  :Nombre jours absence/total;
  :Pourcentage taux;

  :Classifier par type;
  :Congés payés;
  :Maladie;
  :Autres absences;

  :Afficher graphique;
  :Tendance mensuelle;
  :Répartition par type;
  :Analyse par employé;

elseif (Effectifs) then
  :Afficher courbe effectifs;
  :Historique 12 mois;
  :Événements: embauches/départs;

  :Calculer turnover;
  :Nombre départs/année;
  :Taux turnover %;

  :Afficher distribution;
  :Effectifs par fonction;
  :Effectifs par département;
  :Répartition ancienneté;

elseif (Paies) then
  :Distribution salaires;
  :Graphique courbe Gauss;
  :Salaire min/max/moyen;
  :Écart-type;

  :Charges sociales;
  :Par type charge;
  :Total patronal/salarial;
  :Évolution charges;

  :Retenues;
  :Détail types retenues;

else (Rapport)
  :Sélectionner éléments inclure;
  :Période couvrir;
  :Entreprises inclure;

  :Générer PDF rapport;
  :Inclure graphiques;
  :Inclure tableaux;

  :Pouvoir ajouter notes;
  :Ajouter commentaires;
  :Ajouter recommandations;

  :Envoyer par email;
  :Destinataires;
  :Message personnalisé;
  :Enregistrer l'action (Audit Log: REPORT_SENT);
endif

if (Client exporte ?) then (oui)
  if (Format ?) then (CSV)
    :Exporter CSV;
  elseif (Excel) then
    :Exporter Excel;
  else (JSON)
    :Exporter JSON;
  endif

  :Télécharger archive;
  :Enregistrer l'action (Audit Log: ANALYTICS_EXPORTED);
endif

if (Client compare ?) then (oui)
  :Sélectionner 2 périodes;
  :Comparer statistiques;
  :Afficher déltas;
  :Enregistrer l'action (Audit Log: ANALYTICS_COMPARED);
endif

:Afficher analytics complet;

stop

@enduml
