@startuml Dep-01-Deployment-Infrastructure
!theme plain
title Diagramme de Déploiement - Infrastructure SocialFlow

node "🖥️ Navigateur Client" as ClientBrowser {
  artifact "Application Web\n(HTML/CSS/JS)" as WebAppClient
}

node "☁️ VPS Hostinger" as VPS {

  node "🐳 Hôte Docker" as DockerHost {

    node "Conteneur: Web (Nginx)" as NginxContainer {
      artifact "Proxy Inverse Nginx\nPort 80/443" as NginxApp
    }

    node "Conteneur: App (Node.js)" as AppContainer {
      artifact "Serveur Next.js\nPort 3000" as NextJSApp
      artifact "Routes API" as APIRoutesApp
      artifact "Service Authentification" as AuthApp
    }

    node "Conteneur: Base de Données" as DatabaseContainer {
      artifact "PostgreSQL 16\nPort 5432" as PostgreSQLApp
      artifact "Volume Données: /var/lib/postgresql" as DataVolume
    }

    node "Conteneur: Cache" as CacheContainer {
      artifact "Redis 7\nPort 6379" as RedisApp
      artifact "Magasin Sessions" as SessionStore
    }

    node "Conteneur: File" as QueueContainer {
      artifact "Travailleurs BullMQ\nTâches: email, pdf" as WorkersApp
      artifact "Magasin Tâches (Redis)" as JobStore
    }

    node "Conteneur: Stockage" as StorageContainer {
      artifact "Stockage MinIO S3\nPort 9000" as MinIOApp
      artifact "Volume Stockage Fichiers" as FileStorage
    }
  }

  artifact "Panneau Contrôle Coolify" as CoolifyPanel
}

cloud "🌐 Services Externes" as ExternalServices {
  node "Stripe" as StripeService {
    artifact "Passerelle Paiement" as StripeAPI
  }

  node "Exact Online" as ExactOnlineService {
    artifact "API Comptabilité" as ExactAPI
  }

  node "ONSS Belgique" as ONSSService {
    artifact "API DIMONA/ONSS" as ONSSAPI
  }

  node "Resend" as ResendService {
    artifact "Service Email" as ResendAPI
  }

  node "Sentry" as SentryService {
    artifact "Suivi des Erreurs" as SentryAPI
  }
}

node "📦 Sauvegardes & Monitoring" as BackupNode {
  artifact "Sauvegardes Quotidiennes\n(Chiffrées)" as BackupStorage
  artifact "Tableau de Bord Monitoring" as MonitoringDash
}

ClientBrowser --> NginxApp : HTTPS\nPort 443

NginxApp --> NextJSApp : Équilibrage Charge\nPort 3000

NextJSApp --> AuthApp : Authentification
NextJSApp --> APIRoutesApp : Routage

APIRoutesApp --> PostgreSQLApp : Requêtes SQL
APIRoutesApp --> RedisApp : Cache Mémoire
APIRoutesApp --> WorkersApp : Mettre en File Tâches
APIRoutesApp --> MinIOApp : Stockage Fichiers

WorkersApp --> ResendAPI : Envoi Emails
APIRoutesApp --> StripeAPI : Paiement
APIRoutesApp --> ExactAPI : Synchronisation Comptabilité
APIRoutesApp --> ONSSAPI : Soumettre Déclarations

APIRoutesApp --> SentryAPI : Journaux Erreurs

PostgreSQLApp --> DataVolume : Persistant
RedisApp --> JobStore : Données file
MinIOApp --> FileStorage : Fichiers

DatabaseContainer --> BackupStorage : Sauvegarde nocturne
CoolifyPanel --> MonitoringDash : Surveillance

note right of NginxContainer
  Proxy Inverse
  Terminaison SSL/TLS
  Équilibrage Charge
  Compression Gzip
end note

note right of AppContainer
  Runtime Node.js
  Multi-instances pour scalabilité
  Redémarrage automatique défaillance
  Limites ressources conteneur
end note

note right of DatabaseContainer
  PostgreSQL 16
  Rétention 7 ans
  Sauvegardes quotidiennes
  Récupération point-in-time
end note

note right of QueueContainer
  Traitement tâches asynchrone
  Email/PDF/Export
  Retries automatiques
  File de lettres mortes
end note

note right of ExternalServices
  Intégrations tierces
  Appels API HTTPS
  Gestionnaires Webhooks
  Authentification sécurisée
end note

@enduml

