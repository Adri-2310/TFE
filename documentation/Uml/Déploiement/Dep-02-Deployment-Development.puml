@startuml Dep-02-Deployment-Development
!theme plain
title Diagramme de Déploiement - Environnement Développement WorkZen

node "💻 Machine Développeur Local" as DevMachine {

  node "🐳 Docker Desktop" as DockerDesktop {

    node "Conteneur: Serveur Next.js" as DevNextJSContainer {
      artifact "Serveur Développement Next.js\nPort 3000" as DevNextJSApp
      artifact "Hot Reload" as DevHotReload
      artifact "Routes API Locales" as DevAPIRoutes
      artifact "Service Authentification Béta" as DevAuthService
    }

    node "Conteneur: Base de Données" as DevDatabaseContainer {
      artifact "PostgreSQL 16 Local\nPort 5432" as DevPostgresApp
      artifact "Volume Données Local" as DevDataVolume
      artifact "Seed Données Test" as DevSeedData
    }

    node "Conteneur: Cache" as DevCacheContainer {
      artifact "Redis 7 Local\nPort 6379" as DevRedisApp
      artifact "Magasin Sessions" as DevSessionStore
    }

    node "Conteneur: Stockage" as DevStorageContainer {
      artifact "MinIO Local\nPort 9000" as DevMinIOApp
      artifact "Console MinIO\nPort 9001" as DevMinIOConsole
      artifact "Bucket Test" as DevBucket
    }

    node "Conteneur: File Asynchrone" as DevQueueContainer {
      artifact "Travailleurs BullMQ\nMode développement" as DevWorkers
      artifact "Dashboard BullMQ\nPort 3001" as DevQueueDash
    }
  }

  node "📋 Services Mock Locaux" as MockServices {
    artifact "Stripe Test Mode" as MockStripe
    artifact "Exact Online Sandbox" as MockExact
    artifact "ONSS Mode Test" as MockONSS
    artifact "Resend Mock Emails" as MockResend
  }

  artifact "🔧 Outils Développement" as DevTools {
    artifact "VS Code / IDE"
    artifact "Git Local"
    artifact "Node Package Manager"
    artifact "Bash/PowerShell Terminal"
  }

  artifact "📊 Logs & Debugging" as DevLogging {
    artifact "Console Navigateur"
    artifact "Logs Docker (docker logs)"
    artifact "Network Inspector"
  }
}

DevMachine --> DevNextJSContainer : Développement actif
DevNextJSApp --> DevHotReload : Rechargement automé
DevNextJSApp --> DevAPIRoutes : Routes locales
DevNextJSApp --> DevAuthService : Authentification

DevAPIRoutes --> DevPostgresApp : Requêtes SQL
DevAPIRoutes --> DevRedisApp : Cache Mémoire
DevAPIRoutes --> DevWorkers : Mettre en File Tâches
DevAPIRoutes --> DevMinIOApp : Stockage Fichiers

DevWorkers --> MockResend : Envoi Emails Test
DevAPIRoutes --> MockStripe : Paiement Test
DevAPIRoutes --> MockExact : Sync Comptabilité Test
DevAPIRoutes --> MockONSS : Déclarations Test

DevPostgresApp --> DevDataVolume : Données persistantes
DevPostgresApp --> DevSeedData : Données initiales test
DevRedisApp --> DevSessionStore : Sessions
DevMinIOApp --> DevBucket : Fichiers test

DevTools -.-> DevMachine : Interaction développeur
DevLogging -.-> DevMachine : Debugging

note bottom of DockerDesktop
  Configuration minimale
  Reproduction complète de la production
  Redémarrage rapide des services
  Performance optimale pour développement
end note

note bottom of MockServices
  Services externes simulés
  Pas de charges réelles
  Données aléatoires ou prédéfinies
  Pas d'authentification requise
end note

note bottom of DevTools
  Édition code en temps réel
  Commits locaux
  Exécution scripts
  Inspection réseau et DOM
end note

note bottom of DevLogging
  Sortie console complète
  Visualisation logs conteneur
  Inspection requêtes HTTP
  Débugage JavaScript/TypeScript
end note

@enduml
