@startuml Dep-04-Deployment-Production
!theme plain
title Diagramme de Déploiement - Environnement Production SocialFlow

node "🚀 Infrastructure Production" as ProductionInfra {

  node "🌐 Équilibreur Charge" as LoadBalancer {
    artifact "Nginx Reverse Proxy HA\nPort 80/443" as ProdNginx
    artifact "Terminaison SSL/TLS\nCertificats automatisés" as ProdSSL
    artifact "Haute Disponibilité Active/Active" as ProdHA
    artifact "Compression Gzip\nCache HTTP" as ProdCompression
  }

  node "🐳 Cluster Applications (3+ instances)" as AppCluster {

    node "Conteneur: Next.js Server (Instance 1)" as ProdNextJSContainer1 {
      artifact "Serveur Next.js Production\nPort 3000" as ProdNextJS1
      artifact "Serveur Rendu SSR/SSG" as ProdSSR1
    }

    node "Conteneur: Next.js Server (Instance 2)" as ProdNextJSContainer2 {
      artifact "Serveur Next.js Production\nPort 3000" as ProdNextJS2
      artifact "Serveur Rendu SSR/SSG" as ProdSSR2
    }

    node "Conteneur: Next.js Server (Instance 3)" as ProdNextJSContainer3 {
      artifact "Serveur Next.js Production\nPort 3000" as ProdNextJS3
      artifact "Serveur Rendu SSR/SSG" as ProdSSR3
    }

    node "Conteneur: Routes API (2+ instances)" as ProdAPIContainer {
      artifact "Routes API Production (Instance 1)\nPort 3000" as ProdAPI1
      artifact "Routes API Production (Instance 2)\nPort 3000" as ProdAPI2
    }

    node "Conteneur: Service Authentification (2+ instances)" as ProdAuthContainer {
      artifact "Service Better Auth (Instance 1)" as ProdAuth1
      artifact "Service Better Auth (Instance 2)" as ProdAuth2
    }
  }

  node "💾 Couche Données" as DataTier {

    node "Conteneur: Base de Données Cluster" as ProdDatabaseCluster {
      artifact "PostgreSQL 16 Primaire\nPort 5432" as ProdPostgresPrimary
      artifact "Réplique PostgreSQL (Read-Only 1)" as ProdPostgresReplica1
      artifact "Réplique PostgreSQL (Read-Only 2)" as ProdPostgresReplica2
      artifact "Volume Données Persistant (SSD)" as ProdDataVolume
      artifact "Write-Ahead Logs (WAL) Archiving" as ProdWAL
    }

    node "Conteneur: Cache Cluster HA" as ProdCacheCluster {
      artifact "Redis Cluster (Node 1)\nPort 6379" as ProdRedis1
      artifact "Redis Cluster (Node 2)\nPort 6379" as ProdRedis2
      artifact "Redis Cluster (Node 3)\nPort 6379" as ProdRedis3
      artifact "Sentinel pour Failover Automatique" as ProdSentinel
    }

    node "Conteneur: Stockage Distribué" as ProdStorageCluster {
      artifact "MinIO Distributed (Node 1)\nPort 9000" as ProdMinIO1
      artifact "MinIO Distributed (Node 2)\nPort 9000" as ProdMinIO2
      artifact "MinIO Distributed (Node 3)\nPort 9000" as ProdMinIO3
      artifact "Réplication multi-zone" as ProdMinIOReplication
    }
  }

  node "⚙️ Traitement Asynchrone" as JobProcessing {

    node "Conteneur: Travailleurs Asynchrones (Auto-scalé)" as ProdQueueContainer {
      artifact "Travailleurs BullMQ (Instance 1)" as ProdWorker1
      artifact "Travailleurs BullMQ (Instance 2)" as ProdWorker2
      artifact "Travailleurs BullMQ (Instance N) - Scaling" as ProdWorkerN
      artifact "Auto-scaling basé charge" as ProdAutoScaling
    }

    artifact "File Tâches Production\nRésilience garantie" as ProdJobQueue
    artifact "Retry Automatiques\nFile lettres mortes" as ProdRetryMechanism
  }

  node "📊 Monitoring, Logs & Alertes" as MonitoringStack {
    artifact "Prometheus + AlertManager\nMétriques temps réel" as ProdPrometheus
    artifact "Grafana Dashboards\nVisualisation avancée" as ProdGrafana
    artifact "ELK Stack (Elasticsearch/Logstash/Kibana)\nLogs centralisés" as ProdELK
    artifact "Sentry Production\nSuivi Erreurs applicatives" as ProdSentry
    artifact "Uptime Monitoring\nAlertes SMS/Email" as ProdUptimeMonitoring
  }

  node "🔐 Sécurité & Accès" as SecurityLayer {
    artifact "WAF (Web Application Firewall)" as ProdWAF
    artifact "Authentification Multi-Facteurs (MFA)" as ProdMFA
    artifact "Audit Logs & Compliance" as ProdAuditLogs
    artifact "Chiffrement End-to-End Sensible" as ProdEncryption
  }

  node "💾 Sauvegardes & Récupération Sinistre" as BackupDisasterRecovery {
    artifact "Sauvegardes Quotidiennes Chiffrées\nMulti-région" as ProdDailyBackups
    artifact "Récupération Point-in-Time (PITR)\nJusqu'à 35 jours" as ProdPITR
    artifact "Tests Récupération Réguliers" as ProdRecoveryTests
    artifact "Réplication Géographique DB" as ProdGeoReplication
    artifact "Plan Récupération Sinistre (DRP)\nObjectif RTO < 1h" as ProdDRP
  }
}

cloud "🌐 Services Externes Production" as ExternalServicesProduction {
  node "Stripe Production" as StripeProd {
    artifact "Compte Production Stripe\nClés de Production" as StripeProdAPI
  }

  node "Exact Online Production" as ExactProd {
    artifact "Environnement Production\nComptes clients réels" as ExactProdAPI
  }

  node "ONSS Production" as ONSSProd {
    artifact "API Production ONSS\nDéclarations réelles" as ONSSProdAPI
  }

  node "Resend Production" as ResendProd {
    artifact "Service Email Production\nEmails clients réels" as ResendProdAPI
  }

  node "Sentry Cloud" as SentryCloud {
    artifact "Sentry.io Production\nSuivi erreurs global" as SentryCloudAPI
  }

  node "CDN Global" as CDN {
    artifact "Cloudflare/CDN Edge\nDistribution statiques" as CDNEdge
    artifact "Caching global 24h" as CDNCache
  }
}

node "📱 Accès Administrateur" as AdminAccess {
  artifact "Console Administrateur Sécurisée\nVPN + MFA"
  artifact "Logs d'audit immédiat"
  artifact "Alertes anomalies"
}

ProdNginx --> ProdHA : Failover automatique

ProdHA --> ProdNextJS1 : Charge équilibrée
ProdHA --> ProdNextJS2 : Charge équilibrée
ProdHA --> ProdNextJS3 : Charge équilibrée
ProdHA --> ProdAPI1 : Routes API
ProdHA --> ProdAPI2 : Routes API
ProdHA --> ProdAuth1 : Authentification
ProdHA --> ProdAuth2 : Authentification

ProdNextJS1 --> ProdAuth1 : Token validation
ProdNextJS2 --> ProdAuth2 : Token validation
ProdNextJS3 --> ProdAuth1 : Token validation

ProdAPI1 --> ProdPostgresPrimary : Écriture
ProdAPI2 --> ProdPostgresPrimary : Écriture
ProdNextJS1 --> ProdPostgresReplica1 : Lecture
ProdNextJS2 --> ProdPostgresReplica2 : Lecture
ProdNextJS3 --> ProdPostgresReplica1 : Lecture

ProdAPI1 --> ProdRedis1 : Cache distribué
ProdAPI2 --> ProdRedis2 : Cache distribué
ProdNextJS1 --> ProdRedis3 : Cache sessions
ProdRedis1 -.-> ProdSentinel : Moniteur
ProdRedis2 -.-> ProdSentinel : Moniteur
ProdRedis3 -.-> ProdSentinel : Moniteur

ProdAPI1 --> ProdMinIO1 : Upload/Téléchargement
ProdAPI2 --> ProdMinIO2 : Upload/Téléchargement
ProdMinIO1 -.-> ProdMinIOReplication : Sync
ProdMinIO2 -.-> ProdMinIOReplication : Sync
ProdMinIO3 -.-> ProdMinIOReplication : Sync

ProdAPI1 --> ProdWorker1 : Enqueuer tâches
ProdAPI2 --> ProdWorker2 : Enqueuer tâches
ProdWorker1 --> ProdJobQueue : Tâches
ProdWorker2 --> ProdJobQueue : Tâches
ProdWorkerN --> ProdJobQueue : Tâches
ProdWorker1 --> ProdRetryMechanism : Retries

ProdWorker1 --> ResendProdAPI : Envoi Emails
ProdWorker2 --> ResendProdAPI : Envoi Emails
ProdAPI1 --> StripeProdAPI : Paiements
ProdAPI2 --> StripeProdAPI : Paiements
ProdAPI1 --> ExactProdAPI : Sync Comptabilité
ProdAPI2 --> ExactProdAPI : Sync Comptabilité
ProdAPI1 --> ONSSProdAPI : Déclarations
ProdWorker1 --> ONSSProdAPI : Envoi batch

ProdNextJS1 --> CDNEdge : Assets statiques
ProdNextJS2 --> CDNEdge : Assets statiques
ProdNextJS3 --> CDNEdge : Assets statiques

ProdAPI1 --> ProdSentry : Erreurs
ProdAPI2 --> ProdSentry : Erreurs
ProdNextJS1 --> ProdSentry : Erreurs client
ProdWorker1 --> ProdSentry : Erreurs jobs

ProdPostgresPrimary --> ProdWAL : Archiving
ProdPostgresPrimary --> ProdDailyBackups : Sauvegarde
ProdPostgresPrimary --> ProdGeoReplication : Réplication
ProdDailyBackups --> ProdPITR : Récupération
ProdPITR --> ProdRecoveryTests : Validation

ProdPrometheus --> ProdGrafana : Métriques
ProdPrometheus --> ProdAlerts : Alertes critiques
ProdELK --> ProdGrafana : Logs
ProdUptimeMonitoring --> ProdAlerts : Disponibilité

ProdAPI1 --> ProdWAF : Filtrage sécurité
ProdAPI2 --> ProdWAF : Filtrage sécurité
ProdWAF --> ProdMFA : Validation MFA
ProdMFA --> ProdAuditLogs : Logging

AdminAccess -.-> ProductionInfra : Gestion sécurisée

note bottom of LoadBalancer
  Haute Disponibilité garantie
  Certificats SSL auto-renouvelés
  Compression transparente
  Cache HTTP intelligent
end note

note bottom of AppCluster
  Instances multiples pour redondance
  Auto-scaling horizontal
  Déploiement zero-downtime (rolling updates)
  Santé checks continues
end note

note bottom of DataTier
  Réplication maître-esclave temps réel
  Cache distribué pour performance
  Stockage objet répliqué multi-zone
  Données persistantes garanties
end note

