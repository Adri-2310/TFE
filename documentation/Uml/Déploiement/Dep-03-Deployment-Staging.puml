@startuml Dep-03-Deployment-Staging
!theme plain
title Diagramme de Déploiement - Environnement Préproduction WorkZen

node "🧪 Serveur Préproduction" as StagingServer {

  node "🌐 Proxy Inverse" as StagingProxy {
    artifact "Nginx Reverse Proxy\nPort 80/443" as StagingNginx
    artifact "Terminaison SSL/TLS" as StagingSSL
    artifact "Équilibrage Charge Simple" as StagingLoadBalancer
  }

  node "🐳 Cluster Conteneurs" as StagingCluster {

    node "Conteneur: Serveur Next.js (Instance 1)" as StagingNextJSContainer1 {
      artifact "Serveur Next.js\nPort 3000" as StagingNextJS1
    }

    node "Conteneur: Serveur Next.js (Instance 2)" as StagingNextJSContainer2 {
      artifact "Serveur Next.js\nPort 3001" as StagingNextJS2
    }

    node "Conteneur: Routes API" as StagingAPIContainer {
      artifact "Routes API Staging" as StagingAPIRoutes
      artifact "Service Authentification" as StagingAuthService
    }

    node "Conteneur: Travailleurs Asynchrones" as StagingQueueContainer {
      artifact "Travailleurs BullMQ\nMode production" as StagingWorkers
      artifact "File Tâches (Redis)" as StagingJobQueue
    }
  }

  node "💾 Couche Données" as StagingDataLayer {

    node "Conteneur: Base de Données" as StagingDatabaseContainer {
      artifact "PostgreSQL 16 Staging\nPort 5432" as StagingPostgres
      artifact "Volume Données Staging" as StagingDataVolume
      artifact "Sauvegarde Quotidienne" as StagingDailyBackup
    }

    node "Conteneur: Cache" as StagingCacheContainer {
      artifact "Redis 7 Staging\nPort 6379" as StagingRedis
      artifact "Magasin Sessions" as StagingSessionStore
    }

    node "Conteneur: Stockage" as StagingStorageContainer {
      artifact "MinIO Staging\nPort 9000" as StagingMinIO
      artifact "Volume Stockage" as StagingStorageVolume
    }
  }

  node "📊 Monitoring & Logs" as StagingMonitoring {
    artifact "Prometheus Staging" as StagingPrometheus
    artifact "Grafana Staging" as StagingGrafana
    artifact "Logs (ELK Stack)" as StagingLogs
    artifact "Sentry Staging Project" as StagingSentry
  }
}

cloud "🌐 Services Externes - Mode Test" as ExternalServicesTesting {
  node "Stripe Test" as StripeTest {
    artifact "Compte Test Stripe\nClés Test" as StripeTestAPI
  }

  node "Exact Online Sandbox" as ExactSandbox {
    artifact "Environnement Sandbox\nAccès API Test" as ExactSandboxAPI
  }

  node "ONSS Test API" as ONSSTest {
    artifact "Environnement Test\nDéclarations de test" as ONSSTestAPI
  }

  node "Resend Test" as ResendTest {
    artifact "Mode Test Resend\nEmails simulés" as ResendTestAPI
  }

  node "Sentry Staging" as SentryStaging {
    artifact "Projet Sentry Staging\nSuivi Erreurs" as SentryStagingAPI
  }
}

node "🔐 Accès Contrôlé" as AccessControl {
  artifact "VPN ou IP Whitelist"
  artifact "Authentification Fortifiée"
  artifact "Logs Audits"
}

StagingProxy --> StagingNginx : Requêtes entrantes
StagingNginx --> StagingLoadBalancer : Distribution requêtes
StagingLoadBalancer --> StagingNextJS1 : Instance 1
StagingLoadBalancer --> StagingNextJS2 : Instance 2
StagingLoadBalancer --> StagingAPIRoutes : Routes API

StagingNextJS1 --> StagingAuthService : Authentification
StagingNextJS2 --> StagingAuthService : Authentification

StagingAPIRoutes --> StagingPostgres : Requêtes SQL
StagingAPIRoutes --> StagingRedis : Cache
StagingAPIRoutes --> StagingWorkers : Mettre en File
StagingAPIRoutes --> StagingMinIO : Stockage Fichiers

StagingWorkers --> ResendTestAPI : Envoi Emails Test
StagingAPIRoutes --> StripeTestAPI : Paiements Test
StagingAPIRoutes --> ExactSandboxAPI : Sync Comptabilité Test
StagingAPIRoutes --> ONSSTestAPI : Déclarations Test

StagingAPIRoutes --> SentryStagingAPI : Erreurs
StagingPostgres --> StagingPrometheus : Métriques
StagingNextJS1 --> StagingPrometheus : Métriques
StagingNextJS2 --> StagingPrometheus : Métriques

StagingPrometheus --> StagingGrafana : Visualisation
StagingCluster --> StagingLogs : Logs
StagingDatabaseContainer --> StagingLogs : Logs

StagingServer -.-> AccessControl : Sécurité d'accès

note bottom of StagingProxy
  Proxy inverse haute disponibilité
  Terminaison SSL/TLS obligatoire
  Équilibrage charge simple (round-robin)
end note

note bottom of StagingCluster
  Instances multiples pour validation scalabilité
  Configuration similaire à production
  Redéploiement fréquent
end note

note bottom of StagingDataLayer
  Données de test réalistes
  Sauvegardes chiffrées quotidiennes
  Récupération point-in-time disponible
  Clones des bases production (anonymisées)
end note

note bottom of ExternalServicesTesting
  Services externes en mode test
  Données de test fictives
  Pas d'impact sur comptes production
  Webhooks vers Staging uniquement
end note

note bottom of AccessControl
  Accès restricto au personnel autorisé
  Journalisation complète des actions
  Tests d'intégration validés
  Avant déploiement production
end note

@enduml
