@startuml SM-07-States-Alerte
!theme plain
title Diagramme d'État-Transition - Entité Alerte

[*] --> CRÉÉE : création par système

state CRÉÉE {
  [*] --> INACTIVE
  INACTIVE --> CRÉÉE : validation initiale
}

CRÉÉE --> ACTIVE : alerte validée

ACTIVE --> NOTIFIÉE : notification envoyée

NOTIFIÉE --> CONFIRMÉE : confirmée par destinataire

ACTIVE --> CONFIRMÉE : auto-confirmation

NOTIFIÉE --> ESCALADÉE : pas de confirmation 24h

ESCALADÉE --> CONFIRMÉE : confirmée après escalade

CONFIRMÉE --> ARCHIVÉE : fermeture de l'alerte

ARCHIVÉE --> [*] : destruction après rétention (1 an)

state CRÉÉE : Alerte créée\nStatus: CREATED\nEn phase initiale
state ACTIVE : Alerte active\nStatus: ACTIVE\nEn attente notification
state NOTIFIÉE : Notification envoyée\nStatus: NOTIFIED\nEn attente confirmation
state ESCALADÉE : Escaladée\nStatus: ESCALATED\nSans réponse 24h
state CONFIRMÉE : Confirmée\nStatus: CONFIRMED\nReconnue par utilisateur
state ARCHIVÉE : Archivée\nStatus: ARCHIVED\nConservation 1 an
state INACTIVE : Inactive\nEn création

note right of ACTIVE
  Canaux: email, SMS, push
  Priorité: LOW, MEDIUM, HIGH
  Récurrence possible
end note

note right of ESCALADÉE
  Manager notifié
  Escalade CRITIQUE
  Nouvelle tentative notification
end note

note right of ARCHIVÉE
  Audit trail complet
  Historique conservé
  Statistiques d'alertes
end note

@enduml
