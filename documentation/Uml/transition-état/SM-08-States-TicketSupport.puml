@startuml SM-08-States-TicketSupport
!theme plain
title Diagramme d'État-Transition - Entité TicketSupport

[*] --> CRÉÉ : création par client

state CRÉÉ {
  [*] --> INCOMPLET
  INCOMPLET --> CRÉÉ : correction données
  CRÉÉ --> INCOMPLET : validation échouée
}

CRÉÉ --> OPEN : enregistrement complet

OPEN --> ASSIGNÉ : assignation consultant

ASSIGNÉ --> IN_PROGRESS : consultant commence traitement

IN_PROGRESS --> EN_ATTENTE : attente info client

EN_ATTENTE --> IN_PROGRESS : client fournit info

IN_ATTENTE --> RÉPONDU : consultant apporte solution

IN_PROGRESS --> RÉPONDU : solution fournie

RÉPONDU --> RESOLVED : client valide solution

RÉPONDU --> REOPENED : client rejette solution

REOPENED --> IN_PROGRESS : traitement reprend

RESOLVED --> CLOSED : fermeture finale

OPEN --> CLOSED : fermeture sans résolution (annulation)

CLOSED --> ARCHIVÉ : satisfaction collectée

ARCHIVÉ --> [*] : destruction après rétention (2 ans)

state CRÉÉ : Ticket créé\nStatus: CREATED\nEn validation initiale
state OPEN : Ouvert\nStatus: OPEN\nEn attente assignation
state ASSIGNÉ : Assigné\nStatus: ASSIGNED\nEn traitement initial
state IN_PROGRESS : En cours\nStatus: IN_PROGRESS\nTraitement actif
state EN_ATTENTE : En attente\nStatus: WAITING\nAttente info client
state RÉPONDU : Répondu\nStatus: ANSWERED\nSolution proposée
state RESOLVED : Résolu\nStatus: RESOLVED\nSolution acceptée
state REOPENED : Réouvert\nStatus: REOPENED\nSolution rejetée
state CLOSED : Fermé\nStatus: CLOSED\nFermeture finale
state ARCHIVÉ : Archive\nStatus: ARCHIVED\nConservation 2 ans
state INCOMPLET : Incomplet\nDonnées manquantes

note right of OPEN
  SLA: assignment 4h
  Priorité: LOW-CRITICAL
  Catégories: Bug, Feature, Admin
end note

note right of IN_PROGRESS
  Consultant assigné
  Notes internes possibles
  Pièces jointes autorisées
end note

note right of ARCHIVÉ
  Satisfaction collectée (1-5)
  Feedback client conservé
  Historique support
  Statistiques KPI
end note

@enduml
