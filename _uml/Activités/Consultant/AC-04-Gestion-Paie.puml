@startuml AC-04-Gestion-Paie

title AC-04: Gestion Paie Consultant (Consultant)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:Consultant accède Gestion Paie;
:Sélectionner client;
:Afficher liste employés;

if (Consultant choisit ?) then (Générer paie)
  :Sélectionner période (mois/année);
  :Sélectionner employés ou tous;

  :Vérifier données complètes;
  if (Données valides ?) then (non)
    :Afficher erreurs données manquantes;
    :Enregistrer l'action (Audit Log: PAYROLL_GENERATION_FAILED);
    stop
  else (oui)
    :Continuer;
  endif

  :Calculer paie;
  :Salaire brut;
  :Appliquer cotisations ONSS;
  :Appliquer cotisations salariales;
  :Appliquer retenues;
  :Appliquer avantages;
  :Calculer net à payer;

  :Créer fiches paie brouillon;
  :Afficher résumé paies;
  :Afficher total masse salariale;
  :Enregistrer l'action (Audit Log: PAYROLL_GENERATED);

elseif (Consulter détail) then
  :Cliquer sur fiche;
  :Afficher tous éléments de paie;

  :Afficher bloc salaire brut;
  :Afficher bloc cotisations patronales;
  :Afficher bloc cotisations salariales;
  :Afficher bloc net à payer;

  if (Consultant modifie ?) then (oui)
    :Sélectionner élément à modifier;
    :Saisir nouvelle valeur;
    :Système recalcule paie;
    :Enregistrer l'action (Audit Log: PAYROLL_ELEMENT_MODIFIED);
  endif

elseif (Ajouter élément) then
  :Saisir type (prime, gratification);
  :Saisir montant;
  :Système applique cotisations;
  :Recalcul automatique;
  :Enregistrer l'action (Audit Log: PAYROLL_ELEMENT_ADDED);

elseif (Valider fiches) then
  :Sélectionner fiches à valider;
  :Afficher résumé validation;
  :Confirmation validation;

  :Changer statut à VALIDÉES;
  :Marquer date validation;
  :Enregistrer validateur;
  :Enregistrer l'action (Audit Log: PAYSLIPS_VALIDATED);

  :Notification clients;
  :Envoyer email fiches paie;
  :Fiches disponibles portail client;

else (Exporter)
  :Sélectionner format;

  if (Format PDF ?) then (oui)
    :Générer PDF fiches;
    :Signer numériquement;
  elseif (Format Excel ?) then (oui)
    :Générer Excel;
  else (CSV)
    :Générer CSV;
  endif

  :Chiffrer archive;
  :Télécharger;
  :Enregistrer l'action (Audit Log: PAYROLL_EXPORTED);
endif

:Afficher fiches paie complètes;

stop

@enduml
