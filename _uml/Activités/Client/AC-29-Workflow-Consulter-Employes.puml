@startuml AC-29-Consulter-Employes

title AC-29: Consulter Employés (Client)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:Client accède espace employés;
:Charger liste employés;
:Afficher tableau employés;

:Afficher colonnes: Nom, Prénom, Contrat, Statut, Date début;

split
  :Filtrer employés;
  :Sélectionner critères filtre;

  split
    :Filtrer par statut;
    :Afficher: Actif, Suspendu, Terminé;
    :Sélectionner statut(s);
  split
    :Filtrer par type contrat;
    :Afficher: CDI, CDD, Interim;
    :Sélectionner type(s);
  split
    :Rechercher par nom;
    :Entrer nom/prénom;
    :Recherche texte;
  end split

  :Appliquer filtres;
  :Afficher résultats filtrés;

split
  :Consulter détails employé;
  :Cliquer sur employé;
  :Charger profil complet;

  :Afficher bloc infos personnelles;
  :Afficher nom, prénom, email;
  :Afficher adresse, téléphone;
  :Afficher contact d'urgence;

  split
    :Afficher infos contrat;
    :Afficher type contrat;
    :Afficher date début;
    :Afficher date fin (si CDD);
    :Afficher classification;
  split
    :Afficher infos salaire;
    :Afficher salaire brut;
    :Afficher date dernière paie;
    :Afficher prochaine date paie;
  split
    :Afficher infos cotisations;
    :Afficher cotisations ONSS;
    :Afficher taux cotisations;
  end split

  :Afficher historique actions;
  :Afficher créations/modifications;
  :Afficher les dernières opérations;

  :Retour liste employés;

split
  :Consulter fiche paie employé;
  :Cliquer "Fiches paie";
  :Charger historique fiches;

  :Afficher liste fiches paie;
  :Filtrer par période;
  :Sélectionner fiche;

  :Afficher détails fiche sélectionnée;
  :Afficher salaire brut, net, cotisations;
  :Proposer téléchargement;

  if (Télécharger ?) then (oui)
    :Générer PDF;
    :Proposer téléchargement;
  else (non)
    :Retour employé;
  endif

split
  :Consulter documents employé;
  :Cliquer "Documents";
  :Charger liste documents;

  :Afficher documents disponibles;
  :Afficher: Certificats, Contrats, Attestations;

  split
    :Télécharger document;
    :Sélectionner document;
    :Cliquer "Télécharger";
    :Générer/préparer document;
    :Proposer téléchargement;
  split
    :Consulter contrat;
    :Afficher détails contrat;
    :Afficher conditions principales;
    :Proposer téléchargement;
  end split

split
  :Consulter absences/congés;
  :Cliquer "Absences";
  :Charger historique absences;

  :Afficher liste absences;
  :Afficher: Congés, Maladies, Autorisations;

  split
    :Filtrer par type;
    :Sélectionner type absence;
    :Appliquer filtre;
  split
    :Afficher détails absence;
    :Cliquer sur absence;
    :Afficher dates, motif, statut;
  end split

  :Afficher solde congés;
  :Afficher congés restants;
  :Afficher congés utilisés;

end split

:Afficher liste employés;
:Client peut continuer ou quitter;

stop

@enduml
