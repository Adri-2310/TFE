@startuml AC-08-Infos-Personnelles

title AC-08: Infos Personnelles (Employé)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:Employé accède Infos Personnelles;

if (Employé section ?) then (Profil)
  :Afficher nom, prénom;
  :Afficher NISS;
  :Afficher date naissance;
  :Afficher fonction, département;
  :Afficher date d'engagement;
  :Afficher statut;

elseif (Contact personnel) then
  if (Employé modifie ?) then (Email)
    :Saisir nouvel email;
    :Valider format;
    :Confirmer nouvel email;
    :Envoyer lien confirmation;
    :Enregistrer l'action (Audit Log: EMAIL_UPDATED);

  elseif (Téléphone) then
    :Saisir nouveau téléphone;
    :Valider format;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: PHONE_UPDATED);

  else (Adresse)
    :Saisir adresse personnelle;
    :Saisir code postal;
    :Saisir ville;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: ADDRESS_UPDATED);
  endif

elseif (Infos bancaires) then
  :Afficher IBAN masqué;

  if (Employé modifie ?) then (oui)
    :Saisir nouvel IBAN;
    :Valider format IBAN;
    :Chiffrer AES-256;
    :Sauvegarder;
    :Enregistrer l'action (Audit Log: BANKING_INFO_UPDATED);
  endif

elseif (Congés) then
  :Afficher solde congés légaux;
  :Afficher congés pris année;
  :Afficher congés restants;
  :Afficher historique absences;
  :Afficher justificatifs maladie;

else (Préférences)
  if (Employé configure ?) then (Langue)
    :Sélectionner: FR/NL/EN;
  elseif (Fuseau horaire) then
    :Sélectionner timezone;
  elseif (Notifications) then
    :Configurer email notifications;
    :Choisir fréquence;
    :Choisir types notifications;
  else (Format documents)
    :Préférence PDF/HTML;
  endif

  :Sauvegarder préférences;
  :Enregistrer l'action (Audit Log: PREFERENCES_UPDATED);
endif

:Enregistrer l'action (Audit Log: PERSONAL_INFO_ACCESSED);

stop

@enduml
