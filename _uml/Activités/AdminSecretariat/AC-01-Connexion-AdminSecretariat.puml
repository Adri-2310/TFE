@startuml AC-01-Connexion-AdminSecretariat

title AC-01: Connexion AdminSecretariat

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:AdminSecretariat accède /auth/login;
:Afficher formulaire connexion;

:Saisir email;
:Saisir mot de passe;

partition "Vérification Utilisateur" {
  :Valider format email;

  if (Format valide ?) then (non)
    :Afficher erreur;
    :Enregistrer l'action (Audit Log: LOGIN_FAILED_INVALID_EMAIL);
    stop
  else (oui)
    :Continuer;
  endif

  :Récupérer utilisateur par email;

  if (Utilisateur existe ?) then (non)
    :Afficher "Email non trouvé";
    :Enregistrer l'action (Audit Log: LOGIN_FAILED_USER_NOT_FOUND);
    stop
  else (oui)
    :Continuer;
  endif
}

partition "Vérification Mot de Passe" {
  :Compter tentatives échouées;

  if (Tentatives > 5 ?) then (oui)
    :Compte verrouillé 15 minutes;
    :Envoyer email alerte;
    :Afficher "Compte temporairement verrouillé";
    :Enregistrer l'action (Audit Log: ACCOUNT_LOCKED);
    stop
  else (non)
    :Continuer;
  endif

  :Récupérer password hash;
  :Comparer mot de passe (bcrypt);

  if (Mot de passe correct ?) then (non)
    :Incrémenter tentatives;
    :Afficher "Mot de passe incorrect";
    :Enregistrer l'action (Audit Log: LOGIN_FAILED_WRONG_PASSWORD);
    stop
  else (oui)
    :Réinitialiser tentatives à 0;
  endif
}

partition "Authentification 2FA" {
  :Vérifier 2FA activé;

  if (2FA obligatoire ?) then (oui)
    :Générer code 2FA (6 chiffres);
    :Envoyer email/SMS code;
    :Afficher écran saisie code;
    :AdminSecretariat saisit code;

    if (Code valide ?) then (non)
      :Afficher "Code invalide";
      :Enregistrer l'action (Audit Log: LOGIN_FAILED_INVALID_2FA);
      stop
    else (oui)
      :Code accepté;
    endif
  else (non)
    :2FA optionnel;
  endif
}

partition "Création Session" {
  :Enregistrer timestamp connexion;
  :Enregistrer IP client;
  :Enregistrer user-agent;

  fork
    partition "Session" {
      :Créer cookie sécurisé;
      :HttpOnly flag;
      :Secure flag;
      :SameSite=Strict;
      :Durée: 7 jours;
    }
  fork again
    partition "Token" {
      :Créer JWT token;
      :Signer token;
      :Inclure email, role, permissions;
      :TTL: 7 jours;
    }
  fork again
    partition "Audit" {
      :Enregistrer l'action (Audit Log: LOGIN_SUCCESS);
      :Enregistrer: Email, IP, Timestamp;
    }
  end fork
}

:Rediriger vers /admin/dashboard;
:Afficher bienvenue;

stop

@enduml
