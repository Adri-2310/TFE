@startuml AC-16-Veille-Legislative

title AC-16: Veille Législative Automatisée (SuperAdmin)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:SuperAdmin accède Veille Législative;

partition "Configuration Sources" {
  :Sélectionner sources;

  if (ONSS ?) then (activer)
    :Activer scraper ONSS;
  endif

  if (DIMONA ?) then (activer)
    :Activer scraper DIMONA;
  endif

  if (Bulletin Officiel ?) then (activer)
    :Activer scraper Bulletin Officiel;
  endif

  :Sauvegarder configuration;
  :Enregistrer l'action (Audit Log: CONFIG_VEILLE);
}

if (SuperAdmin choisit ?) then (Consulter alertes)
  :Afficher alertes détectées;
  :Lister par date récente;
  :Afficher source, titre, résumé;
  :Afficher impact (Paie/RGPD/Contrat);
  :Afficher date publication;

  if (SuperAdmin filtre ?) then (oui)
    :Filtrer par source;
    :Filtrer par impact;
    :Filtrer par période;
  else (non)
    :Afficher tous;
  endif

elseif (Détail alerte) then
  :Cliquer alerte;
  :Afficher texte complet;
  :Afficher lien source;
  :Afficher analyse impact;

  if (SuperAdmin marque vu ?) then (oui)
    :Marquer alerte comme vue;
  endif

  if (SuperAdmin ajoute note ?) then (oui)
    :Saisir note interne;
    :Sauvegarder note;
    :Enregistrer l'action (Audit Log: ALERT_NOTED);
  endif

elseif (Distribution) then
  :Sélectionner alertes;
  :Choisir destinataires;
  :AdminSecretariat notifiés;
  :Email envoyé;
  :Enregistrer l'action (Audit Log: ALERT_DISTRIBUTED);

else (Historique)
  :Définir horaire scraping;
  :Horaire par défaut: 02:00 AM;
  :Afficher derniers scraping;
  :Afficher nombre alertes détectées;
  :Afficher statut succès/erreur;
  :Enregistrer l'action (Audit Log: SCRAPING_REVIEWED);
endif

:Afficher veille complète;

stop

@enduml
