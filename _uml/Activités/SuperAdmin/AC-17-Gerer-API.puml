@startuml AC-17-Gerer-API

title AC-17: Gérer API Publique et Intégrations (SuperAdmin)

skinparam activityFontColor #000
skinparam backgroundColor #FEFEFF
skinparam arrowColor #333

:SuperAdmin accède Gestion API;

:Afficher clés API actives;
:Lister toutes clés API;

if (SuperAdmin choisit ?) then (Afficher clés)
  :Afficher nom, environnement, créée, dernier usage;
  :Afficher scopes/permissions;

elseif (Créer clé) then
  :Saisir nom clé;
  :Sélectionner environnement (sandbox/production);
  :Sélectionner scopes API;
  :Définir restrictions IP (optionnel);
  :Définir webhook URL;
  :Générer clé sécurisée;
  :Afficher clé unique (une seule fois);
  :Enregistrer l'action (Audit Log: API_KEY_CREATED);
  :Afficher confirmation;

elseif (Modifier clé) then
  :Cliquer sur clé;
  :Modifier nom;
  :Modifier restrictions IP;
  :Modifier webhook URL;
  :Modifier scopes;
  :Sauvegarder modifications;
  :Enregistrer l'action (Audit Log: API_KEY_UPDATED);

elseif (Révoquer clé) then
  :Sélectionner clé;
  :Confirmation révocation;
  :Invalider clé immédiatement;
  :Notifier intégrateurs;
  :Enregistrer l'action (Audit Log: API_KEY_REVOKED);

elseif (Tester API) then
  :Saisir endpoint;
  :Saisir payload JSON;
  :Saisir headers (authorization);
  :Envoyer requête test;
  :Afficher réponse;
  :Afficher status HTTP;

elseif (Webhooks) then
  :Lister webhooks enregistrés;
  :Afficher URL, events, dernière livraison;

  if (SuperAdmin crée webhook ?) then (oui)
    :Entrer URL endpoint;
    :Sélectionner événements;
    :Tester livraison webhook;
    :Enregistrer l'action (Audit Log: WEBHOOK_CREATED);
  endif

else (Documentation)
  :Afficher documentation API;
  :Lister endpoints disponibles;
  :Afficher description, méthode, paramètres;
  :Afficher exemples requête/réponse;
endif

:Afficher gestion API complète;

stop

@enduml
