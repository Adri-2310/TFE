@startuml AdminSecretariat-Package-Diagram
!theme plain
title Diagramme de Package - Admin Secrétariat (SocialFlow)

package "🎯 Inscription & Onboarding" as P_Onboarding {
  package "Processus d'Inscription" {
    [Formulaire Inscription]
    [Validation Données]
    [Création Compte]
  }
  package "Configuration Initiale" {
    [Sélection Plan Abonnement]
    [Configuration Secrétariat]
    [Intégration Systèmes]
  }
}

package "🔐 Authentification & Compte" as P_Auth {
  package "Module Authentification" {
    [Gestion Inscription]
    [Gestion Connexion]
    [Réinitialisation Mot de Passe]
  }
  package "Gestion Compte" {
    [Gestion Profil]
    [Paramètres]
    [Infos Abonnement]
  }
}

package "👤 Gestion Personnel" as P_Personnel {
  package "Répertoire Employés" {
    [CRUD Employés]
    [Recherche Employés]
    [Gestion Contrats]
  }
  package "Données Employés" {
    [Informations Personnelles]
    [Détails Emploi]
    [Informations Salaire]
  }
  package "Attribution Rôles" {
    [Gestion Postes]
    [Gestion Départements]
    [Droits d'Accès]
  }
}

package "📋 Gestion Paie" as P_Paie {
  package "Traitement Paie" {
    [Générateur Fiche Paie]
    [Calcul Salaire]
    [Gestion Déductions]
  }
  package "Archives Paie" {
    [Données Historiques]
    [Corrections]
    [Validations]
  }
}

package "📄 Gestion Documents" as P_Documents {
  package "Bibliothèque Templates" {
    [Templates Documents]
    [Édition Templates]
    [Versioning Templates]
  }
  package "Génération Documents" {
    [Génération Automatique]
    [Documents Personnalisés]
    [Stockage Documents]
  }
}

package "🏢 Gestion Entreprise" as P_Entreprise {
  package "Abonnement" {
    [Sélection Plan]
    [Facturation]
    [Suivi Utilisation]
    [Renouvellement]
  }
  package "Paramètres" {
    [Infos Entreprise]
    [Paramètres Intégrations]
    [Préférences Notifications]
  }
}

package "📊 Dashboard & Analytics" as P_Dashboard {
  package "Dashboard Admin" {
    [Vue d'ensemble Personnel]
    [Résumé Paie]
    [Tâches À Venir]
  }
  package "Rapports" {
    [Rapports Personnel]
    [Rapports Paie]
    [Rapports Conformité]
  }
}

package "📥 Gestion Données" as P_Donnees {
  package "Import/Export" {
    [Import Données]
    [Export Données]
    [Conversion Formats]
  }
  package "Outils RGPD" {
    [Export Données RGPD]
    [Suppression Données]
    [Conformité Privée]
  }
}

package "📜 Audit & Monitoring" as P_Audit {
  package "Journaux Audit" {
    [Suivi Actions]
    [Activités Utilisateurs]
    [Historique Modifications]
  }
  package "Monitoring" {
    [Santé Système]
    [Journaux Erreurs]
  }
}

