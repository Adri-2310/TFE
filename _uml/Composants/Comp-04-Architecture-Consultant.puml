@startuml Comp-04-Architecture-Consultant
!theme plain
title Diagramme de Composants - Accès Consultant (UML 2.x)

package "🎨 Frontend - Consultant" {
  component ["Tableau de Bord Consultant"] as DashCons
  component ["React Query"] as ReactQuery
  component ["ShadcnUI"] as ShadcnUI
}

package "⚙️ Backend - Routes API" {
  component ["Routes API"] as APIRoutes
  component ["Routes Authentification"] as AuthRoutes
}

package "⚙️ Métier" {
  component ["Logique Métier"] as BusinessLogic
  component ["Moteur de Calcul"] as CalcEngine
}

package "🗄️ Couche Données" {
  component ["Prisma ORM"] as PrismaORM
  component ["PostgreSQL"] as PostgreSQL
}

package "📦 Traitement Jobs" {
  component ["File BullMQ"] as BullMQ
  component ["Worker PDF"] as PDFWorker
  component ["Worker Email"] as EmailWorker
  component ["Logger"] as Logger
}

package "☁️ Services Externes" {
  component ["Exact Online"] as ExactOnline
  component ["API ONSS"] as ONSSAPI
  component ["Better Auth"] as BetterAuth
}

package "📁 Stockage" {
  component ["MinIO (S3)"] as MinIO
}

' ═════════════════════════════════════════════════════════════════
' INTERFACES MAJEURES (UML 2.x)
' ═════════════════════════════════════════════════════════════════

interface "API REST (JSON)" as I_API
interface "Data Access (Prisma/SQL)" as I_Data
interface "Job Queue (Redis)" as I_Queue

' ═════════════════════════════════════════════════════════════════
' RELATIONS FOURNISSEUR D'INTERFACES
' ═════════════════════════════════════════════════════════════════

APIRoutes --o I_API : fournit
PrismaORM --o I_Data : fournit
BullMQ --o I_Queue : fournit

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES FRONTEND
' ═════════════════════════════════════════════════════════════════

DashCons --> ReactQuery : afficher données
DashCons --> ShadcnUI : composants UI

' ═════════════════════════════════════════════════════════════════
' RELATIONS CONSOMMATEURS D'INTERFACES
' ═════════════════════════════════════════════════════════════════

ReactQuery ..> I_API : <<use>>\nrequêtes HTTP

APIRoutes ..> I_Data : <<use>>\nrequêtes métier
BusinessLogic ..> I_Data : <<use>>\nrequêtes données
CalcEngine ..> I_Data : <<use>>\nrécupère données

APIRoutes ..> I_Queue : <<use>>\nmettre en queue
PDFWorker ..> I_Queue : <<use>>\ntraiter PDFs
EmailWorker ..> I_Queue : <<use>>\ntraiter emails

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES BACKEND
' ═════════════════════════════════════════════════════════════════

APIRoutes --> AuthRoutes : authentification
APIRoutes --> BusinessLogic : gestion clients
APIRoutes --> BusinessLogic : gestion employés
APIRoutes --> CalcEngine : calcul fiches paie

BusinessLogic --> ExactOnline : synchronisation
BusinessLogic --> ONSSAPI : validation déclarations
BusinessLogic --> MinIO : stocker exports

PDFWorker --> MinIO : stocker fiches paie
EmailWorker --> MinIO : pièces jointes

APIRoutes --> BetterAuth : authentification
APIRoutes --> Logger : audit consultant

' ═════════════════════════════════════════════════════════════════
' ANNOTATIONS TECHNIQUES
' ═════════════════════════════════════════════════════════════════

note right of DashCons
  Gestion clients assignés
  Gestion employés clients
  Calcul fiches paie
  Génération PDF
  Envoi emails
end note

note right of BusinessLogic
  Gestion clients
  Gestion employés
  Validation données
  Synchronisation comptable
  Préparation exports
end note

note right of CalcEngine
  Calculs complexes
  Règles ONSS belges
  Calculs fiscaux
  Validation paies
  Prorations salaires
end note

note right of PDFWorker
  Génération fiches paie
  Export données
  Formatage documents
  Signature numérique
end note

note right of APIRoutes
  ACCÈS RESTREINT
  Gestion clients/employés
  Pas d'accès infrastructure
  Audit limité
end note

note right of I_API
  Endpoints métier sécurisés
  Authentication Bearer JWT
  Rate Limiting standard
  Validation requêtes
end note

note right of I_Data
  Requêtes Prisma (MÉTIER)
  Transactions SQL (MÉTIER)
  Filtrage par consultant
  Pas d'accès autres
end note

note right of I_Queue
  Redis jobs consultant
  PDF/Email workers
  Exports asynchrones
  Sync comptable
end note

note bottom
  ═════════════════════════════════════════════════════════════════
  RÔLE: CONSULTANT
  ═════════════════════════════════════════════════════════════════
  Permissions: LECTURE/ÉCRITURE MÉTIER

  Peut:
  - Gérer clients assignés
  - Gérer employés des clients
  - Générer fiches paie
  - Synchroniser comptabilité
  - Exporter données

  Restrictions:
  - Pas d'accès infrastructure
  - Audit limité
  - Pas d'autres consultants
end note

@enduml
