@startuml Comp-03-Architecture-AdminSecretariat
!theme plain
title Diagramme de Composants - Accès Admin Secrétariat (UML 2.x)

package "🎨 Frontend - Secrétariat" {
  component ["Tableau de Bord Secrétariat"] as DashSecr
  component ["React Query"] as ReactQuery
  component ["ShadcnUI"] as ShadcnUI
}

package "⚙️ Backend - Routes API" {
  component ["Routes API"] as APIRoutes
  component ["Routes Authentification"] as AuthRoutes
}

package "⚙️ Métier" {
  component ["Logique Métier"] as BusinessLogic
  component ["Moteur de Calcul"] as CalcEngine
}

package "🗄️ Couche Données" {
  component ["Prisma ORM"] as PrismaORM
  component ["PostgreSQL"] as PostgreSQL
}

package "📦 Traitement Jobs" {
  component ["File BullMQ"] as BullMQ
  component ["Worker Email"] as EmailWorker
  component ["Logger"] as Logger
}

package "☁️ Services Externes" {
  component ["Stripe"] as Stripe
  component ["Better Auth"] as BetterAuth
}

package "📁 Stockage" {
  component ["MinIO (S3)"] as MinIO
}

' ═════════════════════════════════════════════════════════════════
' INTERFACES MAJEURES (UML 2.x)
' ═════════════════════════════════════════════════════════════════

interface "API REST (JSON)" as I_API
interface "Data Access (Prisma/SQL)" as I_Data
interface "Job Queue (Redis)" as I_Queue

' ═════════════════════════════════════════════════════════════════
' RELATIONS FOURNISSEUR D'INTERFACES
' ═════════════════════════════════════════════════════════════════

APIRoutes --o I_API : fournit
PrismaORM --o I_Data : fournit
BullMQ --o I_Queue : fournit

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES FRONTEND
' ═════════════════════════════════════════════════════════════════

DashSecr --> ReactQuery : afficher données
DashSecr --> ShadcnUI : composants UI

' ═════════════════════════════════════════════════════════════════
' RELATIONS CONSOMMATEURS D'INTERFACES
' ═════════════════════════════════════════════════════════════════

ReactQuery ..> I_API : <<use>>\nrequêtes HTTP

APIRoutes ..> I_Data : <<use>>\nrequêtes métier
BusinessLogic ..> I_Data : <<use>>\nrequêtes données
CalcEngine ..> I_Data : <<use>>\nrécupère données

APIRoutes ..> I_Queue : <<use>>\nmettre en queue
EmailWorker ..> I_Queue : <<use>>\ntraiter jobs

' ═════════════════════════════════════════════════════════════════
' RELATIONS INTERNES BACKEND
' ═════════════════════════════════════════════════════════════════

APIRoutes --> AuthRoutes : authentification
APIRoutes --> BusinessLogic : gestion personnels
APIRoutes --> BusinessLogic : gestion abonnement
APIRoutes --> CalcEngine : validation données

BusinessLogic --> Stripe : gestion abonnement
BusinessLogic --> MinIO : stocker documents

EmailWorker --> MinIO : pièces jointes

APIRoutes --> BetterAuth : authentification
APIRoutes --> Logger : audit secrétariat

' ═════════════════════════════════════════════════════════════════
' ANNOTATIONS TECHNIQUES
' ═════════════════════════════════════════════════════════════════

note right of DashSecr
  Gestion personnels
  Gestion abonnements
  Import données
  Notifications
end note

note right of BusinessLogic
  Gestion équipe
  Gestion abonnements clients
  Validation données entrée
  Transactions financières
end note

note right of CalcEngine
  Validation règles métier
  Vérification cohérence données
  Calculs validations
  Contrôles intégrité
end note

note right of APIRoutes
  ACCÈS RESTREINT
  Gestion personnels/abonnement
  Pas d'accès infrastructure
  Audit limité
end note

note right of I_API
  Endpoints métier sécurisés
  Authentication Bearer JWT
  Rate Limiting standard
  Validation requêtes
end note

note right of I_Data
  Requêtes Prisma (MÉTIER)
  Transactions SQL (MÉTIER)
  Filtrage par secrétariat
  Pas d'accès système
end note

note right of I_Queue
  Redis jobs secrétariat
  Email workers
  Exports asynchrones
end note

note bottom
  ═════════════════════════════════════════════════════════════════
  RÔLE: ADMIN SECRÉTARIAT
  ═════════════════════════════════════════════════════════════════
  Permissions: LECTURE/ÉCRITURE MÉTIER

  Peut:
  - Gérer personnels
  - Gérer abonnements
  - Importer données
  - Valider données

  Restrictions:
  - Pas d'accès infrastructure
  - Audit limité
  - Pas de configuration système
end note

@enduml
