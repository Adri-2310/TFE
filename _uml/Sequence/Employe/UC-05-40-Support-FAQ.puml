@startuml Employe_UC05-40_Support_FAQ
title UC-05-40: Support et FAQ - Employé (Tous Scenarios)

actor Employé as E
participant Affichage
participant Contrôleur
participant Modèle
participant Log

E -> Affichage: 1. Accede a "FAQ / Support"
activate Affichage

Affichage -> Modèle: 2. Recupere FAQ publique\n(toutes categories)
activate Modèle

alt BD indisponible
  Modèle --> Affichage: ERREUR: BD down
  deactivate Modèle
  Affichage --> E: ERREUR 500: Impossible charger FAQ
  deactivate Affichage
else BD disponible
  Modèle --> Affichage: Retourne FAQ (question, reponse, categorie, date update)
  deactivate Modèle

  Affichage --> E: 3. Affiche FAQ avec categories\n(paie, conges, contrat, documents, support)
  deactivate Affichage

  E -> Affichage: 4. Consulte FAQ question
  activate Affichage

  Affichage --> E: 5. Affiche question et reponse details
  deactivate Affichage

  E -> Affichage: 6. Clique "Envoyer Message Support"
  activate Affichage

  Affichage --> E: 7. Affiche formulaire message\n(sujet, message, piece jointe optional)
  deactivate Affichage

  E -> Affichage: 8. Ecrit message et clique "Envoyer"
  activate Affichage

  Affichage -> Contrôleur: 9. Valide message\n(sujet non vide, message > 10 chars)
  activate Contrôleur

  alt Message invalide
    Contrôleur --> Affichage: ERREUR: Message invalide
    deactivate Contrôleur
    Affichage --> E: ERREUR: Verifiez le message
    deactivate Affichage
  else Message valide
    deactivate Contrôleur

    Affichage -> Modèle: 10. Cree ticket support en transaction\n(employee_id, client_id, sujet, message, status=OUVERT)
    activate Modèle

    alt Transaction echouee
      Modèle --> Affichage: ERREUR: Conflit ecriture
      deactivate Modèle
      Affichage --> E: ERREUR: Impossible envoyer, ressayez
      deactivate Affichage
    else Transaction reussie
      Modèle -> Modèle: 11. INSERT ticket_support

      Modèle -> Modèle: 12. INSERT notification pour support team

      Modèle --> Affichage: Ticket cree
      deactivate Modèle

      Affichage -> Log: 13. Log event: Ticket support cree
      activate Log
      Log --> Affichage: Event loggue
      deactivate Log

      Affichage --> E: 14. SUCCES! Ticket envoye\nNumero: #54321
      deactivate Affichage

      E -> Affichage: 15. Clique "Consulter mes messages"
      activate Affichage

      Affichage -> Modèle: 16. Recupere tickets support de l'employe\n(employee_id, client_id, order DESC)
      activate Modèle
      Modèle --> Affichage: Retourne tickets (sujet, date, statut, reponses)
      deactivate Modèle

      Affichage --> E: 17. Affiche liste tickets\n(avec statut: OUVERT, EN_COURS, RESOLU, FERME)
      deactivate Affichage

      E -> Affichage: 18. Clique sur ticket pour voir reponses
      activate Affichage

      Affichage -> Modèle: 19. Recupere ticket + reponses\n(ticket_id, employee_id, client_id)
      activate Modèle

      alt Ticket inexistant ou acces refuse
        Modèle --> Affichage: ERREUR 404: Non trouve ou 403: Acces refuse
        deactivate Modèle
        Affichage --> E: ERREUR: Ticket inexistant
        deactivate Affichage
      else Ticket existe et acces OK
        Modèle --> Affichage: Retourne ticket + reponses (qui, quand, contenu)
        deactivate Modèle

        Affichage --> E: 20. Affiche conversation\n(messages employe et support)
        deactivate Affichage

        E -> Affichage: 21. Clique "Repondre"
        activate Affichage

        Affichage --> E: 22. Affiche formulaire reponse
        deactivate Affichage

        E -> Affichage: 23. Ecrit reponse et clique "Envoyer"
        activate Affichage

        Affichage -> Contrôleur: 24. Valide reponse
        activate Contrôleur

        alt Reponse invalide
          Contrôleur --> Affichage: ERREUR: Reponse invalide
          deactivate Contrôleur
          Affichage --> E: ERREUR: Message invalide
          deactivate Affichage
        else Reponse valide
          deactivate Contrôleur

          Affichage -> Modèle: 25. Ajoute reponse en transaction
          activate Modèle

          alt Transaction echouee
            Modèle --> Affichage: ERREUR: Conflit ecriture
            deactivate Modèle
            Affichage --> E: ERREUR: Impossible envoyer
            deactivate Affichage
          else Transaction reussie
            Modèle -> Modèle: 26. INSERT reponse_ticket

            Modèle -> Modèle: 27. Notify support team

            Modèle --> Affichage: Reponse ajoutee
            deactivate Modèle

            Affichage -> Log: 28. Log event: Reponse employe enregistree
            activate Log
            Log --> Affichage: Event loggue
            deactivate Log

            Affichage --> E: 29. SUCCES! Reponse envoyee
            deactivate Affichage

            note over E, Log
              **SUPPORT EMPLOYE OK:**
              - FAQ consultable
              - Tickets creables et repondables
              - Conversation centralisee
              - Notifications support
              - Audit log enregistre
              - Employe isole: employee_id filtre
            end note
          end
        end
      end
    end
  end
end

@enduml
