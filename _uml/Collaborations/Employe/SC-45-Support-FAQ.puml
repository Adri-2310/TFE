@startuml SC-45-Support-FAQ
!theme plain
title Diagramme de Collaboration - Support & FAQ (Employe)

object Employe
object "Centre d'Aide" as CentreAide
object "Service FAQ" as ServiceFAQ
object "Service Support" as ServiceSupport
object "Base Données" as BaseDonnees
object "Service Audit" as ServiceAudit

Employe --> CentreAide : 1: acceder("Aide & FAQ")
CentreAide --> ServiceFAQ : 2: obtenirListeFAQ()
ServiceFAQ --> BaseDonnees : 3: executerRequete(articles_faq)
BaseDonnees --> ServiceFAQ : 3.1: listeArticles[]
ServiceFAQ --> CentreAide : 4: afficher(articles)
CentreAide --> Employe : 4.1: montrer(faq)

Employe --> CentreAide : 5: rechercher(motsCles)
CentreAide --> ServiceFAQ : 6: rechercherFAQ(motsCles)
ServiceFAQ --> BaseDonnees : 7: executerRequete(recherche)
BaseDonnees --> ServiceFAQ : 7.1: resultats[]
ServiceFAQ --> CentreAide : 8: afficher(resultats)
CentreAide --> Employe : 9: montrer(articles_trouves)

Employe --> CentreAide : 10: creer(ticket_support)
CentreAide --> ServiceSupport : 11: creerTicket({titre, description})
ServiceSupport --> BaseDonnees : 12: sauvegarderTicket(ticket)
BaseDonnees --> ServiceSupport : 12.1: ticketId

ServiceSupport --> ServiceAudit : 12.2: enregistrerAction("TICKET_SUPPORT_CREE")
ServiceAudit --> BaseDonnees : 12.3: sauvegarderLog()

ServiceSupport --> CentreAide : 13: succes()
CentreAide --> Employe : 14: afficher("Ticket cree")

@enduml
