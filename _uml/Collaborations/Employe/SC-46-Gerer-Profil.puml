@startuml SC-46-Gerer-Profil
!theme plain
title Diagramme de Collaboration - Gerer Profil Personnel (Employe)

object Employe
object "Interface Profil" as InterfaceProfil
object "Service Profil" as ServiceProfil
object "Base Données" as BaseDonnees
object "Service Audit" as ServiceAudit

Employe --> InterfaceProfil : 1: acceder("Parametres")
InterfaceProfil --> ServiceProfil : 2: obtenirParametres(employeId)
ServiceProfil --> BaseDonnees : 3: executerRequete(parametres)
BaseDonnees --> ServiceProfil : 3.1: donneeParametres
ServiceProfil --> InterfaceProfil : 4: afficher(parametres)
InterfaceProfil --> Employe : 4.1: montrer(options)

Employe --> InterfaceProfil : 5: modifier(preferences)
InterfaceProfil --> ServiceProfil : 6: mettreAJourPreferences({langue, theme, notifications})
ServiceProfil --> BaseDonnees : 7: mettreAJourEnregistrement(prefs)
BaseDonnees --> ServiceProfil : 7.1: ok

ServiceProfil --> ServiceAudit : 7.2: enregistrerAction("PREFERENCES_MISES_A_JOUR")
ServiceAudit --> BaseDonnees : 7.3: sauvegarderLog()

ServiceProfil --> InterfaceProfil : 8: succes()
InterfaceProfil --> Employe : 9: afficher("Preferences mises a jour")

Employe --> InterfaceProfil : 10: changer(motDePasse)
InterfaceProfil --> ServiceProfil : 11: changerMotDePasse(ancienMotDePasse, nouveauMotDePasse)
ServiceProfil --> ServiceProfil : 12: validerAncienMotDePasse()
ServiceProfil --> BaseDonnees : 13: mettreAJourMotDePasse(nouveauMotDePasse)
BaseDonnees --> ServiceProfil : 13.1: ok

ServiceProfil --> ServiceAudit : 13.2: enregistrerAction("MOTDEPASSE_CHANGE")
ServiceAudit --> BaseDonnees : 13.3: sauvegarderLog()

ServiceProfil --> InterfaceProfil : 14: succes()
InterfaceProfil --> Employe : 15: afficher("Mot de passe modifie")

@enduml
