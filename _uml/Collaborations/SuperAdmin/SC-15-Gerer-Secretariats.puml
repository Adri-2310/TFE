@startuml SC-15-Gerer-Secretariats
!theme plain
title Diagramme de Collaboration - Gerer Secretariats (SuperAdmin)

object SuperAdmin
object "Interface Admin" as InterfaceAdmin
object "Service Secretariat" as ServiceSecretariat
object "Service Plans" as ServicePlans
object "Base Données" as BaseDonnees
object "Service Notification" as ServiceNotification
object "Service Audit" as ServiceAudit

SuperAdmin --> InterfaceAdmin : 1: acceder("Gestion Secretariats")
InterfaceAdmin --> ServiceSecretariat : 2: obtenirTousSecretariats()
ServiceSecretariat --> BaseDonnees : 3: executerRequete(tous_secretariats)
BaseDonnees --> ServiceSecretariat : 3.1: listeSecretariats[]
ServiceSecretariat --> InterfaceAdmin : 4: afficher(liste)
InterfaceAdmin --> SuperAdmin : 4.1: montrer(tableau)

SuperAdmin --> InterfaceAdmin : 5: creer(nouveau_secretariat)
InterfaceAdmin --> ServiceSecretariat : 6: creerSecretariat({nom, adresse, contact})
ServiceSecretariat --> ServicePlans : 7: assignerPlanDefaut(idSecretariat)
ServicePlans --> BaseDonnees : 8: sauvegarderPlan(plan)
BaseDonnees --> ServicePlans : 8.1: ok
ServicePlans --> ServiceSecretariat : 9: planAssigne
ServiceSecretariat --> BaseDonnees : 10: sauvegarderSecretariat(donnees)
BaseDonnees --> ServiceSecretariat : 10.1: idSecretariat

ServiceSecretariat --> ServiceAudit : 10.2: enregistrerAction("CREATION_SECRETARIAT")
ServiceAudit --> BaseDonnees : 10.3: sauvegarderLog()

ServiceSecretariat --> ServiceNotification : 11: notifier(secretariat)
ServiceNotification --> ServiceNotification : 12: envoyerEmail(admin)
ServiceSecretariat --> InterfaceAdmin : 13: succes(idSecretariat)
InterfaceAdmin --> SuperAdmin : 14: afficher("Secretariat cree")

SuperAdmin --> InterfaceAdmin : 15: selectionner(secretariat)
InterfaceAdmin --> ServiceSecretariat : 16: obtenirSecretariat(idSecretariat)
ServiceSecretariat --> BaseDonnees : 17: executerRequete(details)
BaseDonnees --> ServiceSecretariat : 17.1: donneesSecretariat
ServiceSecretariat --> InterfaceAdmin : 18: afficher(details)
InterfaceAdmin --> SuperAdmin : 19: montrer(informations)

SuperAdmin --> InterfaceAdmin : 20: modifier(secretariat)
InterfaceAdmin --> ServiceSecretariat : 21: modifierSecretariat(idSecretariat, donnees)
ServiceSecretariat --> BaseDonnees : 22: mettreAJourEnregistrement(donnees)
BaseDonnees --> ServiceSecretariat : 22.1: ok

ServiceSecretariat --> ServiceAudit : 22.2: enregistrerAction("MODIFICATION_SECRETARIAT")
ServiceAudit --> BaseDonnees : 22.3: sauvegarderLog()

ServiceSecretariat --> InterfaceAdmin : 23: succes()
InterfaceAdmin --> SuperAdmin : 24: afficher("Modifie")

SuperAdmin --> InterfaceAdmin : 25: suspendre(secretariat)
InterfaceAdmin --> ServiceSecretariat : 26: suspendreSecretariat(idSecretariat)
ServiceSecretariat --> BaseDonnees : 27: mettreAJourStatut(SUSPENDU)
BaseDonnees --> ServiceSecretariat : 27.1: ok

ServiceSecretariat --> ServiceAudit : 27.2: enregistrerAction("SUSPENSION_SECRETARIAT")
ServiceAudit --> BaseDonnees : 27.3: sauvegarderLog()

ServiceSecretariat --> ServiceNotification : 28: notifierAdmin(suspendu)
ServiceSecretariat --> InterfaceAdmin : 29: succes()
InterfaceAdmin --> SuperAdmin : 30: afficher("Suspendu")

@enduml
