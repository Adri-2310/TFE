<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gestion Paie — Admin Secrétariat | SocialFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary:   { DEFAULT: '#0F7BA7', light: '#1A9FD4', dark: '#0A5A7A' },
            secondary: { DEFAULT: '#10B981', light: '#34D399', dark: '#059669' },
            accent:    { DEFAULT: '#F97316' },
            danger:    { DEFAULT: '#EF4444' },
            warning:   { DEFAULT: '#F59E0B' },
            sidebar:   { DEFAULT: '#0F172A' },
          },
          animation: {
            'fade-in': 'fadeIn 0.3s ease-in-out',
            'slide-up': 'slideUp 0.3s ease-out',
          },
          keyframes: {
            fadeIn: {
              '0%': { opacity: '0' },
              '100%': { opacity: '1' },
            },
            slideUp: {
              '0%': { opacity: '0', transform: 'translateY(10px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            },
          }
        }
      }
    }
  </script>
  <style>
    .modal-backdrop { animation: fadeIn 0.3s ease-in-out; }
    .modal-content { animation: slideUp 0.3s ease-out; }
    .toast { animation: slideUp 0.3s ease-out, fadeOut 0.3s ease-out 2.7s forwards; }
    @keyframes fadeOut { 100% { opacity: 0; transform: translateY(-10px); } }
    .badge-valide { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800; }
    .badge-attente { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800; }
    .badge-rejected { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800; }
    .btn-primary { @apply bg-primary text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-primary-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed; }
    .btn-secondary { @apply bg-gray-200 text-gray-900 px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-300 transition-colors; }
    .btn-danger { @apply bg-danger text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-red-600 transition-colors; }
  </style>
</head>
<body class="min-h-screen bg-gray-50">

<!-- SIDEBAR -->
<div id="sidebar-container"></div>

<!-- MAIN -->
<main class="ml-64 min-h-screen flex flex-col">
  <!-- Header -->
  <div class="bg-white border-b border-gray-200 sticky top-0 z-30">
    <div class="px-8 py-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Gestion Paie</h1>
          <p class="text-gray-500 text-sm mt-1">Bulletins de paie et validation</p>
        </div>
        <button onclick="openCreateModal()" class="btn-primary">
          + Créer bulletin
        </button>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="p-8 flex-1">
    <!-- Filters & Search -->
    <div class="mb-6 flex flex-col sm:flex-row gap-4">
      <input
        type="text"
        id="searchInput"
        placeholder="Rechercher par employé..."
        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
      />
      <select id="moisFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
        <option value="">Tous les mois</option>
        <option value="2026-05">Mai 2026</option>
        <option value="2026-06">Juin 2026</option>
        <option value="2026-07">Juillet 2026</option>
      </select>
      <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
        <option value="">Tous les statuts</option>
        <option value="Validé">Validé</option>
        <option value="En attente">En attente</option>
        <option value="Rejeté">Rejeté</option>
      </select>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Employé</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Période</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Brut</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Retenues</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Net</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Statut</th>
              <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody id="tableBody" class="divide-y divide-gray-200">
            <!-- Dynamically populated -->
          </tbody>
        </table>
      </div>
      <div class="px-6 py-4 border-t border-gray-200 text-sm text-gray-600 bg-gray-50">
        <span id="recordCount">Affichage 0 bulletins</span>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 py-6 px-8 text-center text-gray-500 text-sm">
    <p>&copy; 2026 SocialFlow SPRL. Tous droits réservés.</p>
  </footer>
</main>

<!-- DETAIL BULLETIN MODAL -->
<div id="detailModal" class="hidden fixed inset-0 bg-black/50 modal-backdrop z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-2xl modal-content max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
      <div>
        <h2 id="detailTitle" class="text-xl font-bold text-gray-900">Bulletin de Paie</h2>
        <p id="detailPeriod" class="text-xs text-gray-500 mt-1">Période</p>
      </div>
      <button onclick="closeDetailModal()" class="text-gray-500 hover:text-gray-700 text-2xl leading-none">&times;</button>
    </div>

    <div class="p-6 space-y-6">
      <!-- Employee Info -->
      <div>
        <h3 class="text-sm font-semibold text-gray-600 uppercase mb-3">Informations</h3>
        <div class="bg-gray-50 rounded-lg p-4">
          <p id="detailEmploye" class="text-sm font-medium text-gray-900">Employé</p>
          <p id="detailStatus" class="text-xs text-gray-500 mt-2">Statut</p>
        </div>
      </div>

      <!-- Salary Breakdown -->
      <div>
        <h3 class="text-sm font-semibold text-gray-600 uppercase mb-3">Rémunération</h3>
        <div class="bg-primary/10 rounded-lg p-4 border border-primary/20 space-y-2">
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-700">Salaire de base</span>
            <span id="detailSalaire" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="border-t border-primary/20 pt-2 flex justify-between items-center">
            <span class="text-sm font-medium text-primary">Total Brut</span>
            <span id="detailBrut" class="text-lg font-bold text-primary">0.00 €</span>
          </div>
        </div>
      </div>

      <!-- Deductions -->
      <div>
        <h3 class="text-sm font-semibold text-gray-600 uppercase mb-3">Retenues</h3>
        <div class="bg-danger/10 rounded-lg p-4 border border-danger/20 space-y-2">
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-700">ONSS (13.07%)</span>
            <span id="detailONSS" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm text-gray-700">Précompte professionnel</span>
            <span id="detailPrecompte" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="border-t border-danger/20 pt-2 flex justify-between items-center">
            <span class="text-sm font-medium text-danger">Total Retenues</span>
            <span id="detailTotalRetenues" class="text-lg font-bold text-danger">0.00 €</span>
          </div>
        </div>
      </div>

      <!-- Net Pay -->
      <div class="bg-secondary/10 rounded-lg p-4 border border-secondary/20">
        <p class="text-sm text-gray-700 mb-2">Net à payer</p>
        <p id="detailNet" class="text-3xl font-bold text-secondary">0.00 €</p>
      </div>

      <!-- Employer Cost -->
      <div>
        <h3 class="text-sm font-semibold text-gray-600 uppercase mb-3">Coût Employeur</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
            <span class="text-sm text-gray-700">Base salaire</span>
            <span id="detailCostBase" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
            <span class="text-sm text-gray-700">ONSS employeur (25%)</span>
            <span id="detailCostONSS" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
            <span class="text-sm text-gray-700">Cotisations</span>
            <span id="detailCostCotisations" class="text-sm font-semibold text-gray-900">0.00 €</span>
          </div>
          <div class="flex justify-between items-center p-3 bg-accent/10 rounded border border-accent/20">
            <span class="text-sm font-bold text-gray-900">Coût total employeur</span>
            <span id="detailCostTotal" class="text-lg font-bold text-accent">0.00 €</span>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <button onclick="closeDetailModal()" class="btn-secondary flex-1">Fermer</button>
        <button onclick="detailPrintBulletin()" class="bg-gray-100 text-gray-900 px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors flex-1">Imprimer</button>
        <button id="detailApproveBtn" onclick="detailApproveBulletin()" class="btn-primary flex-1">Approuver</button>
      </div>
    </div>
  </div>
</div>

<!-- CREATE/EDIT MODAL -->
<div id="formModal" class="hidden fixed inset-0 bg-black/50 modal-backdrop z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-2xl modal-content max-w-lg w-full max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
      <h2 id="modalTitle" class="text-xl font-bold text-gray-900">Créer bulletin</h2>
      <button onclick="closeFormModal()" class="text-gray-500 hover:text-gray-700 text-2xl leading-none">&times;</button>
    </div>

    <form id="paieForm" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Employé *</label>
        <select id="formEmploye" required class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
          <option value="">Sélectionner un employé</option>
          <option value="Marie Aubry">Marie Aubry</option>
          <option value="Sophie Noel">Sophie Noel</option>
          <option value="Jean Dupont">Jean Dupont</option>
          <option value="Marc Durand">Marc Durand</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Mois *</label>
        <input type="month" id="formMois" required class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Salaire brut €</label>
          <input type="number" id="formBrut" step="0.01" placeholder="0.00" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Cotisations €</label>
          <input type="number" id="formCotisations" step="0.01" placeholder="0.00" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Salaire net € (calculé)</label>
        <div class="px-4 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-600">
          <span id="formNet">0.00</span>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Statut</label>
        <select id="formStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
          <option value="En attente">En attente</option>
          <option value="Validé">Validé</option>
          <option value="Rejeté">Rejeté</option>
        </select>
      </div>

      <input type="hidden" id="formId" />

      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <button type="button" onclick="closeFormModal()" class="btn-secondary flex-1">Annuler</button>
        <button type="submit" class="btn-primary flex-1">Enregistrer</button>
      </div>
    </form>
  </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div id="deleteModal" class="hidden fixed inset-0 bg-black/50 modal-backdrop z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-2xl modal-content max-w-md w-full">
    <div class="p-6">
      <div class="flex items-center justify-center w-12 h-12 mx-auto bg-red-100 rounded-full mb-4">
        <svg class="w-6 h-6 text-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2m9-15a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Supprimer ce bulletin ?</h3>
      <p class="text-gray-500 text-xs text-center mb-6 p-3 bg-gray-50 rounded">
        Cette action est irréversible.
      </p>
      <div class="flex gap-3">
        <button onclick="closeDeleteModal()" class="btn-secondary flex-1">Annuler</button>
        <button onclick="confirmDelete()" class="btn-danger flex-1">Supprimer</button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST NOTIFICATIONS -->
<div id="toastContainer" class="fixed bottom-6 right-6 z-50 space-y-2"></div>

<script src="./includes-admin.js"></script>
<script>
// ============ STATE MANAGEMENT ============
let bulletins = [];
let currentEditId = null;
let currentDeleteId = null;

// ============ INITIALIZATION ============
function initData() {
  const saved = localStorage.getItem('socialflow_paie');
  if (saved) {
    bulletins = JSON.parse(saved);
  } else {
    bulletins = [
      { id: 1, employe: 'Marie Aubry', mois: '2026-06', brut: 3500, cotisations: 700, net: 2800, status: 'Validé' },
      { id: 2, employe: 'Sophie Noel', mois: '2026-06', brut: 3200, cotisations: 640, net: 2560, status: 'Validé' },
      { id: 3, employe: 'Marc Durand', mois: '2026-07', brut: 2400, cotisations: 480, net: 1920, status: 'En attente' },
    ];
    saveData();
  }
  renderTable();
  setupEventListeners();
  setupCalculations();
}

function saveData() {
  localStorage.setItem('socialflow_paie', JSON.stringify(bulletins));
}

// ============ EVENTS ============
function setupEventListeners() {
  document.getElementById('searchInput').addEventListener('input', renderTable);
  document.getElementById('moisFilter').addEventListener('change', renderTable);
  document.getElementById('statusFilter').addEventListener('change', renderTable);
  document.getElementById('paieForm').addEventListener('submit', handleFormSubmit);
}

function setupCalculations() {
  const brutInput = document.getElementById('formBrut');
  const cotisationsInput = document.getElementById('formCotisations');
  const netDisplay = document.getElementById('formNet');

  function updateNet() {
    const brut = parseFloat(brutInput.value) || 0;
    const cotisations = parseFloat(cotisationsInput.value) || 0;
    const net = brut - cotisations;
    netDisplay.textContent = net.toFixed(2);
  }

  brutInput.addEventListener('input', updateNet);
  cotisationsInput.addEventListener('input', updateNet);
}

// ============ TABLE RENDERING ============
function getFilteredData() {
  let data = [...bulletins];

  const search = document.getElementById('searchInput').value.toLowerCase();
  if (search) {
    data = data.filter(b => b.employe.toLowerCase().includes(search));
  }

  const mois = document.getElementById('moisFilter').value;
  if (mois) {
    data = data.filter(b => b.mois === mois);
  }

  const status = document.getElementById('statusFilter').value;
  if (status) {
    data = data.filter(b => b.status === status);
  }

  return data;
}

function renderTable() {
  const data = getFilteredData();
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';

  if (data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">Aucun bulletin trouvé</td></tr>';
    document.getElementById('recordCount').textContent = 'Affichage 0 bulletins';
    return;
  }

  data.forEach(bulletin => {
    const badgeClass = bulletin.status === 'Validé' ? 'badge-valide' : bulletin.status === 'En attente' ? 'badge-attente' : 'badge-rejected';
    const moisDisplay = new Date(bulletin.mois + '-01').toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' });
    const retenues = bulletin.cotisations;
    const totalBrut = bulletin.brut + bulletin.cotisations;
    const brutPercent = Math.round((bulletin.brut / totalBrut) * 100);
    const retenuesPercent = 100 - brutPercent;

    const tr = document.createElement('tr');
    tr.className = 'hover:bg-gray-50 transition-colors cursor-pointer';
    tr.onclick = () => openDetailModal(bulletin.id);
    tr.innerHTML = `
      <td class="px-6 py-4 text-sm">
        <p class="text-gray-900 font-medium">${escapeHtml(bulletin.employe)}</p>
      </td>
      <td class="px-6 py-4 text-sm text-gray-600">${moisDisplay}</td>
      <td class="px-6 py-4 text-sm text-right">
        <div class="font-semibold text-primary">${bulletin.brut.toFixed(2)} €</div>
        <div class="text-xs text-gray-500 mt-1">Brut</div>
      </td>
      <td class="px-6 py-4 text-sm text-right">
        <div class="font-semibold text-danger">${retenues.toFixed(2)} €</div>
        <div class="text-xs text-gray-500 mt-1">${((retenues/bulletin.brut)*100).toFixed(0)}%</div>
      </td>
      <td class="px-6 py-4 text-sm text-right">
        <div class="font-semibold text-secondary">${bulletin.net.toFixed(2)} €</div>
        <div class="text-xs text-gray-500 mt-1">Net</div>
      </td>
      <td class="px-6 py-4">
        <span class="${badgeClass}">
          ${bulletin.status}
        </span>
      </td>
      <td class="px-6 py-4 text-center">
        <div class="flex gap-2 justify-center">
          <button onclick="event.stopPropagation(); openEditModal(${bulletin.id})" class="text-primary hover:underline text-sm font-medium">Éditer</button>
          <button onclick="event.stopPropagation(); openDeleteModal(${bulletin.id})" class="text-danger hover:underline text-sm font-medium">Supprimer</button>
        </div>
      </td>
    `;
    tbody.appendChild(tr);
  });

  document.getElementById('recordCount').textContent = `Affichage ${data.length} bulletin${data.length > 1 ? 's' : ''}`;
}

// ============ MODALS ============
function openDetailModal(id) {
  const bulletin = bulletins.find(b => b.id === id);
  if (!bulletin) return;

  const moisDisplay = new Date(bulletin.mois + '-01').toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' });
  const onss = bulletin.brut * 0.1307;
  const precompte = bulletin.cotisations - onss;
  const costONSS = bulletin.brut * 0.25;
  const costTotal = bulletin.brut + costONSS + bulletin.cotisations;

  document.getElementById('detailTitle').textContent = `Bulletin #${bulletin.id}-${bulletin.mois}`;
  document.getElementById('detailPeriod').textContent = moisDisplay;
  document.getElementById('detailEmploye').textContent = escapeHtml(bulletin.employe);
  document.getElementById('detailStatus').textContent = `Statut: ${bulletin.status}`;
  document.getElementById('detailSalaire').textContent = bulletin.brut.toFixed(2) + ' €';
  document.getElementById('detailBrut').textContent = bulletin.brut.toFixed(2) + ' €';
  document.getElementById('detailONSS').textContent = onss.toFixed(2) + ' €';
  document.getElementById('detailPrecompte').textContent = precompte.toFixed(2) + ' €';
  document.getElementById('detailTotalRetenues').textContent = bulletin.cotisations.toFixed(2) + ' €';
  document.getElementById('detailNet').textContent = bulletin.net.toFixed(2) + ' €';
  document.getElementById('detailCostBase').textContent = bulletin.brut.toFixed(2) + ' €';
  document.getElementById('detailCostONSS').textContent = costONSS.toFixed(2) + ' €';
  document.getElementById('detailCostCotisations').textContent = bulletin.cotisations.toFixed(2) + ' €';
  document.getElementById('detailCostTotal').textContent = costTotal.toFixed(2) + ' €';

  const approveBtn = document.getElementById('detailApproveBtn');
  approveBtn.textContent = bulletin.status === 'Validé' ? 'Déjà approuvé' : 'Approuver';
  approveBtn.disabled = bulletin.status === 'Validé';

  document.getElementById('detailModal').classList.remove('hidden');
}

function closeDetailModal() {
  document.getElementById('detailModal').classList.add('hidden');
}

function detailApproveBulletin() {
  showToast('Bulletin approuvé avec succès', 'success');
  closeDetailModal();
  renderTable();
}

function detailPrintBulletin() {
  window.print();
  showToast('Impression lancée', 'success');
}

function openCreateModal() {
  currentEditId = null;
  document.getElementById('modalTitle').textContent = 'Créer bulletin';
  document.getElementById('paieForm').reset();
  document.getElementById('formId').value = '';
  document.getElementById('formNet').textContent = '0.00';
  document.getElementById('formModal').classList.remove('hidden');
}

function openEditModal(id) {
  const bulletin = bulletins.find(b => b.id === id);
  if (!bulletin) return;

  currentEditId = id;
  document.getElementById('modalTitle').textContent = 'Éditer bulletin';
  document.getElementById('formId').value = id;
  document.getElementById('formEmploye').value = bulletin.employe;
  document.getElementById('formMois').value = bulletin.mois;
  document.getElementById('formBrut').value = bulletin.brut;
  document.getElementById('formCotisations').value = bulletin.cotisations;
  document.getElementById('formNet').textContent = bulletin.net.toFixed(2);
  document.getElementById('formStatus').value = bulletin.status;

  document.getElementById('formModal').classList.remove('hidden');
}

function closeFormModal() {
  document.getElementById('formModal').classList.add('hidden');
  document.getElementById('paieForm').reset();
}

function openDeleteModal(id) {
  currentDeleteId = id;
  document.getElementById('deleteModal').classList.remove('hidden');
}

function closeDeleteModal() {
  document.getElementById('deleteModal').classList.add('hidden');
  currentDeleteId = null;
}

// ============ FORM HANDLING ============
function handleFormSubmit(e) {
  e.preventDefault();

  const id = parseInt(document.getElementById('formId').value);
  const employe = document.getElementById('formEmploye').value;
  const mois = document.getElementById('formMois').value;
  const brut = parseFloat(document.getElementById('formBrut').value) || 0;
  const cotisations = parseFloat(document.getElementById('formCotisations').value) || 0;
  const net = brut - cotisations;
  const status = document.getElementById('formStatus').value;

  if (!employe || !mois || brut <= 0) {
    showToast('Tous les champs sont obligatoires', 'error');
    return;
  }

  if (id) {
    const bulletin = bulletins.find(b => b.id === id);
    if (bulletin) {
      bulletin.employe = employe;
      bulletin.mois = mois;
      bulletin.brut = brut;
      bulletin.cotisations = cotisations;
      bulletin.net = net;
      bulletin.status = status;
      showToast('Bulletin mis à jour avec succès', 'success');
    }
  } else {
    const newId = Math.max(...bulletins.map(b => b.id), 0) + 1;
    bulletins.push({ id: newId, employe, mois, brut, cotisations, net, status });
    showToast('Bulletin créé avec succès', 'success');
  }

  saveData();
  renderTable();
  closeFormModal();
}

function confirmDelete() {
  if (!currentDeleteId) return;
  bulletins = bulletins.filter(b => b.id !== currentDeleteId);
  saveData();
  renderTable();
  showToast('Bulletin supprimé avec succès', 'success');
  closeDeleteModal();
}

// ============ INITIALIZATION ============
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initData);
} else {
  initData();
}
</script>
</body>
</html>
